{% if section.settings.collection.products.size > 0 %}
<section class="purchase-wrp">
        <div class="container">
          <div class="purchase-block">
            <h2>{{ section.settings.heading }}</h2>
            <div class="row">
              <div class="col-md-8 col-sm-12">
                <div class="row">
                  {%- for product in section.settings.collection.products limit: 4 -%}
                        {% render 'cart-product',
                      card_product: product,
                      media_aspect_ratio: section.settings.image_ratio,
                      image_shape: section.settings.image_shape,
                      show_secondary_image: section.settings.show_secondary_image,
                      show_vendor: section.settings.show_vendor,
                      show_rating: section.settings.show_rating,
                      show_quick_add: section.settings.enable_quick_add,
                      section_id: section.id,
                          color: section.settings.btn-color
                    %}
                        {% endfor %}
                </div>
                <a href="{{ section.settings.btn-link }}" class="btn-secondary"
                  ><i class="fa fa-angle-left"></i>{{ section.settings.btn-text }}</a
                >
              </div>
            </div>
          </div>
        </div>
      </section>
      {% endif %}
{% schema %}
  {
    "name": "Cart products",
    "settings": [
      {
        "type": "text",
        "id": "heading",
        "label": "Heading"
        },
         {
        "type": "text",
        "id": "btn-text",
        "label": "Button text"
        },
      {
      "type": "collection",
      "id": "collection",
      "label": "t:sections.featured-collection.settings.collection.label"
      },
         {
        "type": "url",
        "id": "btn-link",
        "label": "Button link"
        },
      {
          "type": "color",
          "id": "btn-color",
          "label": "Button background"
        }
    ],
    "presets": [
      {
        "name": "Cart products"
      }
    ]
  }
{% endschema %}