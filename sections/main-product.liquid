                              </select>
                            </div>
                          </quantity-input>
                        </li>
                        <li>
                          {% if product.metafields.custom.upsell_product != blank %}
                            <button
                              type="button"
                              class="btn-orange combined_atc-btn"
                              data-variant="{{ product.selected_or_first_available_variant.id }}"
                              data-qty="1"
                              style="background: {{ block.settings.btn-color }};"
                              {% if product.selected_or_first_available_variant.available == false %}
                                disabled
                              {% endif %}
                            >
                              {%- if product.selected_or_first_available_variant.available == false -%}
                                {{ 'products.product.sold_out' | t }}
                              {%- else -%}
                                In winkelwagen
                              {%- endif -%}
                              {%- render 'loading-spinner' -%}
                            </button>
                            <script>
                              // Prevent multiple event listeners
                              if (!window.combinedAtcBtnInitialized) {
                                window.combinedAtcBtnInitialized = true;
                                $(document).on('click', '.combined_atc-btn', function () {
                                // Prevent multiple simultaneous cart additions
                                if (window.cartAddingInProgress) {
                                  return;
                                }
                                window.cartAddingInProgress = true;
                                
                                var cart_items_array = [];
                                $('.combined_atc-btn').find('.loading__spinner').removeClass('hidden');
                                if ($('.form-check-input#checkbox1').prop('checked')) {
                                  var care_kit_variant_id = $('.form-check-input#checkbox1').val();
                                  
                                  // Get the main product variant ID - try multiple methods
                                  var main_product_variant_id = null;
                                  
                                  // Method 1: Try to get from variant-selects component (most reliable)
                                  var variantSelects = document.querySelector('#variant-selects-{{ section.id }}');
                                  if (variantSelects && variantSelects.currentVariant) {
                                    main_product_variant_id = variantSelects.currentVariant.id.toString();
                                  }
                                  
                                  // Method 2: Try from form input (may be hidden but should still have value)
                                  if (!main_product_variant_id) {
                                    var productForm = $('#product-form-{{ section.id }}');
                                    main_product_variant_id = productForm.find('input[name="id"]').val();
                                  }
                                  
                                  // Method 3: Try class selector
                                  if (!main_product_variant_id) {
                                    main_product_variant_id = $('.product-variant-id').val();
                                  }
                                  
                                  // Method 4: Try from button data attribute (fallback, may be stale)
                                  if (!main_product_variant_id) {
                                    main_product_variant_id = $(this).data('variant');
                                  }
                                  
                                  // Get quantity
                                  var main_product_qty = $('.product-form_quantity').val() || $('#Quantity-{{ section.id }}').val() || 1;
                                  
                                  // Validate that we have both variant IDs
                                  if (!main_product_variant_id || main_product_variant_id === '' || main_product_variant_id === 'undefined' || !care_kit_variant_id || care_kit_variant_id === '') {
                                    console.error('Missing variant IDs:', { 
                                      main: main_product_variant_id, 
                                      careKit: care_kit_variant_id
                                    });
                                    $('.combined_atc-btn').find('.loading__spinner').addClass('hidden');
                                    window.cartAddingInProgress = false;
                                    return;
                                  }

                                  // Ensure we have valid numeric IDs
                                  main_product_variant_id = main_product_variant_id.toString().trim();
                                  care_kit_variant_id = care_kit_variant_id.toString().trim();

                                  // Cart Ajax Function
                                  Shopify.queue = [];

                                  // Add both variants: main product first, then care kit
                                  Shopify.queue.push({
                                    variantId: main_product_variant_id,
                                    quantity: parseInt(main_product_qty) || 1
                                  });
                                  
                                  Shopify.queue.push({
                                    variantId: care_kit_variant_id,
                                    quantity: 1  // Care kit always quantity 1
                                  });
                                  
                                  var itemsAdded = 0;
                                  var totalItems = Shopify.queue.length;
                                  var lastAddedItem = null;
                                
                                Shopify.moveAlong = function () {
                                    // If we still have requests in the queue, let's process the next one.
                                    if (Shopify.queue.length) {
                                      var request = Shopify.queue.shift();
                                      var req = request.variantId;
                                      var qty = request.quantity;
                                      var data = 'id=' + req + '&quantity=' + qty;
                                      $.ajax({
                                        type: 'POST',
                                        url: '/cart/add.js',
                                        dataType: 'json',
                                        data: data,
                                        success: function (res) {
                                          itemsAdded++;
                                          lastAddedItem = res;
                                          Shopify.moveAlong();
                                        },
                                        error: function (xhr, status, error) {
                                          if (Shopify.queue.length) {
                                            Shopify.moveAlong();
                                          } else {
                                            $('.combined_atc-btn').find('.loading__spinner').addClass('hidden');
                                            window.cartAddingInProgress = false;
                                          }
                                        },
                                      });
                                    } else {
                                      // All items have been added, now fetch cart sections and trigger notification
                                      if (itemsAdded === totalItems && lastAddedItem) {
                                        var cartNotification = document.querySelector('cart-notification');
                                        if (cartNotification) {
                                          // Get sections to render
                                          var sectionsToRender = cartNotification.getSectionsToRender().map(function(section) {
                                            return section.id;
                                          });
                                          
                                          // Fetch cart with sections
                                          var sectionsUrl = '/cart.js?sections=' + sectionsToRender.join(',');
                                          fetch(sectionsUrl)
                                            .then(function(response) {
                                              return response.json();
                                            })
                                            .then(function(cartData) {
                                              // Create response object similar to what product-form.js expects
                                              var response = {
                                                sections: cartData.sections || {},
                                                key: lastAddedItem.key,
                                                item_count: cartData.item_count
                                              };
                                              
                                              // Update cart count
                                              $(document)
                                                .find('.navtop-row #cart-icon-bubble')
                                                .html(
                                                  '<img src="https://cdn.shopify.com/s/files/1/0563/8412/7158/files/head-icon3.svg?v=1717136574" width="34" height="34" alt=""><span>' +
                                                    cartData.item_count +
                                                    '</span>'
                                                );
                                              
                                              // Publish cart update event
                                              if (typeof publish !== 'undefined' && typeof PUB_SUB_EVENTS !== 'undefined') {
                                                publish(PUB_SUB_EVENTS.cartUpdate, {
                                                  source: 'combined-atc',
                                                  productVariantId: main_product_variant_id,
                                                  cartData: response
                                                });
                                              }
                                              
                                              // Trigger cart notification
                                              cartNotification.setActiveElement(document.activeElement);
                                              cartNotification.renderContents(response);
                                              
                                              // Hide loading spinner
                                              $('.combined_atc-btn').find('.loading__spinner').addClass('hidden');
                                              window.cartAddingInProgress = false;
                                            })
                                            .catch(function(error) {
                                              // Fallback: just update cart count
                                              jQuery.getJSON('/cart.js', function (cart) {
                                                $(document)
                                                  .find('.navtop-row #cart-icon-bubble')
                                                  .html(
                                                    '<img src="https://cdn.shopify.com/s/files/1/0563/8412/7158/files/head-icon3.svg?v=1717136574" width="34" height="34" alt=""><span>' +
                                                      cart.item_count +
                                                      '</span>'
                                                  );
                                                $('.combined_atc-btn').find('.loading__spinner').addClass('hidden');
                                                window.cartAddingInProgress = false;
                                              });
                                            });
                                        } else {
                                          // No cart notification, just update cart count
                                          jQuery.getJSON('/cart.js', function (cart) {
                                            $(document)
                                              .find('.navtop-row #cart-icon-bubble')
                                              .html(
                                                '<img src="https://cdn.shopify.com/s/files/1/0563/8412/7158/files/head-icon3.svg?v=1717136574" width="34" height="34" alt=""><span>' +
                                                  cart.item_count +
                                                  '</span>'
                                              );
                                            $('.combined_atc-btn').find('.loading__spinner').addClass('hidden');
                                            window.cartAddingInProgress = false;
                                          });
                                        }
                                      }
                                    }
                                  };
                                  Shopify.moveAlong();
                                } else {
                                  // Let the regular form submission handle this case
                                  $('.product-form .form .product-form__buttons .product-form__submit').trigger(
                                    'click'
                                  );
                                  // Reset the cart adding flag since we're delegating to the form
                                  window.cartAddingInProgress = false;
                                }
                              });
                              }
                            </script>
