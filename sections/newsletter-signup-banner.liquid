<section class="newsletter-signup-banner">
    <div class="container">
        <div class="newsletter-signup-block">
          {% if section.settings.banner-heading != blank %}
            <div class="newsletter-left">
                <h2>{{ section.settings.banner-heading }}</h2>
            </div>
          {% endif %}
            <div class="newsletter-form">
              {% if section.settings.form-heading != blank %}
                <h6>{{ section.settings.form-heading }}</h6>
              {% endif %}
                  {% form 'customer', class: '' %}
                    <!-- <div class="form-group">
                        <input type="email" class="form-control" placeholder="Vul hier je emailadres is" />
                    </div> -->
                    <!-- <button type="submit" class="btn-orange">Aanmelden</button> -->

                    <input type="hidden" name="contact[tags]" value="newsletter">
                    <div
                      class="form-group"
                    >
                      <div class="field">
                        <input
                          id="NewsletterForm--{{ section.id }}"
                          type="email"
                          name="contact[email]"
                          class="form-control"
                          value="{{ form.email }}"
                          aria-required="true"
                          autocorrect="off"
                          autocapitalize="off"
                          autocomplete="email"
                          {% if form.errors %}
                            autofocus
                            aria-invalid="true"
                            aria-describedby="Newsletter-error--{{ section.id }}"
                          {% elsif form.posted_successfully? %}
                            aria-describedby="Newsletter-success--{{ section.id }}"
                          {% endif %}
                          placeholder="Vul hier je emailadres is"
                          required
                        >
                      </div>
                      {%- if form.errors -%}
                        <small class="newsletter-form__message form__message" id="Newsletter-error--{{ section.id }}">
                          {%- render 'icon-error' -%}
                          {{- form.errors.translated_fields.email | capitalize }}
                          {{ form.errors.messages.email -}}
                        </small>
                      {%- endif -%}
                    </div>
                    <button
                      type="submit"
                      class="btn-orange"
                      name="commit"
                      id="Subscribe"
                    >
                      {{ section.settings.btnText }}
                    </button>
                    {%- if form.posted_successfully? -%}
                      <h3
                        class="newsletter-form__message newsletter-form__message--success form__message"
                        id="Newsletter-success--{{ section.id }}"
                        tabindex="-1"
                        autofocus
                      >
                        {% render 'icon-success' -%}
                        {{- 'newsletter.success' | t }}
                      </h3>
                    {%- endif -%}
                  {% endform %}
                  {% if section.settings.form-conclusion != blank %}
                    <p>{{ section.settings.form-conclusion }}</p>
                  {% endif %}
            </div>
        </div>
    </div>
</section>

{% schema %}
  {
    "name": "Newsletter SignUp Banner",
    "settings": [
      {
        "type": "inline_richtext",
        "id": "banner-heading",
        "label": "Newsletter Heading"
      },
      {
        "type": "inline_richtext",
        "id": "form-heading",
        "label": "Form Heading"
      },
      {
        "type": "text",
        "id": "btnText",
        "label": "Button Text"
      },
      {
        "type": "inline_richtext",
        "id": "form-conclusion",
        "label": "Form Conclusion"
      }
    ],
    "presets": [
      {
        "name": "Newsletter SignUp Banner"
      }
    ]
  }
{% endschema %}