                    </div>
                </div>
            </section>
{% schema %}
  {
    "name": "Deals section",
    "settings": [
      {
      "type": "inline_richtext",
      "id": "title",
      "label": "Title"
      }
    ],
    "blocks": [
    {
      "type": "text",
      "name": "Images",
      "settings": [
         {
        "type": "image_picker",
        "id": "image",
        "label": "Image"
        },
        {
        "type": "text",
        "id": "alt",
        "label": "Alt text"
        },
         {
        "type": "text",
        "id": "heading",
        "label": "Heading"
        },
         {
        "type": "text",
        "id": "text",
        "label": "Button text"
        },
         {
        "type": "url",
        "id": "url",
        "label": "Button link"
        }
      ]
    }
  ],
    "presets": [
      {
        "name": "Deals section"
      }
    ]
  }
{% endschema %}