<section class="deals-wrp">
                <div class="container">
                    <div class="titlebar">
                        <h2>{{ section.settings.title }}</h2>
                    </div>
                    <div class="deals-slider">
                      {% for block in section.blocks %}
                        <div>
                          <a href="{{ block.settings.url }}">
                            <div class="deals-box">
                                <div class="box-img">
                                    <img src="{{ block.settings.image | img_url: 'master' }}" alt="{{ block.settings.alt | escape }}">
                                </div>
                              <h4>{{ block.settings.heading }}</h4>
                                <a href="{{ block.settings.url }}" class="btn-orange">{{ block.settings.text }}</a>
                            </div>
                          </a>
                        </div>
                      {% endfor %}
