<script>
    $(document).ready(function () {
        function getSecondsUntilMidnight() {
            // Get the current time in the user's local timezone
            const now = new Date();

            // Convert current time to UTC, then to NL timezone (GMT+1 or GMT+2 in DST)
            const utcOffsetNL = now.getTimezoneOffset() / 60 + 1; // Default GMT+1 (Standard time)
            const nlOffset = now.getMonth() >= 2 && now.getMonth() <= 9 ? 2 : 1; // Adjust for DST
            const utcNow = now.getTime() + now.getTimezoneOffset() * 60000;
            const nlNow = new Date(utcNow + nlOffset * 3600000);

            // Calculate the time remaining until midnight
            const nextMidnight = new Date(nlNow.getFullYear(), nlNow.getMonth(), nlNow.getDate() + 1, 0, 0, 0);
            return (nextMidnight - nlNow) / 1000; // Return seconds
        }

        function updateTimerDisplay(secondsLeft) {
            const hours = Math.floor(secondsLeft / 3600);
            const minutes = Math.floor((secondsLeft % 3600) / 60);

            // Update the #hours element
            $("#hours").text(hours);

            // Update the #minutes element
            $("#minutes").text(minutes);
        }

        function startTimer() {
            let secondsLeft = getSecondsUntilMidnight();

            // Update the timer every second
            const interval = setInterval(() => {
                secondsLeft--;

                if (secondsLeft <= 0) {
                    clearInterval(interval); // Stop the interval
                    resetTimer(); // Reset the timer
                } else {
                    updateTimerDisplay(secondsLeft);
                }
            }, 1000);
        }

        function resetTimer() {
            startTimer(); // Restart the timer for the next day
        }

        // Initialize the timer
        startTimer();
    });
</script>

