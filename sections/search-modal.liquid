<!-- Search Modal -->
<div id="search-modal" class="search-modal--search">
  <div class="search-modal--search__overlay"></div>
  <div class="search-modal--search__container">
    <!-- Search Header -->
    <div class="search-modal--search__header">
      <div class="search-modal--search__input-container">
        <!-- Search Icon -->
        <div class="search-modal--search__icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
        </div>
        <input
          type="text"
          id="search-modal-input"
          class="search-modal--search__input"
          placeholder="Zoek naar producten..."
          autocomplete="off"
        >
        <button class="search-modal--search__clear-btn" type="button" id="search-modal-clear">Wissen</button>
        <button class="search-modal--search__go-to-search-btn" type="button" id="search-modal-go-to-search">
          Zoek
        </button>
      </div>
      <button class="search-modal--search__close-btn" type="button">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>

    <!-- Search Content -->
    <div class="search-modal--search__content">
      <!-- Loading State -->
      <div id="search-loading" class="search-modal--search__loading" style="display: none;">
        <div class="search-modal--search__spinner"></div>
        <p>Producten zoeken...</p>
      </div>

      <!-- Initial & No Results State -->
      <div id="search-no-results" class="search-modal--search__no-results">
        <div class="search-modal--search__no-results-icon">
          <i class="fa fa-search"></i>
        </div>
        <h3>Nog geen resultaten</h3>
        <p>Gebruik de zoekbalk om te beginnen of kies een categorie.</p>
        <div class="search-modal--search__suggestions">
          <button class="search-modal--search__suggestion-btn" data-search="eettafel">Eettafel</button>
          <button class="search-modal--search__suggestion-btn" data-search="stoel">Stoel</button>
          <button class="search-modal--search__suggestion-btn" data-search="eetkamerstoel">Eetkamerstoel</button>
          <button class="search-modal--search__suggestion-btn" data-search="bank">Bank</button>
          <button class="search-modal--search__suggestion-btn" data-search="salontafel">Salontafel</button>
          <button class="search-modal--search__suggestion-btn" data-search="dressoir">Dressoir</button>
          <button class="search-modal--search__suggestion-btn" data-search="buffetkast">Buffetkast</button>
          <button class="search-modal--search__suggestion-btn" data-search="mangohouten">Mangohouten</button>
          <button class="search-modal--search__suggestion-btn" data-search="zwart">Zwart</button>
          {% comment %} BLACK FRIDAY SUGGESTION - REMOVE AFTER BLACK FRIDAY {% endcomment %}
          <button class="search-modal--search__suggestion-btn search-modal--search__black-friday-suggestion" data-navigate="/collections/lente-deals">
            <div class="notification-bar" style="background:none!important; padding: 0px!important; border-radius: 10px!important;">
              <div class="notification-block" style="justify-content: left!important;">
                <h6 style="padding: 4px 10px !important; width: 100%; border-radius: 5px;">
                  <b>PAAS</b>
                  <span>DEALS</span>
                </h6>
              </div>
            </div>
          </button>
          {% comment %} END BLACK FRIDAY SUGGESTION {% endcomment %}
        </div>
      </div>

      <!-- Search Results -->
      <div id="search-results" class="search-modal--search__results">
        <!-- Dynamic results will be populated here -->
      </div>

      <!-- Search Stats -->
      <div id="search-stats" class="search-modal--search__stats" style="display: none;">
        <span id="search-count">0 resultaten gevonden</span>
      </div>

      <!-- Infinite Scroll Loading Indicator -->
      <div id="search-infinite-loading" class="search-modal--search__infinite-loading">
        <div class="search-modal--search__infinite-spinner"></div>
        <span>Meer resultaten laden...</span>
      </div>
    </div>
  </div>
</div>

<style>
  :root {
    --brand-primary: #fb5a00;
    --brand-primary-light: #fff5ef;
    --text-primary: #1a1a1a;
    --text-secondary: #666;
    --background-light: #ffffff;
    --background-medium: #f8f9fa;
    --border-color: #e5e7eb;
    --transition-fast: 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Search Modal Base */
  .search-modal--search {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 9999;
    opacity: 0;
    visibility: hidden;
    display: flex;
    transition: opacity 0.3s ease, visibility 0.3s ease;
    font-family: 'Poppins', sans-serif;
  }

  .search-modal--search.active {
    opacity: 1;
    visibility: visible;
  }

  .search-modal--search__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(5px);
  }

  .search-modal--search__container {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    background: var(--background-light);
    transform: scale(0.95);
    transition: transform 0.3s ease;
  }

  .search-modal--search.active .search-modal--search__container {
    transform: scale(1);
  }

  /* Header */
  .search-modal--search__header {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    border-bottom: 1px solid var(--border-color);
    background: var(--background-light);
    flex-shrink: 0;
  }

  .search-modal--search__input-container {
    position: relative;
    display: flex;
    align-items: center;
    width: 100%;
  }

  .search-modal--search__icon {
    position: absolute;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-secondary);
    pointer-events: none;
  }

  .search-modal--search__input {
    width: 100%;
    padding: 0.875rem 3rem 0.875rem 3.5rem; /* 14px 48px 14px 56px */
    font-size: 16px; /* 16px minimum to prevent mobile zoom */
    font-family: 'Poppins', sans-serif;
    border: 1px solid var(--border-color);
    border-radius: 8px;
    outline: none;
    transition: all var(--transition-fast);
    background: var(--background-medium);
    color: var(--text-primary);
    -webkit-appearance: none;
  }

  .search-modal--search__input:focus {
    border-color: var(--brand-primary);
    background: var(--background-light);
    box-shadow: 0 0 0 3px var(--brand-primary-light);
  }

  .search-modal--search__input:focus ~ .search-modal--search__go-to-search-btn,
  .search-modal--search__input:not(:placeholder-shown) ~ .search-modal--search__go-to-search-btn {
    opacity: 1;
    transform: translateY(-50%) scale(1);
    pointer-events: auto;
  }

  .search-modal--search__go-to-search-btn {
    position: absolute;
    right: 0.5rem; /* 8px */
    top: 50%;
    transform: translateY(-50%) scale(0.9);
    opacity: 0;
    pointer-events: none;
    padding: 0.5rem 1rem; /* 8px 16px */
    background: var(--brand-primary);
    color: white;
    font-size: 16px; /* 16px to match website standards */
    font-weight: 500;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .search-modal--search__go-to-search-btn:hover {
    background: #e15100;
  }

  .search-modal--search__clear-btn {
    position: absolute;
    right: 5.5rem; /* Position to the left of the search button with proper spacing */
    top: 50%;
    transform: translateY(-50%) scale(0.9);
    opacity: 0;
    pointer-events: none;
    padding: 0.5rem 1rem; /* 8px 16px - more horizontal padding for text */
    background: var(--background-medium);
    color: var(--text-secondary);
    border: none;
    border-radius: 6px;
    cursor: pointer;
    transition: all var(--transition-fast);
    font-size: 16px; /* 16px to match website standards */
    font-weight: 500;
  }

  .search-modal--search__clear-btn:hover {
    background: var(--border-color);
    color: var(--text-primary);
  }

  .search-modal--search__input:focus ~ .search-modal--search__clear-btn,
  .search-modal--search__input:not(:placeholder-shown) ~ .search-modal--search__clear-btn {
    opacity: 1;
    transform: translateY(-50%) scale(1);
    pointer-events: auto;
  }

  .search-modal--search__close-btn {
    border: none;
    background: none;
    cursor: pointer;
    color: var(--text-secondary);
    padding: 0.5rem;
    border-radius: 50%;
    display: flex;
    flex-shrink: 0; /* Prevent button from shrinking */
    transition: background-color var(--transition-fast), color var(--transition-fast);
  }

  .search-modal--search__close-btn:hover {
    background-color: var(--background-medium);
    color: var(--text-primary);
  }

  /* Content Area */
  .search-modal--search__content {
    flex-grow: 1;
    overflow-y: auto;
    overflow-x: hidden; /* Prevent horizontal scrolling */
    padding: 1rem 0.75rem 6rem 0.75rem;
    display: flex;
    flex-direction: column;
    min-height: 0; /* Allow flex item to shrink */
    max-height: 100%; /* Ensure it doesn't exceed container height */
    width: 100%; /* Ensure content area takes full width */
    box-sizing: border-box; /* Include padding in width calculation */
  }

  /* Loading State */
  .search-modal--search__loading {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: var(--text-secondary);
    margin: auto;
  }

  .search-modal--search__spinner {
    width: 3rem; /* 48px */
    height: 3rem; /* 48px */
    border: 4px solid var(--border-color);
    border-top-color: var(--brand-primary);
    border-radius: 50%;
    animation: spin 1s linear infinite;
    margin-bottom: 1.5rem;
  }

  /* No Results & Initial State */
  .search-modal--search__no-results {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    margin: auto;
    padding: 1rem;
  }

  .search-modal--search__no-results-icon {
    color: #cbd5e1;
    margin-bottom: 1.5rem;
    font-size: 3rem;
  }

  .search-modal--search__no-results h3 {
    font-weight: 600;
    margin: 0 0 0.5rem;
    color: var(--text-primary);
  }

  .search-modal--search__no-results p {
    color: var(--text-secondary);
    margin: 0 0 2rem;
  }

  .search-modal--search__suggestions {
    display: flex;
    gap: 0.75rem; /* 12px */
    flex-wrap: wrap;
    justify-content: center;
  }

  .search-modal--search__suggestion-btn {
    padding: 0.75rem 1.5rem; /* 12px 24px */
    background: var(--background-medium);
    border: 1px solid var(--border-color);
    border-radius: 30px;
    cursor: pointer;
    transition: all var(--transition-fast);
    font-size: 16px; /* 16px to match website standards */
    font-weight: 500;
    color: var(--text-primary);
  }

  .search-modal--search__suggestion-btn:hover {
    background: var(--brand-primary);
    color: white;
    border-color: var(--brand-primary);
    transform: translateY(-2px);
  }

  /* Black Friday Suggestion Button - REMOVE AFTER BLACK FRIDAY */
  .search-modal--search__black-friday-suggestion {
    padding: 0 !important;
    background: transparent !important;
    border: none !important;
    border-radius: 10px !important;
  }

  .search-modal--search__black-friday-suggestion:hover {
    background: transparent !important;
    transform: translateY(-2px);
  }

  .search-modal--search__black-friday-suggestion .notification-bar {
    margin: 0;
  }
  /* END Black Friday Suggestion Button */

  /* Results */
  .search-modal--search__results {
    display: none; /* Initially hidden */
    grid-template-columns: 1fr;
    gap: 0.75rem; /* Reduced gap for mobile */
    width: 100%;
    max-width: 100%;
    grid-auto-rows: minmax(80px, auto); /* Mobile: smaller minimum height for horizontal layout */
    box-sizing: border-box; /* Include padding and borders in width calculation */
  }

  .search-modal--search__results.show {
    display: grid !important;
  }

  .search-modal--search__result-item {
    display: flex;
    align-items: flex-start; /* Align to top to accommodate multi-line titles */
    gap: 0.75rem; /* Reduced gap for mobile */
    padding: 0.5rem; /* 8px - reduced padding for mobile */
    border-radius: 8px;
    transition: background-color var(--transition-fast), box-shadow var(--transition-fast);
    cursor: pointer;
    text-decoration: none !important;
    color: inherit;
    border: 1px solid transparent;
    box-sizing: border-box; /* Include padding and borders in width calculation */
    min-width: 0; /* Allow item to shrink below content size */
  }

  .search-modal--search__result-item:link,
  .search-modal--search__result-item:visited,
  .search-modal--search__result-item:active {
    text-decoration: none !important;
  }

  .search-modal--search__result-item:hover {
    background: var(--background-medium);
    border-color: var(--border-color);
    text-decoration: none !important;
  }

  .search-modal--search__result-image {
    width: 70px; /* Slightly larger for mobile */
    height: 70px; /* Slightly larger for mobile */
    border-radius: 6px;
    object-fit: cover;
    flex-shrink: 0;
    background-color: var(--background-medium);
  }

  .search-modal--search__image-placeholder {
    width: 70px;
    height: 70px;
    border-radius: 6px;
    background-color: var(--background-medium);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .search-modal--search__placeholder-icon {
    color: var(--text-secondary);
    opacity: 0.5;
    font-size: 1.5rem;
  }

  .search-modal--search__result-content {
    flex-grow: 1;
    min-width: 0;
    width: 100%; /* Ensure content takes full width */
    overflow: hidden; /* Prevent content overflow */
  }

  .search-modal--search__result-title {
    font-size: 14px; /* 14px - smaller for better fit */
    font-weight: 600;
    margin: 0 0 0.25rem;
    color: var(--text-primary);
    line-height: 1.4;
    white-space: normal; /* Allow text to wrap */
    overflow: visible; /* Show full text */
    text-overflow: unset; /* Remove ellipsis */
    word-wrap: break-word; /* Break long words if needed */
  }

  .search-modal--search__result-price {
    font-size: 16px; /* 16px to match website standards */
    font-weight: 500;
    color: var(--brand-primary);
  }

  .search-modal--search__result-compare-price {
    font-size: 14px; /* 14px to match website standards */
    color: var(--text-secondary);
    text-decoration: line-through;
    margin-left: 0.5rem;
  }

  /* Search term highlighting */
  .search-highlight {
    background-color: var(--brand-primary-light);
    color: var(--brand-primary);
    padding: 1px 3px;
    border-radius: 3px;
    font-weight: 600;
  }

  .search-modal--search__stats {
    text-align: center;
    position: absolute;
    padding: 1rem;
    color: var(--text-secondary);
    border-top: 1px solid var(--border-color);
    background: var(--background-medium);
    bottom: 0px;
    width: 100%;
  }

  /* Infinite Scroll Loading */
  .search-modal--search__infinite-loading {
    display: none;
    text-align: center;
    padding: 1.5rem;
    color: var(--text-secondary);
    font-size: 0.875rem;
    width: 100%;
    max-width: 100%;
    flex-shrink: 0; /* Prevent shrinking */
  }

  .search-modal--search__infinite-loading.show {
    display: block;
  }

  .search-modal--search__infinite-spinner {
    width: 1.5rem; /* 24px */
    height: 1.5rem; /* 24px */
    border: 3px solid var(--border-color);
    border-top-color: var(--brand-primary);
    border-radius: 50%;
    animation: spin 1s linear infinite;
    margin: 0 auto 0.75rem;
  }

  @keyframes spin {
    0% {
      transform: rotate(0deg);
    }
    100% {
      transform: rotate(360deg);
    }
  }

  /* Tablet and Desktop Styles */
  @media (min-width: 768px) {
    .search-modal--search__container {
      max-width: 90vw;
      width: 1024px;
      max-height: 85vh;
      margin: auto;
      border-radius: 12px;
      box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
      overflow: hidden;
    }

    .search-modal--search__header {
      padding: 1.5rem; /* 24px */
    }

    .search-modal--search__input {
      font-size: 18px; /* 18px for desktop */
      padding: 1.125rem 3rem 1.125rem 3.5rem; /* 18px 48px 18px 56px */
    }

    .search-modal--search__go-to-search-btn {
      opacity: 1;
      transform: translateY(-50%) scale(1);
      pointer-events: auto;
      right: 0.75rem; /* Slightly more space on desktop */
    }

    .search-modal--search__clear-btn {
      opacity: 1;
      transform: translateY(-50%) scale(1);
      pointer-events: auto;
      right: 6rem; /* More space on desktop for better alignment */
    }

    .search-modal--search__content {
      padding: 2rem 2rem 6rem 2rem; /* 32px - desktop padding */
    }

    /* Grid layout for results on desktop */
    .search-modal--search__results.show {
      grid-template-columns: repeat(4, 1fr);
      gap: 1.5rem 1rem;
      align-items: start; /* Prevent stretching */
      grid-auto-rows: minmax(200px, auto); /* Desktop: proper minimum height for vertical layout */
    }

    .search-modal--search__result-item {
      flex-direction: column;
      align-items: flex-start;
      padding: 1rem; /* Desktop padding */
      gap: 0.75rem;
      height: fit-content; /* Prevent height issues */
      width: 100%; /* Ensure items take full width of grid cell */
      max-width: 100%; /* Prevent items from exceeding grid cell width */
      overflow: visible; /* Allow content to show fully */
      background: var(--background-medium); /* Default background on desktop */
      border-color: var(--border-color); /* Default border on desktop */
    }

    .search-modal--search__result-image {
      width: 100%;
      height: 180px;
      object-fit: cover; /* Ensure consistent image sizing */
    }

    .search-modal--search__image-placeholder {
      width: 100%;
      height: 180px;
    }

    .search-modal--search__result-title {
      font-size: 16px; /* 16px for desktop - smaller and more readable */
    }

    .search-modal--search__result-item:hover {
