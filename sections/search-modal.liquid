      // Calculate average results
      const avgResults =
        searches.length > 0 ? Math.round(searches.reduce((sum, s) => sum + s.resultCount, 0) / searches.length) : 0;

      // Get recent searches
      const recentSearches = searches.slice(-5).reverse();

