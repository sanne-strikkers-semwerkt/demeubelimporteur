    highlightSearchTerm(text, searchTerm) {
      if (!searchTerm || !text) return text;
      const regex = new RegExp(`(${searchTerm.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi');
      return text.replace(regex, '<mark class="search-highlight">$1</mark>');
    }

    formatPrice(price) {
      if (!price) return '';
      const numPrice = typeof price === 'string' ? parseFloat(price) : price;
      return new Intl.NumberFormat('nl-NL', {
        style: 'currency',
        currency: 'EUR',
        minimumFractionDigits: 0,
        maximumFractionDigits: 2,
      }).format(numPrice);
    }

    debounce(func, wait) {
      let timeout;
      return function executedFunction(...args) {
        const later = () => {
          clearTimeout(timeout);
          func(...args);
        };
        clearTimeout(timeout);
        timeout = setTimeout(later, wait);
      };
    }

    // Caching methods
    getCachedResults(key) {
      try {
        const cached = localStorage.getItem(key);
        if (cached) {
          const { data, timestamp, expiry } = JSON.parse(cached);
          if (Date.now() < timestamp + expiry) {
            return data;
          } else {
            localStorage.removeItem(key);
          }
        }
      } catch (error) {
        console.warn('Cache read error:', error);
      }
      return null;
    }

    cacheResults(key, data, expiry) {
      try {
        const cacheData = {
          data,
          timestamp: Date.now(),
          expiry,
        };
        localStorage.setItem(key, JSON.stringify(cacheData));
      } catch (error) {
        console.warn('Cache write error:', error);
      }
    }

    // Analytics tracking
    trackSearch(query, resultCount) {
      try {
        // Track search queries for analytics
        const searchData = {
          query: query.toLowerCase(),
          resultCount,
          timestamp: Date.now(),
          userAgent: navigator.userAgent,
        };

        // Store in localStorage for analytics
        const searches = JSON.parse(localStorage.getItem('search_analytics') || '[]');
        searches.push(searchData);

        // Keep only last 100 searches
        if (searches.length > 100) {
          searches.splice(0, searches.length - 100);
        }

        localStorage.setItem('search_analytics', JSON.stringify(searches));

        // Send to analytics if available
        if (typeof gtag !== 'undefined') {
          gtag('event', 'search', {
            search_term: query,
            results_count: resultCount,
          });
        }
      } catch (error) {
        console.warn('Analytics tracking error:', error);
      }
    }

    // Push search to Shopify API for analytics (async, non-blocking)
    async pushSearchToShopifyAPI(query, resultCount) {
      try {
        // Use the search page method for analytics tracking
        // This creates a "virtual" search that Shopify can track
        const searchPageUrl = `/search?q=${encodeURIComponent(query)}`;

        // Use a hidden iframe to trigger the search page load
        const iframe = document.createElement('iframe');
        iframe.style.display = 'none';
        iframe.style.width = '0';
        iframe.style.height = '0';
        iframe.src = searchPageUrl;
        document.body.appendChild(iframe);

        // Log success
        console.log('✅ Search pushed to Shopify analytics:', query);

        // Remove iframe after a short delay
        setTimeout(() => {
          if (iframe.parentNode) {
            iframe.parentNode.removeChild(iframe);
          }
        }, 2000);
      } catch (error) {
        // Silently fail - this is just for analytics
        console.debug('Shopify analytics push failed (non-critical):', error.message);
      }
    }

    // Get popular search terms
    getPopularSearches() {
      try {
        const searches = JSON.parse(localStorage.getItem('search_analytics') || '[]');
        const searchCounts = {};

        searches.forEach((search) => {
          const term = search.query.toLowerCase();
          searchCounts[term] = (searchCounts[term] || 0) + 1;
        });

        return Object.entries(searchCounts)
          .sort(([, a], [, b]) => b - a)
          .slice(0, 5)
          .map(([term]) => term);
      } catch (error) {
        console.warn('Popular searches error:', error);
        return [];
      }
    }

    // Fuzzy matching for typos and variations
    fuzzyMatch(query, text, threshold = 0.6) {
      if (!query || !text) return false;

      const queryWords = query.split(/\s+/);
      const textWords = text.split(/\s+/);

      let totalScore = 0;
      let matches = 0;

      for (const queryWord of queryWords) {
        let bestScore = 0;
        for (const textWord of textWords) {
          const score = this.calculateSimilarity(queryWord, textWord);
          if (score > bestScore) {
            bestScore = score;
          }
        }
        totalScore += bestScore;
        if (bestScore > threshold) {
          matches++;
        }
      }

      return matches > 0 && totalScore / queryWords.length > threshold;
    }

    // Calculate similarity between two strings (Levenshtein distance based)
    calculateSimilarity(str1, str2) {
      const longer = str1.length > str2.length ? str1 : str2;
      const shorter = str1.length > str2.length ? str2 : str1;

      if (longer.length === 0) return 1.0;

      const distance = this.levenshteinDistance(longer, shorter);
      return (longer.length - distance) / longer.length;
    }

    // Levenshtein distance calculation
    levenshteinDistance(str1, str2) {
      const matrix = [];

      for (let i = 0; i <= str2.length; i++) {
        matrix[i] = [i];
      }

      for (let j = 0; j <= str1.length; j++) {
        matrix[0][j] = j;
      }

      for (let i = 1; i <= str2.length; i++) {
        for (let j = 1; j <= str1.length; j++) {
          if (str2.charAt(i - 1) === str1.charAt(j - 1)) {
            matrix[i][j] = matrix[i - 1][j - 1];
          } else {
            matrix[i][j] = Math.min(matrix[i - 1][j - 1] + 1, matrix[i][j - 1] + 1, matrix[i - 1][j] + 1);
          }
        }
      }

      return matrix[str2.length][str1.length];
    }

    // Show search analytics dashboard
