    }
  }

  @media (min-width: 1024px) {
    .search-modal--search__results.show {
      grid-template-columns: repeat(4, 1fr);
      gap: 1.5rem 1.25rem;
    }
  }
</style>

<script>
  // --- DO NOT CHANGE ANY LOGIC ---
  class SearchModal {
    constructor() {
      this.modal = document.getElementById('search-modal');
      this.input = document.getElementById('search-modal-input');
      this.results = document.getElementById('search-results');
      this.loading = document.getElementById('search-loading');
      this.noResults = document.getElementById('search-no-results');
      this.stats = document.getElementById('search-stats');
      this.searchCount = document.getElementById('search-count');
      this.infiniteLoading = document.getElementById('search-infinite-loading');
      this.goToSearchBtn = document.getElementById('search-modal-go-to-search');
      this.clearBtn = document.getElementById('search-modal-clear');

      this.isOpen = false;
      this.currentQuery = '';
      this.allResults = [];
      this.visibleCount = 18; // Start with 18 items (6 rows of 3 on desktop)
      this.isLoading = false;
      this.isLoadingMore = false;
      this.hasMoreResults = true;

      this.init();
    }

    init() {
      document.addEventListener('click', (e) => {
        if (
          e.target.matches('.search-modal--search__close-btn') ||
          e.target.matches('.search-modal--search__overlay') ||
          e.target.closest('.search-modal--search__close-btn')
        ) {
          this.close();
        }
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && this.isOpen) {
          this.close();
        }
        if (e.key === '/' && !this.isOpen && !e.target.matches('input, textarea')) {
          e.preventDefault();
          this.open();
        }
      });

      this.input.addEventListener(
        'input',
        this.debounce((e) => {
          this.search(e.target.value);
          this.toggleActionButtons();
        }, 300).bind(this)
      );

      this.input.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
          e.preventDefault();
          this.search(e.target.value);
        }
      });

      this.goToSearchBtn.addEventListener('click', () => {
        this.goToSearchPage();
      });

      if (this.clearBtn) {
        this.clearBtn.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          this.clearInput();
        });
      }

      document.addEventListener('click', (e) => {
        const suggestionBtn = e.target.closest('.search-modal--search__suggestion-btn');
        if (suggestionBtn) {
          // Check if it's the Black Friday button with navigation
          if (suggestionBtn.dataset.navigate) {
            window.location.href = suggestionBtn.dataset.navigate;
            return;
          }
          // Regular search suggestion
          const query = suggestionBtn.dataset.search;
          if (query) {
            this.input.value = query;
            this.search(query);
          }
        }
      });

      if (this.results) {
        const contentArea = this.modal.querySelector('.search-modal--search__content');
        contentArea.addEventListener('scroll', () => {
          this.handleInfiniteScroll(contentArea);
        });
      }

      this.modal.addEventListener('touchstart', (e) => {
        if (e.target === this.modal || e.target.matches('.search-modal--search__overlay')) {
          this.close();
        }
      });
    }

    open() {
      this.modal.classList.add('active');
      this.isOpen = true;
      document.body.style.overflow = 'hidden';

      // Clear any previous state
      this.clearResults();

      // Focus input after modal animation starts
      setTimeout(() => {
        this.input.focus();
      }, 100);
    }

    close() {
      this.modal.classList.remove('active');
      this.isOpen = false;
      this.input.value = '';
      this.clearResults();
      document.body.style.overflow = '';
    }

    async search(query) {
      if (!query.trim()) {
        this.clearResults();
        return;
      }

      // Special analytics search
      if (query.toLowerCase() === 'analytics' || query.toLowerCase() === 'stats') {
        this.showAnalytics();
        return;
      }

      this.currentQuery = query;
      this.isLoading = true;
      this.showLoading();

      // Check cache first
      const cacheKey = `search_v2_${query.toLowerCase()}`;
      const cachedResults = this.getCachedResults(cacheKey);

      if (cachedResults) {
        const hiddenProductId = '15706174095694';
        this.allResults = cachedResults.filter(p => String(p.id) !== hiddenProductId);
        this.visibleCount = 18;
        this.hideLoading();
        this.displayResults();

        // Still push to Shopify API for analytics (async, don't wait)
        this.pushSearchToShopifyAPI(query, cachedResults.length);
        return;
      }

      const timeout = setTimeout(() => {
        this.hideLoading();
        this.showNoResults();
      }, 5000);

      try {
        const rawProducts = await this.fetchAllProductsFromJson();
        const products = this.normalizeProductsFromJSON(rawProducts);
        const results = this.searchInProducts(products, query);

        clearTimeout(timeout);

        // Cache results for 5 minutes
        this.cacheResults(cacheKey, results, 5 * 60 * 1000);

        this.allResults = results;
        this.visibleCount = 18; // Start with 18 items (6 rows of 3 on desktop)
        this.hideLoading();
        this.displayResults();

        // Track search for analytics (both local and Shopify)
        this.trackSearch(query, results.length);
        this.pushSearchToShopifyAPI(query, results.length);
      } catch (error) {
        console.error('Search error:', error);
        clearTimeout(timeout);
        this.hideLoading();
        this.showNoResults();
      } finally {
        this.isLoading = false;
      }
    }

    displayResults() {
      if (this.allResults.length === 0) {
        this.showNoResults();
        return;
      }
      this.hideNoResults();

      const visibleResults = this.allResults.slice(0, this.visibleCount);
      this.results.innerHTML = this.renderResultsHTML(visibleResults);
      this.results.classList.add('show');

      // Update search stats
      this.updateSearchStats();

      this.hasMoreResults = this.allResults.length > this.visibleCount;
    }

    updateSearchStats() {
      if (this.stats && this.searchCount) {
        const totalResults = this.allResults.length;
        const visibleResults = Math.min(this.visibleCount, totalResults);

        let statsText;
        if (totalResults === 0) {
          statsText = 'Geen resultaten gevonden';
        } else if (totalResults === 1) {
          statsText = '1 resultaat gevonden';
        } else if (visibleResults === totalResults) {
          statsText = `${totalResults} resultaten gevonden`;
        } else {
          statsText = `${visibleResults} van ${totalResults} resultaten`;
        }

        this.searchCount.textContent = statsText;
        this.stats.style.display = 'block';
      }
    }

    // ===== BLACK FRIDAY BADGE COMPONENT - REMOVE AFTER BLACK FRIDAY =====
    isBlackFridayProduct(product) {
      // Check if product has black-friday tag
      if (product.tags) {
        const tags = typeof product.tags === 'string' ? product.tags.toLowerCase() : product.tags.join(' ').toLowerCase();
        if (tags.includes('blackfriday2025') || tags.includes('blackfriday2025')) {
          return true;
        }
      }
      return false;
    }

    renderBlackFridayBadge() {
      // Return Black Friday badge HTML - can be removed entirely after Black Friday
      return `<div class="notification-bar" style="background:none!important; padding: 0px!important;  border-radius: 10px!important; transform: scale(0.6); transform-origin: left center;">
        <div class="notification-block" style="justify-content: left!important;">
          <h6 style="padding: 4px 10px !important; width: 100%; border-radius: 5px;">
            <b>PAAS</b>
            <span>DEALS</span>
          </h6>
        </div>
      </div>`;
    }
    // ===== END BLACK FRIDAY BADGE COMPONENT =====

    renderSingleResultHTML(product) {
      // This helper function renders a single search result item
      return `
            <img src="${product.featured_image || ''}" 
                 alt="${product.title}" 
                 class="search-modal--search__result-image"
                 onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
            <div class="search-modal--search__image-placeholder" style="display:none;">
              <div class="search-modal--search__placeholder-icon">
                <i class="fa fa-image"></i>
              </div>
            </div>
            <div class="search-modal--search__result-content">
              <h3 class="search-modal--search__result-title">${this.highlightSearchTerm(
                product.title,
                this.currentQuery
              )}</h3>
              <div class="search-modal--search__result-price">
              
                ${this.formatPrice(product.price)}
                ${
                  product.compare_at_price
                    ? `<span class="search-modal--search__result-compare-price">${this.formatPrice(
                        product.compare_at_price
                      )}</span>`
                    : ''
                }
              </div>
            </div>
        `;
    }

    renderResultsHTML(results) {
      // This is used for the INITIAL render
      return results
        .map((product) => {
          // Ensure URL is valid, fallback to search page if not
          const productUrl =
            product.url && product.url.startsWith('/products/')
              ? product.url
              : `/search?q=${encodeURIComponent(product.title || '')}`;
          
          // Add data attributes for debugging
          const debugInfo = `data-product-id="${product.id}" data-handle="${product.handle}" data-available="${product.available}"`;

          return `
                    <a href="${productUrl}" class="search-modal--search__result-item" data-url="${productUrl}" ${debugInfo}>
                        ${this.renderSingleResultHTML(product)}
                    </a>`;
        })
        .join('');
    }

    handleInfiniteScroll(scrollContainer) {
      if (this.isLoadingMore || !this.hasMoreResults) {
        return;
      }
      const { scrollTop, scrollHeight, clientHeight } = scrollContainer;
      if (scrollTop + clientHeight >= scrollHeight - 300) {
        // 300px threshold
        this.loadMoreResults();
      }
    }

    loadMoreResults() {
      if (this.isLoadingMore || !this.hasMoreResults) {
        return;
      }
      this.isLoadingMore = true;
      if (this.infiniteLoading) this.infiniteLoading.classList.add('show');

      setTimeout(() => {
        const currentCount = this.visibleCount;
        const newVisibleCount = Math.min(currentCount + 12, this.allResults.length); // Load 12 items for better infinite scroll
        const newItems = this.allResults.slice(currentCount, newVisibleCount);

        if (newItems.length > 0) {
          // Create a document fragment for better performance
          const fragment = document.createDocumentFragment();

          // Create each new item as a DOM element
          newItems.forEach((product) => {
            const resultItem = document.createElement('a');
            // Ensure URL is valid, fallback to search page if not
            const productUrl =
              product.url && product.url.startsWith('/products/')
                ? product.url
                : `/search?q=${encodeURIComponent(product.title || '')}`;

            resultItem.href = productUrl;
            resultItem.className = 'search-modal--search__result-item';
            resultItem.dataset.url = productUrl;
            resultItem.dataset.productId = product.id;
            resultItem.dataset.handle = product.handle;
            resultItem.dataset.available = product.available;
            resultItem.innerHTML = this.renderSingleResultHTML(product);
            fragment.appendChild(resultItem);
          });

          // Append all new items at once to prevent layout shifts
          if (this.results) {
            this.results.appendChild(fragment);
          }
        }

        // Update state
        this.visibleCount = newVisibleCount;
        this.hasMoreResults = this.allResults.length > this.visibleCount;
        this.isLoadingMore = false;
        if (this.infiniteLoading) this.infiniteLoading.classList.remove('show');

        // Update search stats
        this.updateSearchStats();
      }, 300); // Reduced delay for better UX
    }

    goToSearchPage() {
      const query = this.input.value.trim();
      window.location.href = query ? `/search?q=${encodeURIComponent(query)}` : '/search';
    }

    clearInput() {
      this.input.value = '';
      this.input.focus();
      this.clearResults();
      this.toggleActionButtons();
    }

    toggleActionButtons() {
      if (this.clearBtn && this.goToSearchBtn) {
        const hasText = this.input.value.trim().length > 0;

        if (hasText) {
          this.clearBtn.style.opacity = '1';
          this.clearBtn.style.transform = 'translateY(-50%) scale(1)';
          this.clearBtn.style.pointerEvents = 'auto';

          this.goToSearchBtn.style.opacity = '1';
          this.goToSearchBtn.style.transform = 'translateY(-50%) scale(1)';
          this.goToSearchBtn.style.pointerEvents = 'auto';
        } else {
          this.clearBtn.style.opacity = '0';
          this.clearBtn.style.transform = 'translateY(-50%) scale(0.9)';
          this.clearBtn.style.pointerEvents = 'none';

          this.goToSearchBtn.style.opacity = '0';
          this.goToSearchBtn.style.transform = 'translateY(-50%) scale(0.9)';
          this.goToSearchBtn.style.pointerEvents = 'none';
        }
      }
    }

    async fetchAllProductsFromJson() {
      const cacheKey = 'search_modal_products_json_full_v3';
      try {
        const cached = sessionStorage.getItem(cacheKey);
        if (cached) {
          const { data, time } = JSON.parse(cached);
          const TTL = 2 * 60 * 1000; // 2 minutes
          if (Date.now() - time < TTL && Array.isArray(data) && data.length > 0) return data;
        }
      } catch (e) {}

      const all = [];
      const perPage = 250;
      let page = 1;
      let hasMore = true;

      while (hasMore) {
        const url = `/products.json?limit=${perPage}&page=${page}`;
        const res = await fetch(url, { cache: 'no-store' });
        if (!res.ok) break;

        const data = await res.json();
        const raw = Array.isArray(data) ? data : (data.products || []);
        if (raw.length === 0) break;

        all.push.apply(all, raw);
        hasMore = raw.length >= perPage;
        page++;
        if (page > 100) break;
      }

      try {
        sessionStorage.setItem(cacheKey, JSON.stringify({ data: all, time: Date.now() }));
      } catch (e) {}

      return all;
    }

    normalizeProductsFromJSON(rawProducts) {
      if (!Array.isArray(rawProducts)) return [];
      return rawProducts.map((p) => {
        const variant = (p.variants && p.variants[0]) || {};
        const img = (p.images && p.images[0]) ? p.images[0] : null;
        const src = (typeof img === 'string') ? img : (img && img.src) ? img.src : '';
        const tags = p.tags;
        const tagsStr = Array.isArray(tags) ? (tags.join ? tags.join(' ') : '') : (typeof tags === 'string' ? tags : '');

        return {
          id: p.id,
          title: p.title || '',
          handle: p.handle || '',
          url: p.handle ? `/products/${p.handle}` : '',
          vendor: p.vendor || '',
          product_type: p.product_type || '',
          tags: tagsStr,
          featured_image: src,
          price: variant.price != null ? String(variant.price) : '',
          compare_at_price: variant.compare_at_price != null ? String(variant.compare_at_price) : null,
          available: variant.available != null ? variant.available : (p.variants && p.variants.some((v) => v.available)),
          updated_at: p.updated_at || '',
        };
      });
    }

    searchInProducts(products, query) {
      const queryLower = query.toLowerCase().trim();
      const queryWords = queryLower.split(/\s+/).filter((word) => word.length > 0);
      const results = [];
      
      // ===== BLACK FRIDAY SPECIAL SEARCH - REMOVE AFTER BLACK FRIDAY =====
      // Check if query is related to Black Friday
      const isBlackFridayQuery = (queryLower.includes('black') && queryLower.includes('friday')) || 
                                  queryLower === 'blackfriday' || 
                                  queryLower === 'black-friday';
      // ===== END BLACK FRIDAY SPECIAL SEARCH =====

      console.log('🔍 Total products to search:', products.length);

      for (const product of products) {
        // Skip products that don't have essential data for display
        if (!product.title || !product.url || !product.price || product.price === '0' || product.price === '0.00') {
          continue;
        }

        // Skip products with invalid URLs (drafts, unpublished, etc.)
        if (!product.url.startsWith('/products/')) {
          continue;
        }

        // Skip products that are truly unavailable (drafts, unpublished, etc.)
        // Note: available: false just means out of stock but still for sale
        // We only skip if there's no valid URL or essential data

        // Skip products without featured images (likely drafts/unpublished)
        if (!product.featured_image) {
          continue;
        }

        let score = 0;
        let matchFound = false;
        
        // ===== BLACK FRIDAY SPECIAL SEARCH - REMOVE AFTER BLACK FRIDAY =====
        // If user searches for "black friday", include all products with black-friday tags
        if (isBlackFridayQuery && this.isBlackFridayProduct(product)) {
          score += 200; // High score for Black Friday products when searching Black Friday
          matchFound = true;
        }
        // ===== END BLACK FRIDAY SPECIAL SEARCH =====

        // Helper function to check if all query words are found in text
        const containsAllWords = (text) => {
          if (!text) return false;
          const textLower = text.toLowerCase();
          return queryWords.every((word) => textLower.includes(word));
        };

        // Helper function to check if any query words are found in text
        const containsAnyWord = (text) => {
          if (!text) return false;
          const textLower = text.toLowerCase();
          return queryWords.some((word) => textLower.includes(word));
        };

        // Enhanced title matching with multiple scoring levels
        if (product.title) {
          const titleLower = product.title.toLowerCase();
          const titleWords = titleLower.split(/\s+/);

          // Exact match gets highest score
          if (titleLower === queryLower) {
            score += 200;
            matchFound = true;
          }
          // Starts with query gets high score
          else if (titleLower.startsWith(queryLower)) {
            score += 150;
            matchFound = true;
          }
          // Contains all words gets good score
          else if (containsAllWords(product.title)) {
            score += 120;
            matchFound = true;

            // Bonus for word order match
            const queryWords = queryLower.split(/\s+/);
            let wordOrderBonus = 0;
            for (let i = 0; i < Math.min(queryWords.length, titleWords.length); i++) {
              if (titleWords[i] === queryWords[i]) {
                wordOrderBonus += 10;
              }
            }
            score += wordOrderBonus;
          }
          // Contains any word gets basic score
          else if (containsAnyWord(product.title)) {
            score += 80;
            matchFound = true;
          }
          // Contains query as substring gets lower score
          else if (titleLower.includes(queryLower)) {
            score += 60;
            matchFound = true;
          }
          // Fuzzy matching for typos and variations
          else if (this.fuzzyMatch(queryLower, titleLower)) {
            score += 40;
            matchFound = true;
          }
        }

        // Vendor matching
        if (product.vendor && containsAnyWord(product.vendor)) {
          score += 50;
          matchFound = true;
        }

        // Product type matching
        if (product.product_type && containsAnyWord(product.product_type)) {
          score += 40;
          matchFound = true;
        }

        // Tags matching
        if (product.tags && containsAnyWord(product.tags)) {
          score += 30;
          matchFound = true;
        }

        // Handle matching
        if (product.handle && containsAnyWord(product.handle)) {
          score += 35;
          matchFound = true;
        }

        if (matchFound) {
          // Bonus for shorter titles (more specific)
          score += Math.max(0, 50 - product.title.length);

          // Bonus for exact word matches
          if (product.title) {
            const titleWords = product.title.toLowerCase().split(/\s+/);
            const exactWordMatches = queryWords.filter((queryWord) =>
              titleWords.some((titleWord) => titleWord === queryWord)
            );
            score += exactWordMatches.length * 10;
          }

          results.push({
            ...product,
            relevanceScore: score,
            price: parseFloat(product.price) || 0,
            compare_at_price: product.compare_at_price ? parseFloat(product.compare_at_price) : null,
          });
        }
      }

      console.log('🔍 Filtered results after data validation:', results.length);
      return results.sort((a, b) => b.relevanceScore - a.relevanceScore).slice(0, 100);
    }

    showLoading() {
      if (this.loading) this.loading.style.display = 'flex';
      if (this.results) this.results.style.display = 'none';
      if (this.noResults) this.noResults.style.display = 'none';
