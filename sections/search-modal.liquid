    // Export analytics data
    exportAnalytics() {
      const searches = JSON.parse(localStorage.getItem('search_analytics') || '[]');
      const dataStr = JSON.stringify(searches, null, 2);
      const dataBlob = new Blob([dataStr], { type: 'application/json' });

      const link = document.createElement('a');
      link.href = URL.createObjectURL(dataBlob);
      link.download = `search-analytics-${new Date().toISOString().split('T')[0]}.json`;
      link.click();
    }

    // Add analytics styles
    addAnalyticsStyles() {
      if (document.getElementById('analytics-styles')) return;

      const style = document.createElement('style');
      style.id = 'analytics-styles';
      style.textContent = `
        .search-analytics {
          padding: 2rem;
          background: var(--background-light);
          border-radius: 8px;
          margin: 1rem 0;
        }
        
        .search-analytics h3 {
          margin: 0 0 1.5rem 0;
          color: var(--text-primary);
        }
        
        .analytics-stats {
          display: grid;
          grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
          gap: 1rem;
          margin-bottom: 2rem;
        }
        
        .stat-item {
          text-align: center;
          padding: 1rem;
          background: var(--background-medium);
          border-radius: 6px;
        }
        
        .stat-item strong {
          display: block;
          font-size: 1.5rem;
          color: var(--brand-primary);
          margin-bottom: 0.25rem;
        }
        
        .stat-item span {
          font-size: 0.875rem;
          color: var(--text-secondary);
        }
        
        .analytics-sections {
          display: grid;
          grid-template-columns: 1fr 1fr;
          gap: 2rem;
          margin-bottom: 2rem;
        }
        
        .analytics-sections h4 {
          margin: 0 0 1rem 0;
          color: var(--text-primary);
        }
        
        .analytics-sections ol,
        .analytics-sections ul {
          list-style: none;
          padding: 0;
          margin: 0;
        }
        
        .analytics-sections li {
          display: flex;
          justify-content: space-between;
          align-items: center;
          padding: 0.5rem 0;
          border-bottom: 1px solid var(--border-color);
        }
        
        .term {
          font-weight: 500;
          color: var(--text-primary);
        }
        
        .count,
        .results {
          font-size: 0.875rem;
          color: var(--text-secondary);
        }
        
        .analytics-actions {
          display: flex;
          gap: 1rem;
          justify-content: center;
        }
        
        .btn-clear,
        .btn-export {
          padding: 0.5rem 1rem;
          border: 1px solid var(--border-color);
          border-radius: 6px;
          background: var(--background-light);
          color: var(--text-primary);
          cursor: pointer;
          transition: all var(--transition-fast);
        }
        
        .btn-clear:hover {
          background: #ff4444;
          color: white;
          border-color: #ff4444;
        }
        
        .btn-export:hover {
          background: var(--brand-primary);
          color: white;
          border-color: var(--brand-primary);
        }
        
        @media (max-width: 768px) {
          .analytics-sections {
            grid-template-columns: 1fr;
            gap: 1rem;
          }
          
          .analytics-stats {
            grid-template-columns: repeat(3, 1fr);
          }
        }
      `;

      document.head.appendChild(style);
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    if (document.getElementById('search-modal')) {
      window.searchModalInstance = new SearchModal();
    }
    document.addEventListener('click', (e) => {
      if (e.target.matches('[data-search-trigger]') || e.target.closest('[data-search-trigger]')) {
        e.preventDefault();
        if (window.searchModalInstance) {
          window.searchModalInstance.open();
        }
      }
    });
  });
</script>
