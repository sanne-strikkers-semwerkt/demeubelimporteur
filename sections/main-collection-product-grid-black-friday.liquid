{% comment %} Clone of main-collection-product-grid with BF cards {% endcomment %}
{{ 'template-collection.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-facets.css' | asset_url | stylesheet_tag }}
<script src="{{ 'facets.js' | asset_url }}" defer="defer"></script>


<style>
  .black-friday-product-wrp .product-box .box-img {
height: unset;
  }
</style>


<section class="product-wrpper">
  <div class="container">
    <div class="custom-bbb">
      <div class="breadcrumb">
        <a href="javascript:void(0);" class="btn-back-custom" onclick="if (document.referrer.indexOf(window.location.host) !== -1) { history.go(-1); return false; } else { window.location.href = 'https://www.demeubelimporteur.nl/'; }">Ga terug</a>
        {% render 'breadcrumbs' %}
      </div>
      <h3 class="no-margin">
        <span id="ProductCountDesktop">
          {%- if collection.results_count -%}
            {{ 'templates.search.results_with_count' | t: terms: collection.terms, count: collection.results_count }}
          {%- elsif collection.products_count == collection.all_products_count -%}
            {{ 'products.facets.product_count_simple' | t: count: collection.products_count }}
          {%- else -%}
            {{ 'products.facets.product_count' | t: product_count: collection.products_count, count: collection.all_products_count }}
          {%- endif -%}
        </span>
      </h3>
    </div>
  </div>

  <div class="bg-colored">
    <div class="container">
      <div class="row">
        <div class="mb-3 hidden-mobile">
          <div class="breadcrumb">
            <a href="javascript:void(0);" class="btn-back-custom" onclick="if (document.referrer.indexOf(window.location.host) !== -1) { history.go(-1); return false; } else { window.location.href = 'https://www.demeubelimporteur.nl/'; }">Ga terug</a>
            {% render 'breadcrumbs' %}
          </div>
        </div>
        <div class="container custom-container">
          <div class="hero-custom-bg">
            <div class=" no-margin">
              <h1>{{ collection.title }}</h1>
            </div>
            {% render 'slider-quicklinks' %}
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="container">
    <div class="row">
      <div class="col-md-3 col-sm-12">
        {{ 'component-facets.css' | asset_url | stylesheet_tag }}
        <script src="{{ 'facets.js' | asset_url }}" defer="defer"></script>
        {%- if section.settings.enable_filtering or section.settings.enable_sorting -%}
          <aside aria-labelledby="verticalTitle" class="facets-wrapper filter-sidebar{% unless section.settings.enable_filtering %} facets-wrapper--no-filters{% endunless %}" id="main-collection-filters" data-id="{{ section.id }}">
            <a href="javascript:void(0);" class="close-btn"><img src="https://cdn.shopify.com/s/files/1/0851/2523/4979/files/close-icon.svg?v=1710745127" alt=""></a>
            {% render 'facets',
              results: collection,
              enable_filtering: section.settings.enable_filtering,
              enable_sorting: section.settings.enable_sorting,
              filter_type: section.settings.filter_type,
              kleur: section.settings.kleur,
              kleur_text: section.settings['kleur-text'],
              materiaal: section.settings.materiaal,
              materiaal_text: section.settings['materiaal-text'],
              prijs: section.settings.prijs,
              prijs_text: section.settings['prijs-text'],
              zithoogte: section.settings.zithoogte,
              zithoogte_text: section.settings['zithoogte-text'],
              breedte: section.settings.breedte,
              breedte_text: section.settings['breedte-text'],
              lengte: section.settings.lengte,
              lengte_text: section.settings['lengte-text'],
              vorm: section.settings.vorm,
              vorm_text: section.settings['vorm-text'],
              aantal_personen: section.settings['aantal-personen'],
              aantal_personen_text: section.settings['aantal-personen-text'],
              serie: section.settings.serie,
              serie_text: section.settings['serie-text'],
              beschikbaarheid: section.settings.beschikbaarheid,
              beschikbaarheid_text: section.settings['beschikbaarheid-text']
            %}
          </aside>
        {% endif %}
      </div>

      <div class="col-md-9 col-sm-12 no-padding">
        <div class="filter-title title-filt hidden-mobile">
          <div class="c">
            <div class="form-group">
              <h3 class="no-margin">
                <span id="ProductCountDesktop">
                  {%- if collection.results_count -%}
                    {{ 'templates.search.results_with_count' | t: terms: collection.terms, count: collection.results_count }}
                  {%- elsif collection.products_count == collection.all_products_count -%}
                    {{ 'products.facets.product_count_simple' | t: count: collection.products_count }}
                  {%- else -%}
                    {{ 'products.facets.product_count' | t: product_count: collection.products_count, count: collection.all_products_count }}
                  {%- endif -%}
                </span>
              </h3>
              {%- if section.settings.enable_sorting -%}
                <facet-filters-form class="facets facets-vertical-sort no-js-hidden">
                  <form class="facets-vertical-form" id="FacetSortForm">
                    <div class="facet-filters sorting">
                      <div class="facet-filters__field">
                        <div class="select">
                          {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}
                          {%- if sort_by == 'created-ascending' or sort_by == 'created-descending' or sort_by == 'title-ascending' or sort_by == 'title-descending' -%}
                            {%- assign sort_by = 'best-selling' -%}
                          {%- endif -%}
                          <select name="sort_by" class="facet-filters__sort form-control select__select caption-large form-select" id="SortBy" aria-describedby="a11y-refresh-page-message">
                            {%- for option in collection.sort_options -%}
                              {%- assign skip_option = false -%}
                              {%- if option.value == 'created-ascending' or option.value == 'created-descending' or option.value == 'title-ascending' or option.value == 'title-descending' -%}
                                {%- assign skip_option = true -%}
                              {%- endif -%}
                              {%- unless skip_option -%}
                                <option value="{{ option.value | escape }}" {% if option.value == sort_by %}selected="selected"{% endif %}>{{ option.name | escape }}</option>
                              {%- endunless -%}
                            {%- endfor -%}
                          </select>
                        </div>
                      </div>
                    </div>
                  </form>
                </facet-filters-form>
              {%- endif -%}
            </div>
          </div>
        </div>

        {%- paginate collection.products by section.settings.products_per_page -%}
          <div class="product-wrp2 black-friday-product-wrp">
          <div class="product-items" id="ProductGridContainer">
            {%- if collection.products.size == 0 -%}
              <div class="collection collection--empty" id="product-grid" data-id="{{ section.id }}">
                <div class="loading-overlay gradient"></div>
                <div class="title-wrapper center">
                  <h2 class="title title--primary"></h2>
                </div>
              </div>
            {% else %}
              <div class="collection" id="product-grid" data-id="{{ section.id }}">
                <div class="row">
                  {% for product in collection.products %}
                      {% render 'bf-card-product',
                        card_product: product,
                        media_aspect_ratio: section.settings.image_ratio,
                        show_secondary_image: section.settings.show_secondary_image,
                        show_vendor: section.settings.show_vendor,
                        show_rating: section.settings.show_rating,
                        show_quick_add: section.settings.enable_quick_add,
                        section_id: section.id
                      %}
                  {% endfor %}
                </div>
              </div>
            {% endif %}
            {%- if paginate.pages > 1 -%}
              {% render 'pagination', paginate: paginate, anchor: '' %}
            {% endif %}
          </div>
          </div>
        {% endpaginate %}

        <div class="product-titlebar coll-description">
          <p>{{ collection.description }}</p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var imgs = document.querySelectorAll('.black-friday-product-wrp .product-box .box-img img');
    imgs.forEach(function(img){
      var parent = img.closest('.box-img');
      function markReady(){ if(parent) parent.classList.add('ready'); }
      if (img.complete && img.naturalWidth > 0) {
        markReady();
      } else {
        img.addEventListener('load', markReady, { once: true });
        img.addEventListener('error', markReady, { once: true });
      }
    });
  });
  // In case of client-side filtering/sorting replaces content, re-run when DOM changes
  var obs = new MutationObserver(function(){
    document.querySelectorAll('.black-friday-product-wrp .product-box .box-img img:not([data-ready-checked])').forEach(function(img){
      img.setAttribute('data-ready-checked','1');
      var parent = img.closest('.box-img');
      function markReady(){ if(parent) parent.classList.add('ready'); }
      if (img.complete && img.naturalWidth > 0) { markReady(); }
      else { img.addEventListener('load', markReady, { once: true }); img.addEventListener('error', markReady, { once: true }); }
    });
  });
  obs.observe(document.getElementById('ProductGridContainer') || document.body, { childList:true, subtree:true });
</script>

{% schema %}
{
  "name": "BF Collection Grid",
  "class": "section",
  "settings": [
    { "type": "range", "id": "products_per_page", "min": 8, "max": 36, "step": 2, "default": 16, "label": "Products per page" },
    { "type": "select", "id": "image_ratio", "options": [{"value":"adapt","label":"Adapt"},{"value":"portrait","label":"Portrait"},{"value":"square","label":"Square"}], "default": "adapt", "label": "Image ratio" },
    { "type": "checkbox", "id": "show_secondary_image", "default": false, "label": "Show secondary image" },
    { "type": "checkbox", "id": "show_vendor", "default": false, "label": "Show vendor" },
    { "type": "checkbox", "id": "show_rating", "default": false, "label": "Show rating" },
    { "type": "checkbox", "id": "enable_filtering", "default": true, "label": "Enable filtering" },
    { "type": "select", "id": "filter_type", "options": [{"value":"horizontal","label":"Horizontal"},{"value":"vertical","label":"Vertical"},{"value":"drawer","label":"Drawer"}], "default": "horizontal", "label": "Filter type" },
    { "type": "checkbox", "id": "enable_sorting", "default": true, "label": "Enable sorting" },
    { "type": "checkbox", "id": "kleur", "label": "Kleur" },
    { "type": "richtext", "id": "kleur-text", "label": "Kleur Popup Content" },
    { "type": "checkbox", "id": "materiaal", "label": "Materiaal" },
    { "type": "richtext", "id": "materiaal-text", "label": "Materiaal Popup Content" },
    { "type": "checkbox", "id": "prijs", "label": "Prijs" },
    { "type": "richtext", "id": "prijs-text", "label": "Prijs Popup Content" },
    { "type": "checkbox", "id": "zithoogte", "label": "Zithoogte" },
    { "type": "richtext", "id": "zithoogte-text", "label": "Zithoogte Popup Content" },
    { "type": "checkbox", "id": "breedte", "label": "Breedte" },
    { "type": "richtext", "id": "breedte-text", "label": "Breedte Popup Content" },
    { "type": "checkbox", "id": "lengte", "label": "Lengte" },
    { "type": "richtext", "id": "lengte-text", "label": "Lengte Popup Content" },
    { "type": "checkbox", "id": "vorm", "label": "Vorm" },
    { "type": "richtext", "id": "vorm-text", "label": "Vorm Popup Content" },
    { "type": "checkbox", "id": "aantal-personen", "label": "Aantal personen" },
    { "type": "richtext", "id": "aantal-personen-text", "label": "Aantal personen Popup Content" },
    { "type": "checkbox", "id": "serie", "label": "Serie" },
    { "type": "richtext", "id": "serie-text", "label": "Serie Popup Content" },
    { "type": "checkbox", "id": "beschikbaarheid", "label": "Beschikbaarheid" },
    { "type": "richtext", "id": "beschikbaarheid-text", "label": "Beschikbaarheid Popup Content" }
  ]
}
{% endschema %}


