<section class="zakelijk-projects color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="container">
    {% if section.settings.heading != blank %}
      <h2>{{ section.settings.heading }}</h2>
    {% endif %}
    <div class="zakelijk-projects-grid">
      {% for block in section.blocks %}
        <div class="zakelijk-project-card" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            <img
              src="{{ block.settings.image | img_url: '600x400' }}"
              alt="{{ block.settings.title | default: 'Project' }}"
              class="zakelijk-project-image"
              width="600"
              height="400"
            >
          {% endif %}
          {% if block.settings.title != blank %}
            <h3 class="zakelijk-project-title">{{ block.settings.title }}</h3>
          {% endif %}
          {% if block.settings.description != blank %}
            <p class="zakelijk-project-description">{{ block.settings.description }}</p>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  .zakelijk-projects {
    padding: 60px 0;
  }
  .zakelijk-projects h2 {
    font-family: 'Zilla Slab', serif;
    font-weight: 600;
    font-size: 32px;
    line-height: 25px;
    color: #000000;
    margin-bottom: 40px;
  }
  .zakelijk-projects-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
  }
  .zakelijk-project-card {
    display: flex;
    flex-direction: column;
  }
  .zakelijk-project-image {
    width: 100%;
    height: 327px;
    object-fit: cover;
    border-radius: 10px;
    margin-bottom: 28px;
  }
  .zakelijk-project-title {
    font-family: 'Zilla Slab', serif;
    font-weight: 600;
    font-size: 22px;
    line-height: 28px;
    color: #000000;
    margin-bottom: 12px;
  }
  .zakelijk-project-description {
    font-family: 'Poppins', sans-serif;
    font-weight: 400;
    font-size: 15px;
    line-height: 25px;
    color: #000000;
  }
  @media (max-width: 991px) {
    .zakelijk-projects-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }
  }
  @media (max-width: 767px) {
    .zakelijk-projects-grid {
      grid-template-columns: 1fr;
    }
    .zakelijk-projects {
      padding: 40px 0;
    }
  }
</style>

{% schema %}
{
  "name": "Zakelijk Projects",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Onze projecten"
    },
    {
      "type": "color_scheme",
