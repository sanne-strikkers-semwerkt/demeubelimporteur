{% comment %}
  Size Calculator Widget
  Helps customers determine if furniture fits their space
{% endcomment %}

<section class="size-calculator-widget color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width">
    <div class="calculator-header">
      <h2 class="calculator-title">{{ section.settings.heading | default: 'Past het in je ruimte?' }}</h2>
      <p class="calculator-description">{{ section.settings.description | default: 'Voer de afmetingen van je ruimte in en ontdek of dit meubel past' }}</p>
    </div>

    <div class="calculator-container">
      <div class="calculator-form">
        <div class="form-section">
          <h3>Meubel afmetingen</h3>
          <div class="input-group">
            <label for="furniture-width">Breedte (cm)</label>
            <input type="number" id="furniture-width" placeholder="0" min="0" step="0.1">
          </div>
          <div class="input-group">
            <label for="furniture-depth">Diepte (cm)</label>
            <input type="number" id="furniture-depth" placeholder="0" min="0" step="0.1">
          </div>
          <div class="input-group">
            <label for="furniture-height">Hoogte (cm)</label>
            <input type="number" id="furniture-height" placeholder="0" min="0" step="0.1">
          </div>
        </div>

        <div class="form-section">
          <h3>Ruimte afmetingen</h3>
          <div class="input-group">
            <label for="room-width">Ruimte breedte (cm)</label>
            <input type="number" id="room-width" placeholder="0" min="0" step="0.1">
          </div>
          <div class="input-group">
            <label for="room-depth">Ruimte diepte (cm)</label>
            <input type="number" id="room-depth" placeholder="0" min="0" step="0.1">
          </div>
          <div class="input-group">
            <label for="room-height">Ruimte hoogte (cm)</label>
            <input type="number" id="room-height" placeholder="0" min="0" step="0.1">
          </div>
        </div>

        <div class="form-section">
          <h3>Extra ruimte</h3>
          <div class="input-group">
            <label for="walkway-space">Loopruimte rondom (cm)</label>
            <input type="number" id="walkway-space" placeholder="60" min="0" step="5" value="60">
            <small>Minimaal 60cm wordt aanbevolen</small>
          </div>
          <div class="input-group">
            <label for="door-width">Deur breedte (cm)</label>
            <input type="number" id="door-width" placeholder="80" min="0" step="1" value="80">
            <small>Voor transport door deur</small>
          </div>
        </div>

        <button class="calculate-btn" onclick="calculateFit()">
          <i class="fa fa-calculator"></i>
          Bereken of het past
        </button>
      </div>

      <div class="calculator-results">
        <div id="results-container" class="results-hidden">
          <h3>Resultaat</h3>
          <div id="fit-result" class="fit-result"></div>
          <div id="space-analysis" class="space-analysis"></div>
          <div id="recommendations" class="recommendations"></div>
        </div>

        <div class="visual-preview">
          <h3>Visuele weergave</h3>
          <div class="room-visualization">
            <div class="room-outline">
              <div id="furniture-preview" class="furniture-preview"></div>
              <div class="room-dimensions">
                <span class="dimension width-dim"></span>
                <span class="dimension depth-dim"></span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="calculator-tips">
      <h3>Tips voor het meten</h3>
      <div class="tips-grid">
        <div class="tip-item">
          <i class="fa fa-ruler"></i>
          <h4>Meet nauwkeurig</h4>
          <p>Gebruik een meetlint en meet op de breedste punten</p>
        </div>
        <div class="tip-item">
          <i class="fa fa-door-open"></i>
          <h4>Controleer deuren</h4>
          <p>Meet de breedte van alle deuren die het meubel moet passeren</p>
        </div>
        <div class="tip-item">
          <i class="fa fa-arrows-alt"></i>
          <h4>Draai ruimte</h4>
          <p>Houd rekening met ruimte om het meubel te draaien</p>
        </div>
        <div class="tip-item">
          <i class="fa fa-lightbulb"></i>
          <h4>Verlichting</h4>
          <p>Controleer of er voldoende licht bij het meubel komt</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .size-calculator-widget {
    padding: 60px 0;
  }

  .calculator-header {
    text-align: center;
    margin-bottom: 50px;
  }

  .calculator-title {
    font-size: 2.5rem;
    margin-bottom: 20px;
    color: var(--color-foreground);
  }

  .calculator-description {
    font-size: 1.2rem;
    color: var(--color-foreground);
    opacity: 0.8;
  }

  .calculator-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    margin-bottom: 60px;
  }

  .calculator-form {
    background: var(--color-background);
    padding: 30px;
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
  }

  .form-section {
    margin-bottom: 30px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--color-border);
  }

  .form-section:last-of-type {
    border-bottom: none;
  }

  .form-section h3 {
    font-size: 1.3rem;
    margin-bottom: 20px;
    color: var(--color-foreground);
  }

  .input-group {
    margin-bottom: 20px;
  }

  .input-group label {
    display: block;
    margin-bottom: 8px;
    font-weight: 600;
    color: var(--color-foreground);
  }

  .input-group input {
    width: 100%;
    padding: 12px;
    border: 2px solid var(--color-border);
    border-radius: 6px;
    font-size: 1rem;
    transition: border-color 0.3s ease;
  }

  .input-group input:focus {
    outline: none;
    border-color: var(--color-button);
  }

  .input-group small {
    display: block;
    margin-top: 5px;
    color: var(--color-foreground);
    opacity: 0.7;
    font-size: 0.9rem;
  }

  .calculate-btn {
    width: 100%;
    background: var(--color-button);
    color: var(--color-button-text);
    border: none;
    padding: 15px 30px;
    border-radius: 8px;
    font-size: 1.1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
  }

  .calculate-btn:hover {
    background: var(--color-button-hover);
    transform: translateY(-2px);
  }

  .calculator-results {
    background: var(--color-background);
    padding: 30px;
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
  }

  .results-hidden {
    display: none;
  }

  .fit-result {
    padding: 20px;
    border-radius: 8px;
    margin-bottom: 20px;
    text-align: center;
    font-weight: 600;
    font-size: 1.2rem;
  }

  .fit-result.success {
    background: #d4edda;
    color: #155724;
    border: 2px solid #c3e6cb;
  }

  .fit-result.warning {
    background: #fff3cd;
    color: #856404;
    border: 2px solid #ffeaa7;
  }

  .fit-result.error {
    background: #f8d7da;
    color: #721c24;
    border: 2px solid #f5c6cb;
  }

  .space-analysis {
    margin-bottom: 20px;
  }

  .space-analysis h4 {
    margin-bottom: 10px;
    color: var(--color-foreground);
  }

  .space-analysis ul {
    list-style: none;
    padding: 0;
  }

  .space-analysis li {
    padding: 5px 0;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .space-analysis .icon {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: bold;
  }

  .space-analysis .icon.check {
    background: #28a745;
    color: white;
  }

  .space-analysis .icon.warning {
    background: #ffc107;
    color: #212529;
  }

  .space-analysis .icon.error {
    background: #dc3545;
    color: white;
  }

  .recommendations {
    background: #f8f9fa;
    padding: 15px;
    border-radius: 6px;
    border-left: 4px solid var(--color-button);
  }

  .recommendations h4 {
    margin-bottom: 10px;
    color: var(--color-foreground);
  }

  .room-visualization {
    margin-top: 20px;
  }

  .room-outline {
    position: relative;
    width: 100%;
    height: 300px;
    border: 3px solid var(--color-foreground);
    border-radius: 8px;
    background: #f8f9fa;
    margin: 20px 0;
  }

  .furniture-preview {
    position: absolute;
    background: var(--color-button);
    opacity: 0.7;
    border-radius: 4px;
    transition: all 0.3s ease;
  }

  .room-dimensions {
    position: absolute;
    top: -25px;
    left: 0;
    right: 0;
    display: flex;
    justify-content: space-between;
  }

  .dimension {
    background: var(--color-foreground);
    color: var(--color-background);
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 0.8rem;
    font-weight: 600;
  }

  .width-dim {
    position: absolute;
    top: -25px;
    left: 50%;
    transform: translateX(-50%);
  }

  .depth-dim {
    position: absolute;
    right: -25px;
    top: 50%;
    transform: translateY(-50%) rotate(90deg);
  }

  .calculator-tips {
    background: var(--color-background);
    padding: 40px;
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
  }

  .calculator-tips h3 {
    text-align: center;
    margin-bottom: 30px;
    color: var(--color-foreground);
  }

  .tips-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
  }

  .tip-item {
    text-align: center;
    padding: 20px;
  }

  .tip-item i {
    font-size: 2rem;
    color: var(--color-button);
    margin-bottom: 15px;
  }

  .tip-item h4 {
    margin-bottom: 10px;
    color: var(--color-foreground);
  }

  .tip-item p {
    color: var(--color-foreground);
    opacity: 0.8;
    font-size: 0.9rem;
  }

  @media (max-width: 768px) {
    .calculator-container {
      grid-template-columns: 1fr;
    }
    
    .calculator-title {
      font-size: 2rem;
    }
    
    .tips-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  function calculateFit() {
    // Get input values
    const furnitureWidth = parseFloat(document.getElementById('furniture-width').value) || 0;
    const furnitureDepth = parseFloat(document.getElementById('furniture-depth').value) || 0;
    const furnitureHeight = parseFloat(document.getElementById('furniture-height').value) || 0;
    
    const roomWidth = parseFloat(document.getElementById('room-width').value) || 0;
    const roomDepth = parseFloat(document.getElementById('room-depth').value) || 0;
    const roomHeight = parseFloat(document.getElementById('room-height').value) || 0;
    
    const walkwaySpace = parseFloat(document.getElementById('walkway-space').value) || 60;
    const doorWidth = parseFloat(document.getElementById('door-width').value) || 80;

    // Validate inputs
    if (furnitureWidth === 0 || furnitureDepth === 0 || roomWidth === 0 || roomDepth === 0) {
      alert('Vul alle afmetingen in om de berekening uit te voeren.');
      return;
    }

    // Calculate fit
    const results = analyzeFit(furnitureWidth, furnitureDepth, furnitureHeight, roomWidth, roomDepth, roomHeight, walkwaySpace, doorWidth);
    
    // Display results
    displayResults(results);
    updateVisualization(furnitureWidth, furnitureDepth, roomWidth, roomDepth);
  }

  function analyzeFit(fw, fd, fh, rw, rd, rh, walkway, doorWidth) {
    const results = {
      fits: true,
      issues: [],
      recommendations: [],
      spaceLeft: {
        width: rw - fw,
        depth: rd - fd,
        height: rh - fh
      }
    };

    // Check basic dimensions
    if (fw > rw) {
      results.fits = false;
      results.issues.push({
        type: 'error',
        message: `Meubel is ${(fw - rw).toFixed(1)}cm te breed voor de ruimte`
      });
    }

    if (fd > rd) {
      results.fits = false;
      results.issues.push({
        type: 'error',
        message: `Meubel is ${(fd - rd).toFixed(1)}cm te diep voor de ruimte`
      });
    }

    if (fh > rh) {
      results.fits = false;
      results.issues.push({
        type: 'error',
        message: `Meubel is ${(fh - rh).toFixed(1)}cm te hoog voor de ruimte`
      });
    }

    // Check walkway space
    const walkwayWidth = rw - fw;
    const walkwayDepth = rd - fd;
    
    if (walkwayWidth < walkway) {
      results.issues.push({
        type: 'warning',
        message: `Slechts ${walkwayWidth.toFixed(1)}cm loopruimte aan de zijkanten (aanbevolen: ${walkway}cm)`
      });
    }

    if (walkwayDepth < walkway) {
      results.issues.push({
        type: 'warning',
        message: `Slechts ${walkwayDepth.toFixed(1)}cm loopruimte voor/achter (aanbevolen: ${walkway}cm)`
      });
    }

    // Check door width
    const diagonal = Math.sqrt(fw * fw + fd * fd);
    if (diagonal > doorWidth) {
      results.issues.push({
        type: 'warning',
        message: `Meubel kan problemen geven bij transport (diagonaal: ${diagonal.toFixed(1)}cm, deur: ${doorWidth}cm)`
      });
    }

    // Generate recommendations
    if (results.fits) {
      if (walkwayWidth >= walkway && walkwayDepth >= walkway) {
        results.recommendations.push('Perfect! Het meubel past uitstekend in de ruimte.');
      } else {
        results.recommendations.push('Het meubel past, maar overweeg de loopruimte.');
      }
    } else {
      results.recommendations.push('Dit meubel is te groot voor de ruimte. Overweeg een kleiner model.');
    }

    if (diagonal > doorWidth) {
      results.recommendations.push('Controleer of het meubel in delen kan worden geleverd.');
    }

    if (results.spaceLeft.width > 0 && results.spaceLeft.depth > 0) {
      results.recommendations.push(`Er blijft ${results.spaceLeft.width.toFixed(1)}cm x ${results.spaceLeft.depth.toFixed(1)}cm ruimte over.`);
    }

    return results;
  }

  function displayResults(results) {
    const container = document.getElementById('results-container');
    const fitResult = document.getElementById('fit-result');
    const spaceAnalysis = document.getElementById('space-analysis');
    const recommendations = document.getElementById('recommendations');

    // Show container
    container.classList.remove('results-hidden');

    // Update fit result
    if (results.fits && results.issues.length === 0) {
      fitResult.className = 'fit-result success';
      fitResult.innerHTML = '✅ Perfect! Het meubel past uitstekend in de ruimte.';
    } else if (results.fits) {
      fitResult.className = 'fit-result warning';
      fitResult.innerHTML = '⚠️ Het meubel past, maar let op de aanbevelingen.';
    } else {
      fitResult.className = 'fit-result error';
      fitResult.innerHTML = '❌ Het meubel past niet in de ruimte.';
    }

    // Update space analysis
    let analysisHTML = '<h4>Ruimte analyse:</h4><ul>';
    results.issues.forEach(issue => {
      const iconClass = issue.type === 'error' ? 'error' : 'warning';
      const icon = issue.type === 'error' ? '✗' : '⚠';
      analysisHTML += `<li><span class="icon ${iconClass}">${icon}</span>${issue.message}</li>`;
    });
    analysisHTML += '</ul>';
    spaceAnalysis.innerHTML = analysisHTML;

    // Update recommendations
    let recHTML = '<h4>Aanbevelingen:</h4><ul>';
    results.recommendations.forEach(rec => {
      recHTML += `<li>${rec}</li>`;
    });
    recHTML += '</ul>';
    recommendations.innerHTML = recHTML;
  }

  function updateVisualization(fw, fd, rw, rd) {
    const furniturePreview = document.getElementById('furniture-preview');
    const widthDim = document.querySelector('.width-dim');
    const depthDim = document.querySelector('.depth-dim');

    // Calculate scale (room is 100% width, scale furniture accordingly)
    const scale = Math.min(280 / rw, 280 / rd); // 280px is roughly the room size
    const scaledFurnitureWidth = fw * scale;
    const scaledFurnitureDepth = fd * scale;

    // Position furniture in center
    const left = (280 - scaledFurnitureWidth) / 2;
    const top = (280 - scaledFurnitureDepth) / 2;

    furniturePreview.style.width = scaledFurnitureWidth + 'px';
    furniturePreview.style.height = scaledFurnitureDepth + 'px';
    furniturePreview.style.left = left + 'px';
    furniturePreview.style.top = top + 'px';

    // Update dimension labels
    widthDim.textContent = rw + 'cm';
    depthDim.textContent = rd + 'cm';
  }

  // Auto-calculate when product dimensions are available
  document.addEventListener('DOMContentLoaded', function() {
    // Try to get product dimensions from product page
    const productDimensions = getProductDimensions();
    if (productDimensions) {
      document.getElementById('furniture-width').value = productDimensions.width;
      document.getElementById('furniture-depth').value = productDimensions.depth;
      document.getElementById('furniture-height').value = productDimensions.height;
    }
  });

  function getProductDimensions() {
    // This would be customized based on how dimensions are stored in your product data
    // For now, return null to use manual input
    return null;
  }
</script>

{% schema %}
{
  "name": "Size Calculator Widget",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Past het in je ruimte?"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Voer de afmetingen van je ruimte in en ontdek of dit meubel past"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "Size Calculator Widget"
    }
  ]
}
{% endschema %}
