<section class="zakelijk-about color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="container zakelijk-about--{{ section.settings.image_position }}">
    <div class="zakelijk-about-image">
      {% if section.settings.image != blank %}
        {{ section.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy' }}
      {% else %}
        {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
      {% endif %}
    </div>
    <div class="zakelijk-about-content">
      {% if section.settings.heading != blank %}
        <h2>{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.description != blank %}
        <div class="zakelijk-about-text">
          {{ section.settings.description }}
        </div>
      {% endif %}
    </div>
  </div>
</section>

<style>
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .zakelijk-about .container {
    display: flex;
    align-items: stretch;
    gap: 60px;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }
  .zakelijk-about--right {
    flex-direction: row-reverse;
  }
  .zakelijk-about-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .zakelijk-about-image {
    flex: 0 0 40%;
    position: relative;
  }
  .zakelijk-about-image img {
    width: 100%;
    height: 100%;
    min-height: 100%;
    border-radius: 10px;
    display: block;
    object-fit: cover;
  }
  .zakelijk-about h2 {
    font-family: 'Zilla Slab', serif;
    font-weight: 600;
    font-size: 32px;
    line-height: 1.2;
    margin-bottom: 30px;
  }
  .zakelijk-about-text {
    font-family: 'Poppins', sans-serif;
    font-weight: 400;
    font-size: 15px;
    line-height: 25px;
  }
  .zakelijk-about-text p {
    margin-bottom: 20px;
  }
  .zakelijk-about-text p:last-child {
    margin-bottom: 0;
  }
  @media (max-width: 767px) {
    .zakelijk-about .container {
      flex-direction: column !important;
      gap: 30px;
    }
    .zakelijk-about-image {
      flex: 1;
      width: 100%;
      height: 300px;
    }
    .zakelijk-about h2 {
      font-size: 28px;
    }
  }
</style>

{% schema %}
{
  "name": "Zakelijk About",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Kleurschema",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Positie afbeelding",
      "options": [
        {
          "value": "left",
          "label": "Links"
        },
        {
          "value": "right",
          "label": "Rechts"
        }
      ],
      "default": "left"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Over De Meubel Importeur zakelijk"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Sinds 2018 maakt De Meubel Importeur meubels die lang meegaan én karakter toevoegen aan je interieur. Je ziet het meteen: elk stuk is gemaakt van mangohout. Deze houtsoort is sterk, warm van kleur en afkomstig van bomen die opnieuw geplant worden na de oogst. Zo kies jij niet alleen voor sfeer, maar ook voor een verantwoorde basis.</p><p>Je vindt ons inmiddels in twee showrooms in Nederland, waar ons team altijd voor je klaarstaat. Wij houden van meubels, denken praktisch en zeggen gewoon waar het op staat. Of je nu liever rustig rondkijkt of gericht advies wilt, bij ons zit je goed.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Afbeelding"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Zakelijk About",
      "category": "Zakelijk"
    }
  ]
}
{% endschema %}
