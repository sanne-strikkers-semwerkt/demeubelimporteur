<style>
  .zakelijk-contact-form {
    padding: 60px 0;
    background-color: #f1f1f1;
  }
  .zakelijk-contact-form-wrapper {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 30px;
    align-items: start;
  }
  .zakelijk-contact-form-image {
    width: 100%;
    height: 613px;
    object-fit: cover;
    border-radius: 10px;
  }
  .zakelijk-contact-form-content {
    background-color: #ffffff;
    padding: 40px;
    border-radius: 10px;
  }
  .zakelijk-contact-form h2 {
    font-family: 'Zilla Slab', serif;
    font-weight: 300;
    font-size: 40px;
    line-height: 48px;
    color: #111313;
    margin-bottom: 30px;
  }
  .zakelijk-contact-form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 20px;
  }
  .zakelijk-contact-form-field {
    margin-bottom: 20px;
  }
  .zakelijk-contact-form-field.full-width {
    grid-column: 1 / -1;
  }
  .zakelijk-contact-form-field label {
    display: block;
    font-family: 'Poppins', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 24px;
    color: #9d9d9d;
    margin-bottom: 8px;
  }
  .zakelijk-contact-form-field input,
  .zakelijk-contact-form-field textarea {
    width: 100%;
    padding: 12px 15px;
    border: 1px solid #d8d8d8;
    border-radius: 10px;
    font-family: 'Poppins', sans-serif;
    font-size: 16px;
    color: #000000;
    background-color: #ffffff;
  }
  .zakelijk-contact-form-field textarea {
    min-height: 119px;
    resize: vertical;
  }
  .zakelijk-contact-form-field input::placeholder,
  .zakelijk-contact-form-field textarea::placeholder {
    color: #9d9d9d;
  }
  .zakelijk-contact-form-note {
    font-family: 'Poppins', sans-serif;
    font-weight: 400;
    font-size: 12px;
    line-height: 18px;
    color: #9d9d9d;
    margin-bottom: 20px;
  }
  .zakelijk-contact-form-button {
    background-color: #fb5a00;
    color: #ffffff;
    border: none;
    border-radius: 10px;
    padding: 15px 30px;
    font-family: 'Zilla Slab', serif;
    font-weight: 600;
    font-size: 20px;
    cursor: pointer;
    transition: opacity 0.3s;
  }
  .zakelijk-contact-form-button:hover {
    opacity: 0.9;
  }
  @media (max-width: 991px) {
    .zakelijk-contact-form-wrapper {
      grid-template-columns: 1fr;
    }
    .zakelijk-contact-form-image {
      height: 400px;
    }
    .zakelijk-contact-form-grid {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 767px) {
    .zakelijk-contact-form {
      padding: 40px 0;
    }
    .zakelijk-contact-form-content {
      padding: 30px 20px;
    }
    .zakelijk-contact-form h2 {
      font-size: 32px;
      line-height: 40px;
    }
  }
</style>

<section class="zakelijk-contact-form">
  <div class="container">
    <div class="zakelijk-contact-form-wrapper">
      {% if section.settings.image != blank %}
        <img src="{{ section.settings.image | img_url: '800x1200' }}" alt="Contact" class="zakelijk-contact-form-image">
      {% endif %}
      <div class="zakelijk-contact-form-content">
        {% if section.settings.heading != blank %}
          <h2>{{ section.settings.heading }}</h2>
        {% endif %}
        {% form 'contact', id: 'zakelijk-contact-form' %}
          <div class="zakelijk-contact-form-grid">
            <div class="zakelijk-contact-form-field">
              <label for="contact-name">Naam*</label>
              <input type="text" id="contact-name" name="contact[name]" required>
            </div>
            <div class="zakelijk-contact-form-field">
              <label for="contact-company">Bedrijfsnaam*</label>
              <input type="text" id="contact-company" name="contact[company]" required>
            </div>
            <div class="zakelijk-contact-form-field">
              <label for="contact-email">E-mailadres*</label>
              <input type="email" id="contact-email" name="contact[email]" required>
            </div>
            <div class="zakelijk-contact-form-field">
              <label for="contact-phone">Telefoonnummer</label>
              <input type="tel" id="contact-phone" name="contact[phone]">
            </div>
            <div class="zakelijk-contact-form-field full-width">
              <label for="contact-message">Stel hier uw vraag...</label>
              <textarea id="contact-message" name="contact[body]" placeholder="Stel hier uw vraag..."></textarea>
            </div>
          </div>
          <p class="zakelijk-contact-form-note">*Verplicht</p>
          <button type="submit" class="zakelijk-contact-form-button">
            {{ section.settings.button_text | default: 'Verstuur' }}
          </button>
        {% endform %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Zakelijk Contact Form",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Side Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Wij hebben alle kennis in huis, stel uw vragen aan onze expert."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Verstuur"
    }
  ],
  "presets": [
    {
      "name": "Zakelijk Contact Form"
    }
  ]
}
{% endschema %}

