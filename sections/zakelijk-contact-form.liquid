<section class="zakelijk-contact-form section-{{ section.id }}-padding">
  <div class="container">
    <div class="zakelijk-contact-form-wrapper">
      {%- if section.settings.image != blank -%}
        {{
          section.settings.image
          | image_url: width: 1000
          | image_tag: class: 'zakelijk-contact-form-image', loading: 'lazy'
        }}
      {%- endif -%}

      <div class="zakelijk-contact-form-content color-{{ section.settings.color_scheme }} gradient">
        {%- if section.settings.heading != blank -%}
          <h2>{{ section.settings.heading }}</h2>
        {%- endif -%}

        {%- form 'contact', id: 'zakelijk-contact-form' -%}
          {%- if form.posted_successfully? -%}
            <div class="form-status-container" tabindex="-1" autofocus>
              <svg class="icon-success" viewBox="0 0 13 13" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="6.5" cy="6.5" r="6" fill="#3AA759"/>
                <path d="M4 6.5L5.5 8L9 4.5" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <p class="form-status">Bedankt voor uw bericht! We nemen zo snel mogelijk contact met u op.</p>
            </div>
          {%- endif -%}

          <div class="zakelijk-contact-form-grid">
            <div class="zakelijk-contact-form-field form-group">
              <input
                class="form-control"
                type="text"
                id="ContactForm-name-{{ section.id }}"
                name="contact[name]"
                placeholder=" "
                required
              >
              <label for="ContactForm-name-{{ section.id }}">Naam*</label>
            </div>
            <div class="zakelijk-contact-form-field form-group">
              <input
                type="text"
                id="ContactForm-company-{{ section.id }}"
                name="contact[company]"
                placeholder=" "
                class="form-control"
                required
              >
              <label for="ContactForm-company-{{ section.id }}">Bedrijfsnaam*</label>
            </div>
            <div class="zakelijk-contact-form-field form-group">
              <input
                type="email"
                id="ContactForm-email-{{ section.id }}"
                name="contact[email]"
                placeholder=" "
                required
                class="form-control"
              >
              <label for="ContactForm-email-{{ section.id }}">E-mailadres*</label>
            </div>
            <div class="zakelijk-contact-form-field form-group">
              <input
                type="tel"
                id="ContactForm-phone-{{ section.id }}"
                name="contact[phone]"
                placeholder=" "
                class="form-control"
              >
              <label for="ContactForm-phone-{{ section.id }}">Telefoonnummer</label>
            </div>
            <div class="zakelijk-contact-form-field form-group field-full">
              <textarea
                id="ContactForm-body-{{ section.id }}"
                name="contact[body]"
                rows="5"
                placeholder=" "
                class="form-control"
              ></textarea>
              <label for="ContactForm-body-{{ section.id }}">Stel hier uw vraag...</label>
            </div>
          </div>
          <span class="zakelijk-contact-form-text">* Verplicht</span>

          <button type="submit" class="zakelijk-contact-form-button btn-orange">
            {{ section.settings.button_text }}
          </button>
        {%- endform -%}
      </div>
    </div>
  </div>
</section>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .zakelijk-contact-form-wrapper {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: 30px;
    align-items: stretch;
  }

  .zakelijk-contact-form-image {
    width: 100%;
    height: 100%;
    min-height: 400px;
    object-fit: cover;
    border-radius: 10px;
  }

  .zakelijk-contact-form-content {
    padding: clamp(20px, 5vw, 45px);
    border-radius: 10px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .zakelijk-contact-form-content h2 {
    font-family: 'Zilla Slab', serif;
    font-size: clamp(28px, 4vw, 40px);
    line-height: 1.2;
    margin-bottom: 30px;
    font-weight: 300;
  }

  .zakelijk-contact-form-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 17px;
  }

  .field-full { grid-column: 1 / -1; }

  .zakelijk-contact-form-field {
    position: relative;
  }

  .zakelijk-contact-form-text {
    font-family: 'Poppins', sans-serif;
    font-weight: 400;
    font-size: 12px;
    line-height: 100%;
  }

  .zakelijk-contact-form-button {
    margin-top: 25px;
  }

  .zakelijk-contact-form .form-status-container {
    display: flex;
    align-items: center;
    gap: 15px;
    background-color: rgba(58, 167, 89, 0.1);
    border: 1px solid #3AA759;
    padding: 15px 20px;
    border-radius: 10px;
    margin-bottom: 25px;
    color: #3AA759;
    animation: fadeIn 0.5s ease-out;
  }

  .zakelijk-contact-form form .zakelijk-contact-form-field.form-group .form-control {
    box-shadow: none;
  }

  .zakelijk-contact-form .icon-success {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .zakelijk-contact-form .form-status {
    margin: 0;
    font-family: 'Poppins', sans-serif;
    font-size: 14px;
    font-weight: 500;
    line-height: 1.4;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 991px) {
    .zakelijk-contact-form-wrapper { grid-template-columns: 1fr; }
    .zakelijk-contact-form-grid { grid-template-columns: 1fr; }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "Zakelijk Contact Form",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Kleurschema formulier",
      "default": "scheme-1"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Afbeelding naast formulier"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Wij hebben alle kennis in huis, stel uw vragen aan onze expert."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Knop tekst",
      "default": "Verstuur"
    },
    {
      "type": "header",
      "content": "Sectie padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Zakelijk Contact Form"
    }
  ]
}
{% endschema %}
