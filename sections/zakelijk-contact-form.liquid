<section class="zakelijk-contact-form section-{{ section.id }}-padding">
  <div class="container">
    <div class="zakelijk-contact-form-wrapper">
      {%- if section.settings.image != blank -%}
        {{
          section.settings.image
          | image_url: width: 1000
          | image_tag: class: 'zakelijk-contact-form-image', loading: 'lazy'
        }}
      {%- endif -%}

      <div class="zakelijk-contact-form-content color-{{ section.settings.color_scheme }} gradient">
        {%- if section.settings.heading != blank -%}
          <h2>{{ section.settings.heading }}</h2>
        {%- endif -%}

        {%- form 'contact', id: 'zakelijk-contact-form' -%}
          {%- if form.posted_successfully? -%}
            <p class="form-status" tabindex="-1" autofocus>Bedankt voor uw bericht!</p>
          {%- endif -%}

          <div class="zakelijk-contact-form-grid">
            <div class="zakelijk-contact-form-field">
              <label for="ContactForm-name-{{ section.id }}">Naam*</label>
              <input type="text" id="ContactForm-name-{{ section.id }}" name="contact[name]" required>
            </div>
            <div class="zakelijk-contact-form-field">
              <label for="ContactForm-company-{{ section.id }}">Bedrijfsnaam*</label>
              <input type="text" id="ContactForm-company-{{ section.id }}" name="contact[company]" required>
            </div>
            <div class="zakelijk-contact-form-field">
              <label for="ContactForm-email-{{ section.id }}">E-mailadres*</label>
              <input type="email" id="ContactForm-email-{{ section.id }}" name="contact[email]" required>
            </div>
            <div class="zakelijk-contact-form-field">
              <label for="ContactForm-phone-{{ section.id }}">Telefoonnummer</label>
              <input type="tel" id="ContactForm-phone-{{ section.id }}" name="contact[phone]">
            </div>
            <div class="zakelijk-contact-form-field field-full">
              <label for="ContactForm-body-{{ section.id }}">Stel hier uw vraag...</label>
              <textarea id="ContactForm-body-{{ section.id }}" name="contact[body]" rows="5"></textarea>
            </div>
          </div>

          <button type="submit" class="zakelijk-contact-form-button">
            {{ section.settings.button_text }}
          </button>
        {%- endform -%}
      </div>
    </div>
  </div>
</section>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .zakelijk-contact-form-wrapper {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 30px;
    align-items: stretch;
  }

  .zakelijk-contact-form-image {
    width: 100%;
    height: 100%;
    min-height: 400px;
    object-fit: cover;
    border-radius: 10px;
  }

  .zakelijk-contact-form-content {
    padding: clamp(20px, 5vw, 40px);
    border-radius: 10px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .zakelijk-contact-form-content h2 {
    font-family: 'Zilla Slab', serif;
    font-size: clamp(28px, 4vw, 40px);
    line-height: 1.2;
    margin-bottom: 30px;
    font-weight: 400;
  }

  .zakelijk-contact-form-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 15px;
  }

  .field-full { grid-column: 1 / -1; }

  .zakelijk-contact-form-field {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 15px;
  }

  .zakelijk-contact-form-field label {
    font-family: 'Poppins', sans-serif;
    font-size: 14px;
    opacity: 0.7;
  }

  .zakelijk-contact-form-field input,
  .zakelijk-contact-form-field textarea {
    padding: 12px;
    border: 1px solid rgba(0,0,0,0.1);
    border-radius: 8px;
    background: transparent;
    font-family: inherit;
  }

  .zakelijk-contact-form-field textarea {
    min-height: 120px;
  }

  .zakelijk-contact-form-button {
    background-color: #fb5a00;
    color: #fff;
    border: none;
    border-radius: 8px;
    padding: 15px 40px;
    font-family: 'Zilla Slab', serif;
    font-weight: 600;
    font-size: 18px;
    cursor: pointer;
    align-self: flex-start;
    transition: opacity 0.3s;
  }

  @media (max-width: 991px) {
    .zakelijk-contact-form-wrapper { grid-template-columns: 1fr; }
    .zakelijk-contact-form-grid { grid-template-columns: 1fr; }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "Zakelijk Contact Form",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Kleurschema formulier",
      "default": "scheme-1"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Afbeelding naast formulier"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Wij hebben alle kennis in huis, stel uw vragen aan onze expert."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Knop tekst",
      "default": "Verstuur"
    },
    {
      "type": "header",
      "content": "Sectie padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Zakelijk Contact Form"
    }
  ]
}
{% endschema %}
