<section class="zakelijk-usp container section-{{ section.id }}-padding">
  <div class="zakelijk-usp-container color-{{ section.settings.color_scheme }} gradient">
    <div class="zakelijk-usp-list">
      {% for block in section.blocks %}
        <div class="zakelijk-usp-item" {{ block.shopify_attributes }}>
          {% if block.settings.icon != blank %}
            <img
              src="{{ block.settings.icon | img_url: '15x15' }}"
              alt=""
              style="width: 15px; height: 15px;"
              width="15"
              height="15"
            >
          {% endif %}
          <span class="zakelijk-usp-item-text">{{ block.settings.text }}</span>
          {% if block.settings.show_flags %}
            <div class="zakelijk-usp-item-flags">
              {% if block.settings.flag_1 != blank %}
                <img
                  src="{{ block.settings.flag_1 | img_url: '13x9' }}"
                  alt=""
                  class="zakelijk-usp-item-flag"
                  width="13"
                  height="9"
                >
              {% endif %}
              {% if block.settings.flag_text_1 != blank %}
                <span class="zakelijk-usp-item-text">{{ block.settings.flag_text_1 }}</span>
              {% endif %}
              {% if block.settings.flag_2 != blank %}
                <img
                  src="{{ block.settings.flag_2 | img_url: '13x9' }}"
                  alt=""
                  class="zakelijk-usp-item-flag"
                  width="13"
                  height="9"
                >
              {% endif %}
              {% if block.settings.flag_text_2 != blank %}
                <span class="zakelijk-usp-item-text">{{ block.settings.flag_text_2 }}</span>
              {% endif %}
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .zakelijk-usp-container {
    padding: 20px 40px;
    border-radius: 30px;
  }
  .zakelijk-usp-list {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
  }
  .zakelijk-usp-item {
    display: flex;
    align-items: center;
    gap: 10px;
    min-width: 200px;
  }
  .zakelijk-usp-item-text {
    font-family: 'Poppins', sans-serif;
    font-weight: 400;
    font-size: 13px;
    line-height: 19.5px;
  }
  .zakelijk-usp-item-flags {
    display: flex;
    align-items: center;
    gap: 5px;
    margin-left: 5px;
    white-space: nowrap;
    flex-shrink: 0;
    margin-left: -5px;
  }
  .zakelijk-usp-item-flag {
    width: 13px;
    height: 9px;
    display: inline-block;
  }
  @media (max-width: 991px) {
    .zakelijk-usp-container {
      padding: 20px;
    }
    .zakelijk-usp-list {
      flex-direction: column;
      align-items: flex-start;
      gap: 15px;
    }
    .zakelijk-usp-item {
      width: 100%;
      min-width: auto;
    }
  }
</style>

{% schema %}
{
  "name": "Zakelijk USP",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Kleurschema container",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "usp",
      "name": "USP Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon (optional)"
        },
        {
          "type": "text",
          "id": "text",
          "label": "USP Text",
          "default": "Geen risico, betaal achteraf"
        },
        {
          "type": "checkbox",
          "id": "show_flags",
          "label": "Show Country Flags",
          "default": false
        },
        {
          "type": "image_picker",
          "id": "flag_1",
          "label": "Vlag 1 (e.g., Netherlands)",
          "visible_if": "{{ block.settings.show_flags == true }}"
        },
        {
          "type": "text",
          "id": "flag_text_1",
          "label": "Tekst voor vlag 1 (e.g., Netherlands)",
          "visible_if": "{{ block.settings.show_flags == true }}"
        },
        {
          "type": "image_picker",
          "id": "flag_2",
          "label": "Vlag 2 (e.g., Belgium)",
          "visible_if": "{{ block.settings.show_flags == true }}"
        },
        {
          "type": "text",
          "id": "flag_text_2",
          "label": "Tekst voor vlag 2 (e.g., Belgium)",
          "visible_if": "{{ block.settings.show_flags == true }}"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Zakelijk USP",
      "category": "Zakelijk",
      "blocks": [
        {
          "type": "usp",
          "settings": {
            "text": "Geen risico, betaal achteraf"
          }
        },
        {
          "type": "usp",
          "settings": {
            "text": "Op voorraad = binnen 5 dagen in huis"
          }
        },
        {
          "type": "usp",
          "settings": {
            "text": "Goedkoopste van",
            "show_flags": true
          }
        },
        {
          "type": "usp",
          "settings": {
            "text": "Altijd 1 jaar garantie"
          }
        }
      ]
    }
  ]
}
{% endschema %}
