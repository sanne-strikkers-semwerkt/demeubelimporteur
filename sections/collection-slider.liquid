<!-- Collection Slider Section -->
<section class="collection-slider-section">
  <div class="container">
    <div class="row">
      <div class="col-12">
        <div class="section-header">
          <div class="description">
            <h3>{{ section.settings.title | default: 'Ontdek onze collecties' }}</h3>
            {% if section.settings.subtitle != blank %}
              <p class="section-subtitle">{{ section.settings.subtitle }}</p>
            {% endif %}
          </div>
        </div>
        <div class="collection-slider">
          {% for block in section.blocks %}
            {% case block.type %}
              {% when 'collection' %}
                <div>
                  <div class="collection-card">
                    <a href="{{ collections[block.settings.collection].url }}">
                      <div class="collection-image">
                        {% if collections[block.settings.collection].featured_image %}
                          <img src="{{ collections[block.settings.collection].featured_image | img_url: 'master' }}" alt="{{ collections[block.settings.collection].title | escape }}" loading="lazy">
                        {% else %}
                          <img src="{{ 'placeholder-collection.jpg' | asset_url }}" alt="{{ collections[block.settings.collection].title | escape }}" loading="lazy">
                        {% endif %}
                        <div class="collection-overlay">
                          <h3>{{ collections[block.settings.collection].title }}</h3>
                        </div>
                      </div>
                    </a>
                  </div>
                </div>
              {% when 'page' %}
                <div>
                  <div class="collection-card">
                    <a href="{{ pages[block.settings.page].url }}">
                      <div class="collection-image">
                        {% if block.settings.image %}
                          <img src="{{ block.settings.image | img_url: 'master' }}" alt="{{ pages[block.settings.page].title | escape }}" loading="lazy">
                        {% else %}
                          <img src="{{ 'placeholder-collection.jpg' | asset_url }}" alt="{{ pages[block.settings.page].title | escape }}" loading="lazy">
                        {% endif %}
                        <div class="collection-overlay">
                          <h3>{{ pages[block.settings.page].title }}</h3>
                        </div>
                      </div>
                    </a>
                  </div>
                </div>
              {% when 'custom_link' %}
                <div>
                  <div class="collection-card">
                    <a href="{{ block.settings.url }}" {% if block.settings.open_in_new_tab %}target="_blank"{% endif %}>
                      <div class="collection-image">
                        {% if block.settings.image %}
                          <img src="{{ block.settings.image | img_url: 'master' }}" alt="{{ block.settings.title | escape }}" loading="lazy">
                        {% else %}
                          <img src="{{ 'placeholder-collection.jpg' | asset_url }}" alt="{{ block.settings.title | escape }}" loading="lazy">
                        {% endif %}
                        <div class="collection-overlay">
                          <h3>{{ block.settings.title }}</h3>
                        </div>
                      </div>
                    </a>
                  </div>
                </div>
            {% endcase %}
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
$(document).ready(function() {
    // Collection Slider
    $('.collection-slider').slick({
        arrows: true,
        loop: true,
        dots: false,
        autoplay: false,
        autoplaySpeed: 4500,
        speed: 500,
        infinite: true,
        slidesToShow: 3,
        slidesToScroll: 1,
        responsive: [
            {
                breakpoint: 1400,
                settings: {
                    slidesToShow: 3,
                },
            },
            {
                breakpoint: 1199,
                settings: {
                    slidesToShow: 3,
                },
            },
            {
                breakpoint: 991,
                settings: {
                    slidesToShow: 2,
                },
            },
            {
                breakpoint: 767,
                settings: {
                    slidesToShow: 1,
                },
            },
            {
                breakpoint: 575,
                settings: {
                    slidesToShow: 1,
                },
            },
            {
                breakpoint: 447,
                settings: {
                    slidesToShow: 1,
                },
            },
        ],
    });
});
</script>

<style>
/* Collection Slider Styles */
.collection-slider-section {
    padding: 80px 0;
    background: #fff;
}

.collection-slider-section .section-header {
    text-align: center;
    margin-bottom: 50px;
}

 .section-header .description h3 {
    color: #000;
    font-size: 36px;
    font-weight: 600;
    line-height: 44px;
    margin: 0 0 15px;
}

.collection-slider-section .section-subtitle {
    color: #666;
    font-size: 18px;
    font-weight: 400;
    line-height: 28px;
    margin: 0;
}

.collection-slider {
    margin: 0 -10px;
}

.collection-slider .slick-slide {
    margin: 0 10px;
}

.collection-slider button.slick-prev.slick-arrow,
.collection-slider button.slick-next.slick-arrow {
    position: absolute;
    left: -20px;
    z-index: var(--z-index-base);
    font-size: 0;
    font-weight: 0;
    border: none;
    box-shadow: none;
    outline: none;
    top: 50%;
    -webkit-transform: translate(0, -50%);
    transform: translate(0, -50%);
    -webkit-transition: all 0.3s linear;
    transition: all 0.3s linear;
}

.collection-slider button.slick-next.slick-arrow {
    left: auto;
    right: -20px;
}

.collection-slider button.slick-prev.slick-arrow:before,
.collection-slider button.slick-next.slick-arrow:before {
    position: absolute;
    content: "\f053";
    font-weight: 600;
    font-family: "Font Awesome 5 Pro";
    left: 0;
    font-size: 20px;
    color: #000;
    width: 50px;
    height: 50px;
    border-radius: 50px;
    border: 1px solid #d8d8d8;
    background: #fff;
    box-shadow: 0px 5px 30px 0px rgba(0, 0, 0, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    top: 50%;
    -webkit-transform: translate(0, -50%);
    transform: translate(0, -50%);
    -webkit-transition: all 0.3s linear;
    transition: all 0.3s linear;
}

.collection-slider button.slick-next.slick-arrow:before {
    content: "\f054";
    left: auto;
    right: 0;
}

.slick-disabled:before {
    display: none !important;
}

.collection-card {
    position: relative;
    border-radius: 15px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    transition: all 0.3s ease;
}

.collection-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
}

.collection-card a {
    position: relative;
    display: block;
    text-decoration: none;
}

.collection-image {
    position: relative;
    height: 400px;
    width: 100%;
    overflow: hidden;
}

.collection-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: all 0.3s ease;
}

.collection-card:hover .collection-image img {
    transform: scale(1.05);
}

.collection-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(transparent, rgba(0, 0, 0, 0.7));
    padding: 40px 30px 30px;
    z-index: 2;
}

.collection-overlay h3 {
    color: #fff;
    font-size: 28px;
    font-weight: 600;
    line-height: 34px;
    margin: 0;
    text-align: center;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
}

/* Responsive Styles */
@media (max-width: 768px) {
    .collection-slider-section {
        padding: 50px 0;
    }
    
 .section-header .description h3 {
        font-size: 28px;
        line-height: 34px;
    }
    
    .collection-slider-section .section-subtitle {
        font-size: 16px;
        line-height: 24px;
    }
    
    .collection-image {
        height: 300px;
    }
    
    .collection-overlay {
        padding: 30px 20px 20px;
    }
    
    .collection-overlay h3 {
        font-size: 22px;
        line-height: 28px;
    }
    
    .collection-slider button.slick-prev.slick-arrow,
    .collection-slider button.slick-next.slick-arrow {
        left: -15px;
    }
    
    .collection-slider button.slick-next.slick-arrow {
        right: -15px;
    }
    
    .collection-slider button.slick-prev.slick-arrow:before,
    .collection-slider button.slick-next.slick-arrow:before {
        width: 40px;
        height: 40px;
        font-size: 16px;
    }
}

@media (max-width: 480px) {
    .collection-image {
        height: 250px;
    }
    
    .collection-overlay {
        padding: 25px 15px 15px;
    }
    
    .collection-overlay h3 {
        font-size: 20px;
        line-height: 26px;
    }
}
</style>

{% schema %}
{
  "name": "Collection Slider",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Ontdek onze collecties"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "info": "Optional subtitle text"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#f8f9fa"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        }
      ]
    },
    {
      "type": "page",
      "name": "Page",
      "settings": [
        {
          "type": "page",
          "id": "page",
          "label": "Page"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "Upload a custom image for this page"
        }
      ]
    },
    {
      "type": "custom_link",
      "name": "Custom Link",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Custom Link"
        },
        {
          "type": "url",
          "id": "url",
          "label": "URL"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "Upload a custom image for this link"
        },
        {
          "type": "checkbox",
          "id": "open_in_new_tab",
          "label": "Open in new tab",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection Slider",
      "blocks": [
        {
          "type": "collection"
        },
        {
          "type": "page"
        },
        {
          "type": "custom_link"
        }
      ]
    }
  ]
}
{% endschema %}
