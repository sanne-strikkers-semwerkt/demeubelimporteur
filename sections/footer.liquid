{%- style -%}
  .footer {
    margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
  }

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .footer {
      margin-top: {{ section.settings.margin_top }}px;
    }

    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="bekend-van-section">
  <div class="container">
    <div class="bekend-van-content">
      <h3>Bekend van</h3>
      <div class="media-logos">
        <div class="media-logo">
          <img src="{{ '100p-nl-logo.svg' | asset_url }}" alt="100NL" class="logo-100nl">
        </div>
        <div class="media-logo">
          <img src="{{ 'Slam_logo.png' | asset_url }}" alt="Slam!" class="logo-slam">
        </div>
      </div>
    </div>
  </div>
</section>

<footer class="site-footer">
  <div class="footer-block">
    <div class="container">
      <div class="row">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {% when 'logo_item' %}
              <div class="col-md-6 col-sm-6">
                <div class="foot-logo">
                  <a href="https://www.demeubelimporteur.nl/"
                    ><img
                      src="{{ block.settings.logo-part | img_url:'master' }}"
                      width="163"
                      height="47"
                      alt=""
                      class="logo-img"
                  ></a>
                  <p>
                    {{ block.settings.texts }}
                  </p>
                  <div class="rating-block">
                    <div class="rating-box">
                      <a href="https://www.webwinkelkeur.nl/webshop/DeMeubelimporteur_1214608/reviews" target="_blank">
                        <h5>{{ shop.metafields.custom.webwinkelkeur | split: ',' | last }}</h5>
                      </a>
                      <a href="https://www.webwinkelkeur.nl/webshop/DeMeubelimporteur_1214608/reviews" target="_blank">
                        <h6>
                          <span>
                            <img
                              src="https://cdn.shopify.com/s/files/1/0563/8412/7158/files/star-icon.svg?v=1717136575"
                              width="14"
                              height="13"
                              alt=""
                            >
                            <img
                              src="https://cdn.shopify.com/s/files/1/0563/8412/7158/files/star-icon.svg?v=1717136575"
                              width="14"
                              height="13"
                              alt=""
                            >
                            <img
                              src="https://cdn.shopify.com/s/files/1/0563/8412/7158/files/star-icon.svg?v=1717136575"
                              width="14"
                              height="13"
                              alt=""
                            >
                            <img
                              src="https://cdn.shopify.com/s/files/1/0563/8412/7158/files/star-icon.svg?v=1717136575"
                              width="14"
                              height="13"
                              alt=""
                            >
                            <img
                              src="https://cdn.shopify.com/s/files/1/0563/8412/7158/files/star-icon.svg?v=1717136575"
                              width="14"
                              height="13"
                              alt=""
                            >
                          </span>
                          {{ shop.metafields.custom.webwinkelkeur | split: ',' | first }} reviews
                        </h6>
                      </a>
                    </div>
                    <a href="https://www.webwinkelkeur.nl/webshop/DeMeubelimporteur_1214608/reviews" target="_blank">
                      <img src="{{ block.settings.keurmerk-logo | img_url:'master' }}" width="114" height="36" alt=""
                    ></a>
                  </div>
                </div>
              </div>
            {%- when 'link_list' -%}
              <div class="col-md-1 col-sm-6">
                <div class="quicklinks">
                  <h3>{{ block.settings.heading }}</h3>
                  <ul>
                    {%- for link in block.settings.menu.links -%}
                      <li>
                        <a href="{{ link.url }}">{{ link.title | escape }}</a>
                      </li>
                    {% endfor %}
                  </ul>
                </div>
              </div>
            {%- when 'link_list2' -%}
              <div class="col-md-1 col-sm-6">
                <div class="quicklinks">
                  <h3>{{ block.settings.heading }}</h3>
                  <ul>
                    {%- for link in block.settings.menu.links -%}
                      <li>
                        <a href="{{ link.url }}">{{ link.title | escape }}</a>
                      </li>
                    {% endfor %}
                  </ul>
                </div>
              </div>
            {%- when 'contact' -%}
              <div class="col-md-4 col-sm-6">
                <div class="ourstore-block">
                  <h3>{{ block.settings.heading }}</h3>
                  <ul>
                    <li>
                      <img src="{{ block.settings.address-img1 | img_url: '400x' }}" loading="lazy" alt="">
                      <div>
                        <h5>{{ block.settings['address-title1'] }}</h5>
                        <h6>{{ block.settings.address1 }}</h6>
                        <a href="{{ block.settings.address1-btn-link }}">
                          {{- block.settings['address1-btn-text'] }}
                          <!-- Route &amp; contact -->
                        </a>
                      </div>
                    </li>
                    <li>
                      <img src="{{ block.settings.address-img2 | img_url: '400x' }}" loading="lazy" alt="">
                      <div>
                        <h5>{{ block.settings['address-title2'] }}</h5>
                        <h6>{{ block.settings.address2 }}</h6>
                        <a href="{{ block.settings.address2-btn-link }}">
                          {{- block.settings['address2-btn-text'] }}
                          <!-- Route &amp; contact -->
                        </a>
                      </div>
                    </li>
                    {%- if block.settings.address3 != blank -%}
                    <li>
                      <img src="{{ block.settings.address-img3 | img_url: '400x' }}" loading="lazy" alt="">
                      <div>
                        <h5>{{ block.settings['address-title3'] }}</h5>
                        <h6>{{ block.settings.address3 }}</h6>
                        <a href="{{ block.settings.address3-btn-link }}">
                          {{- block.settings['address3-btn-text'] }}
                          <!-- Route &amp; contact -->
                        </a>
                      </div>
                    </li>
                    {%- endif -%}
                  </ul>
                </div>
                {% comment %}
                  <div class="quicklinks">
                      <h3>{{ block.settings.heading }}</h3>
                      <ul>
                          <li><a href="{{ block.settings.link1 }}">{{ block.settings.text1 }}</a></li>
                          <li><a href="{{ block.settings.link2 }}">{{ block.settings.text2 }}</a></li>
                          <li><a href="{{ block.settings.link3 }}"><img src="https://cdn.shopify.com/s/files/1/0563/8412/7158/files/tel-icon.svg?v=1717136575" alt="">{{ block.settings.text3 }}</a></li>
                          <li><a href="{{ block.settings.link4 }}" class="underline-txt"><img src="https://cdn.shopify.com/s/files/1/0563/8412/7158/files/mail-icon.svg?v=1717136575" alt="">{{ block.settings.text4 }}</a></li>
                      </ul>
                  </div>
                  <div class="social-icons">
                      <h4>{{ block.settings.social }}</h4>
                      <ul>
                          <li><a href="https://www.facebook.com/demeubelimporteur" target="_blank"> <img src="https://cdn.shopify.com/s/files/1/0563/8412/7158/files/facebook-icon.svg?v=1717136575" alt=""></a></li>
                          <li><a href="https://www.instagram.com/demeubelimporteur/" target="_blank"> <img src="https://cdn.shopify.com/s/files/1/0563/8412/7158/files/insta-icon.svg?v=1717136575" alt=""></a></li>
                          <li class="tiktok"><a href="https://www.tiktok.com/@demeubelimporteur" target="_blank"> <img src="https://cdn.shopify.com/s/files/1/0563/8412/7158/files/icons8-tiktok_2.svg?v=1733203700" alt=""></a></li>
                      </ul>
                  </div>
                {% endcomment %}
              </div>
          {% endcase %}
        {% endfor %}
      </div>
    </div>
    <div class="mobilr-footer">
      <div class="accordion" id="footeraccordionExample">
        {% assign amount = 0 %}
