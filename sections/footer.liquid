                >
                  <div class="accordion-body">
                    <div class="ourstore-block">
                      <ul>
                        <li>
                          <img src="{{ block.settings.address-img1 | img_url: '400x' }}" loading="lazy" alt="">
                          <div>
                            <h5>{{ block.settings['address-title1'] }}</h5>
