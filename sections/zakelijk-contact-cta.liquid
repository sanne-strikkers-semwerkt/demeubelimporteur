<section class="zakelijk-contact-cta section-{{ section.id }}-padding">
  <div class="container">
    {%- if section.settings.heading != blank -%}
      <h2 class="zakelijk-contact-cta-header">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="zakelijk-contact-cta-grid color-{{ section.settings.color_scheme }} gradient">
      <div class="zakelijk-contact-option">
        <div class="zakelijk-contact-option-left">
          {%- if section.settings.left_avatar != blank -%}
            {{
              section.settings.left_avatar
              | image_url: width: 300
              | image_tag: class: 'zakelijk-contact-option-avatar', loading: 'lazy', alt: section.settings.left_heading
            }}
          {%- endif -%}
          <div class="zakelijk-contact-option-info">
            {%- if section.settings.left_heading != blank -%}
              <h3>{{ section.settings.left_heading }}</h3>
            {%- endif -%}
            <nav class="zakelijk-contact-option-contact">
              {%- if section.settings.left_phone != blank -%}
                <a
                  href="tel:{{ section.settings.left_phone | replace: ' ', '' }}"
                  class="zakelijk-contact-option-contact-item"
                >
                  {{ 'icon-tel.svg' | inline_asset_content }}
                  <span>{{ section.settings.left_phone }}</span>
                </a>
              {%- endif -%}
              {%- if section.settings.left_email != blank -%}
                <a href="mailto:{{ section.settings.left_email }}" class="zakelijk-contact-option-contact-item">
                  {{ 'icon-mail.svg' | inline_asset_content }}
                  <span>{{ section.settings.left_email }}</span>
                </a>
              {%- endif -%}
            </nav>
          </div>
        </div>
      </div>

      <div class="zakelijk-contact-cta-divider"></div>

      <div class="zakelijk-contact-option">
        {%- if section.settings.right_heading != blank -%}
          <h3>{{ section.settings.right_heading }}</h3>
        {%- endif -%}
        <div class="zakelijk-contact-option-actions">
          {%- if section.settings.right_button_text != blank -%}
            <button
              onclick="$crisp.push(['do', 'chat:show']);$crisp.push(['do', 'chat:open']);"
              class="zakelijk-contact-option-button"
            >
              {{ section.settings.right_button_text }}
            </button>
          {%- endif -%}
          {%- if section.settings.right_status != blank -%}
            <div class="zakelijk-contact-option-status">
              {{ 'icon-check.svg' | inline_asset_content }}
              {{ section.settings.right_status }}
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</section>

{%- style -%}
  .zakelijk-contact-cta {
    --btn-color: #3aa759;
    --font-family-heading: 'Zilla Slab', serif;
    --font-family-body: 'Poppins', sans-serif;
    --body-color: #000;
  }

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .zakelijk-contact-cta-header {
    font-family: var(--font-family-heading);
    color: var(--body-color);
    font-weight: 600;
    font-size: 32px;
    line-height: 1.2;
    margin-bottom: 40px;
  }

  .zakelijk-contact-cta-grid {
    display: grid;
    grid-template-columns: 1.2fr auto 0.8fr;
    gap: 80px;
    align-items: center;
    padding: 45px clamp(20px, 5vw, 80px);
    border-radius: 10px;
  }

  .zakelijk-contact-cta-divider {
    width: 1px;
    height: 100px;
    background-color: rgba(0,0,0,1);
  }

  .zakelijk-contact-option h3 {
    font-family: var(--font-family-heading);
    color: var(--body-color);
    font-weight: 500;
    font-size: 24px;
    margin-bottom: 20px;
  }

  .zakelijk-contact-option-left {
    display: flex;
    align-items: center;
    gap: clamp(15px, 3vw, 30px);
  }

  .zakelijk-contact-option-avatar {
    width: 120px;
    height: 120px;
    aspect-ratio: 1 / 1;
    border-radius: 50%;
    object-fit: cover;
    border: 1px solid #D8D8D8;
  }

  .zakelijk-contact-option-contact {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-top: 35px;
  }

  .zakelijk-contact-option-contact-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-family-body);
    color: var(--body-color) !important;
    font-size: 15px;
    text-decoration: underline;
    color: inherit;
    transition: opacity 0.3s ease;
    font-weight: 400;
  }

  .zakelijk-contact-option-contact-item:hover {
    text-decoration: none;
  }

  .zakelijk-contact-option-contact-icon {
    width: 16px;
    height: 16px;
  }

  .zakelijk-contact-option-actions {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    align-items: center;
    gap: 15px;
  }

  .zakelijk-contact-option-status {
    color: var(--btn-color);
    font-family: var(--font-family-body);
    font-weight: 500;
    font-size: 15px;
    line-height: 25px;
    text-align: center;
  }

  .zakelijk-contact-option-button {
    background-color: var(--btn-color);
    color: #fff !important;
    padding: 14px 28px;
    border-radius: 8px;
    font-family: var(--font-family-heading);
    font-weight: 500;
    font-size: 18px;
    text-decoration: none;
    transition: all 0.3s ease;
    border: none;
    margin-right: 6px;
  }

  .zakelijk-contact-option-button:hover {
    filter: brightness(1.1);
    text-decoration: none;
  }

  @media (max-width: 991px) {
    .zakelijk-contact-cta-grid {
      grid-template-columns: 1fr;
      padding: 30px;
      gap: 30px;
    }
    .zakelijk-contact-cta-divider {
      width: 100%;
      height: 1px;
    }
    .zakelijk-contact-option-contact {
      margin-top: 0;
    }
  }

  @media (max-width: 480px) {
    .zakelijk-contact-option-left {
      flex-direction: column;
      align-items: flex-start;
    }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "Zakelijk Contact CTA",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Kleurschema grid",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Neem vrijblijvend contact op"
    },
    {
      "type": "header",
      "content": "Linker kolom (60% breedte)"
    },
    {
      "type": "image_picker",
      "id": "left_avatar",
      "label": "Avatar afbeelding"
    },
    {
      "type": "text",
      "id": "left_heading",
      "label": "Heading links",
      "default": "Bel Willem voor gratis interieuradvies!"
    },
    {
      "type": "text",
      "id": "left_phone",
      "label": "Telefoonnummer",
      "default": "0228 - 785 883"
    },
    {
      "type": "text",
      "id": "left_email",
      "label": "E-mailadres",
      "default": "zakelijk@demeubelimporteur.nl"
    },
    {
      "type": "header",
      "content": "Rechter kolom (40% breedte)"
    },
    {
      "type": "text",
      "id": "right_heading",
      "label": "Heading rechts",
      "default": "Of chat met één van onze specialisten"
    },
    {
      "type": "text",
      "id": "right_status",
      "label": "Status tekst",
      "default": "Nu online"
    },
    {
      "type": "text",
      "id": "right_button_text",
      "label": "Knop tekst",
      "default": "Start live chat"
    },
    {
      "type": "header",
      "content": "Sectie padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Zakelijk Contact CTA",
      "category": "Zakelijk"
    }
  ]
}
{% endschema %}
