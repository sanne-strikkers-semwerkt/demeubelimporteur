<section class="locations-banner" style="background-image: url({{ section.settings.image | img_url: 'master' }});">
    <div class="container">
        <div class="breadcrumb">
            <a href="#" class="btn-back">Ga terug</a>
            <ul>
                {% render 'breadcrumbs' %}
            </ul>
        </div>
        <h2>{{ section.settings.title }}</h2>
        <div class="banner-address">
            <a href="{{ section.settings.link }}" class="btn-orange">
                <img src="https://cdn.shopify.com/s/files/1/0563/8412/7158/files/pin-icon.svg?v=1736933327" alt="{{ template.suffix | replace: '-', ' ' }}">
                {{ section.settings.button }}
            </a>
            <h6>{{ section.settings.text }}
              <!-- <strong>Adres: </strong>Industrieweg 7, 1613 KT Breda -->
            </h6>
        </div>
    </div>
</section>
{% schema %}
  {
    "name": "Location banner",
    "settings": [
      {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
      {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
      {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
      {
          "type": "text",
          "id": "button",
          "label": "Button"
        },
      {
          "type": "html",
          "id": "text",
          "label": "Text"
        }
    ],
    "presets": [
      {
        "name": "Location banner"
      }
    ]
  }
{% endschema %}