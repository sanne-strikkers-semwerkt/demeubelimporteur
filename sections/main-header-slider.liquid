<div class="header-slider">
                    <div class="container">
                        <div class="top-slider">
                          {% for block in section.blocks %}
                            <div>
                              <div class="slider-box">
                                <h6>
                                  {{ block.settings.text }}
                                  {% if block.settings.show_country_logos == true %}
                                    {% if block.settings.country-logo-1 != blank %}
                                      <img src="{{ block.settings.country-logo-1 | img_url: 'small' }}" />
                                    {% endif %}
                                    {% if block.settings.country-name-1 != blank %}
                                      {{ block.settings.country-name-1 }}
                                    {% endif %}
                                    {% if block.settings.country-logo-2 != blank %}
                                       &  <img src="{{ block.settings.country-logo-2 | img_url: 'small' }}" />
                                    {% endif %}
                                    {% if block.settings.country-name-2 != blank %}
                                      {{ block.settings.country-name-2 }}
                                    {% endif %}
                                  {% endif %}
                                </h6>
                              </div>
                            </div>
                          {% endfor %}
