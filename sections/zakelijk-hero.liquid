<style>
  .zakelijk-hero {
    background-color: #fbba00;
    padding: 60px 0;
    position: relative;
  }
  .zakelijk-hero .container {
    position: relative;
    z-index: 2;
  }
  .zakelijk-hero-content h1 {
    font-family: 'Zilla Slab', serif;
    font-weight: 400;
    font-size: 42px;
    line-height: 52px;
    color: #000000;
    margin-bottom: 30px;
  }
  .zakelijk-hero-button {
    background-color: #fb5a00;
    color: #ffffff;
    border-radius: 10px;
    padding: 15px 30px;
    font-family: 'Zilla Slab', serif;
    font-weight: 600;
    font-size: 20px;
    text-decoration: none;
    display: inline-block;
    transition: opacity 0.3s;
  }
  .zakelijk-hero-button:hover {
    opacity: 0.9;
    color: #ffffff;
  }
  @media (max-width: 767px) {
    .zakelijk-hero-content h1 {
      font-size: 32px;
      line-height: 42px;
    }
    .zakelijk-hero {
      padding: 40px 0;
    }
  }
</style>

<section class="zakelijk-hero">
  <div class="container">
    <div class="zakelijk-hero-content">
      {% if section.settings.heading != blank %}
        <h1>{{ section.settings.heading }}</h1>
      {% endif %}
      {% if section.settings.button_text != blank and section.settings.button_link != blank %}
        <a href="{{ section.settings.button_link }}" class="zakelijk-hero-button">
          {{ section.settings.button_text }}
        </a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Zakelijk Hero",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Thuisgevoel, ook op kantoor met meubels van De Meubel Importeur"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Ontdek de mogelijkheden"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Zakelijk Hero"
    }
  ]
}
{% endschema %}

