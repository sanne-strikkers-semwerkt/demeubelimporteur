<section class="zakelijk-hero">
  <div class="container">
    <div class="zakelijk-hero-media">
      {% if section.settings.hero_picker == 'video' %}
        {% render 'video-component',
          id: section.id,
          s: section.settings,
          custom_video_url: section.settings.hero_video,
          custom_poster: section.settings.hero_image
        %}
      {% else %}
        {% if section.settings.hero_image != blank %}
          {{
            section.settings.hero_image
            | image_url: width: 800
            | image_tag: loading: 'lazy', class: 'hero-image-render', widths: '400, 600, 800'
          }}
        {% else %}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {% endif %}
      {% endif %}
    </div>

    <div class="zakelijk-hero-content">
      <div>
        {% if section.settings.hero_heading != blank %}
          <div class="zakelijk-hero-heading-wrapper">
            {{ section.settings.hero_heading }}
          </div>
        {% endif %}

        {% if section.settings.button_text != blank and section.settings.button_link != blank %}
          <a href="{{ section.settings.button_link }}" class="zakelijk-hero-button">
            {{ section.settings.button_text }}
          </a>
        {% endif %}
      </div>

      <div class="zakelijk-hero-footer">
        {% if section.settings.footer_text != blank %}
          <p>
            {{ section.settings.footer_text }}
          </p>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% style %}
  .zakelijk-hero {
    background-color: #fbba00;
    padding: 60px 0;
  }
  .zakelijk-hero .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
    display: flex;
    align-items: center;
    gap: 57px;
  }
  .zakelijk-hero-media {
    flex: 1;
    width: 100%;
  }

  .zakelijk-hero-media .video-section,
  .zakelijk-hero-media .deferred-media,
  .zakelijk-hero-media img {
    border-radius: 10px;
    overflow: hidden;
    max-height: 390px;
    width: 100%;
    object-fit: cover;
  }
  .zakelijk-hero-content {
    flex: 1;
  }
  .zakelijk-hero-heading-wrapper p {
    font-family: 'Zilla Slab', serif;
    font-size: 42px;
    line-height: 52px;
    color: #000000;
    margin-bottom: 30px;
  }
  .zakelijk-hero-button {
    background-color: #fb5a00;
    color: #ffffff;
    border-radius: 10px;
    padding: 15px 30px;
    font-family: 'Zilla Slab', serif;
    font-weight: 600;
    font-size: 20px;
    text-decoration: none;
    display: inline-block;
    transition: transform 0.2s ease;
  }
  .zakelijk-hero-button:hover {
    transform: scale(1.02);
    color: #ffffff;
  }

  @media (max-width: 767px) {
    .zakelijk-hero .container {
      flex-direction: column;
      gap: 25px;
      text-align: center;
    }
    .zakelijk-hero-heading-wrapper p {
      font-size: 32px;
      line-height: 42px;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Zakelijk Hero",
  "settings": [
    {
      "type": "richtext",
      "id": "hero_heading",
      "label": "Heading",
      "default": "<p>Thuisgevoel, ook op kantoor met meubels van De Meubel Importeur</p>"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Ontdek de mogelijkheden"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "radio",
      "id": "hero_picker",
      "label": "Hero media",
      "options": [
        { "label": "Video", "value": "video" },
        { "label": "Afbeelding", "value": "image" }
      ],
      "default": "image"
    },
    {
      "type": "video_url",
      "id": "hero_video",
      "label": "Video URL",
      "accept": ["youtube", "vimeo"],
      "default": "https://www.youtube.com/watch?v=_9VUPq3SxOc"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Afbeelding / Video Poster"
    },
    {
      "type": "header",
      "content": "Footer"
    },
    {
      "type": "text",
      "id": "footer_text",
      "label": "Footer tekst",
      "default": "Deze bedrijven gingen je voor"
    }
  ],
  "presets": [
    {
      "name": "Zakelijk Hero"
    }
  ]
}
{% endschema %}
