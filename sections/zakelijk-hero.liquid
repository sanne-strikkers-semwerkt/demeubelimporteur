<style>
  .zakelijk-hero {
    background-color: #fbba00;
    padding: 60px 0;
    position: relative;
  }
  .zakelijk-hero .container {
    position: relative;
    z-index: 2;
  }
  .zakelijk-hero-content h1 {
    font-family: 'Zilla Slab', serif;
    font-weight: 400;
    font-size: 42px;
    line-height: 52px;
    color: #000000;
    margin-bottom: 30px;
  }
  .zakelijk-hero-button {
    background-color: #fb5a00;
    color: #ffffff;
    border-radius: 10px;
    padding: 15px 30px;
    font-family: 'Zilla Slab', serif;
    font-weight: 600;
    font-size: 20px;
    text-decoration: none;
    display: inline-block;
    transition: opacity 0.3s;
  }
  .zakelijk-hero-button:hover {
    opacity: 0.9;
    color: #ffffff;
  }
  @media (max-width: 767px) {
    .zakelijk-hero-content h1 {
      font-size: 32px;
      line-height: 42px;
    }
    .zakelijk-hero {
      padding: 40px 0;
    }
  }
</style>

<section class="zakelijk-hero">
  <div class="container">
    <div class="zakelijk-hero-content">
      {% if section.settings.hero_heading %}
        <p>{{ section.settings.hero_heading }}</p>
      {% endif %}
      {% if section.settings.button_text != blank and section.settings.button_link != blank %}
        <a href="{{ section.settings.button_link }}" class="zakelijk-hero-button">
          {{ section.settings.button_text }}
        </a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Zakelijk Hero",
  "settings": [
    {
      "type": "richtext",
      "id": "hero_heading",
      "label": "Heading",
      "default": "Thuisgevoel, ook op kantoor met meubels van De Meubel Importeur"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Ontdek de mogelijkheden"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "radio",
      "id": "hero_picker",
      "label": "Hero media",
      "options": [
        {
          "label": "Video",
          "value": "video"
        },
        {
          "label": "Afbeelding",
          "value": "image"
        }
      ]
    },
    {
      "type": "video_url",
      "label": "Video URL",
      "id": "hero_video",
      "accept": ["youtube"],
      "visible_if": "{{ section.settings.hero_picker == 'video' }}"
    },
    {
      "type": "image_picker",
      "label": "Afbeelding",
      "id": "hero_image",
      "visible_if": "{{ section.settings.hero_picker == 'image' }}"
    }
  ],
  "presets": [
    {
      "name": "Zakelijk Hero",
      "category": "Zakelijk"
    }
  ]
}
{% endschema %}
