{% if section.settings.hoogte %}
  <div class="modal fade description-modal" id="hoogte" tabindex="-1" aria-labelledby="hoogteLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Hoogte</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal">
