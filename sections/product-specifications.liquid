        </div>
        <div class="modal-body">
          {{ section.settings['breedte-text'] }}
        </div>
      </div>
    </div>
  </div>
{% endif %}
{% if section.settings.diepte %}
  <div class="modal fade description-modal" id="diepte" tabindex="-1" aria-labelledby="diepteLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Diepte</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal">
            Sluiten
            <img src="https://cdn.shopify.com/s/files/1/0474/0454/8262/files/close-icon-black.svg?v=1726308511" alt="">
          </button>
        </div>
        <div class="modal-body">
          {{ section.settings['diepte-text'] }}
        </div>
      </div>
