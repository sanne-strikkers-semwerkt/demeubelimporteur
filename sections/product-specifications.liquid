<!-- Product review -->
<section class="product-review-wrp">
  <div class="container">
    <div class="row">
      <div class="col-md-7 col-sm-12">
        <div class="specificaties-block" id="specificaties">
          <div class="titlebar">
            <h3>Specificaties</h3>
          </div>
          <table class="table table-borderless">
            <tbody>
              {% if product.metafields.spec.garantie != blank %}
                <tr>
                  <td>
                    <span>
                      {%- if section.settings.garantie %}
                        <button type="button" data-bs-toggle="modal" data-bs-target="#garantie">
                          <img
                            src="https://cdn.shopify.com/s/files/1/0474/0454/8262/files/info-circle-solid.svg?v=1750928404"
                            alt=""
                          >
                        </button>
                      {%- endif -%}
                      Garantie</span
                    >
                  </td>
                  <td>
                    <span>{{ product.metafields.spec.garantie }}</span>
                  </td>
                </tr>
              {% endif %}
              {% if product.metafields.spec.materiaal != blank %}
                <tr>
                  <td>
                    <span>
                      {%- if section.settings.material %}
                        <button type="button" data-bs-toggle="modal" data-bs-target="#material">
                          <img
                            src="https://cdn.shopify.com/s/files/1/0474/0454/8262/files/info-circle-solid.svg?v=1750928404"
                            alt=""
                          >
                        </button>
                      {%- endif -%}
                      Materiaal</span
                    >
                  </td>
                  <td>
                    {% assign material_values = product.metafields.spec.materiaal
                      | remove: '"'
                      | remove: '['
                      | remove: ']'
                      | split: ','
                    %}
                    {% for material in material_values %}
                      {% assign clean_material = material | strip %}
                      {% comment %} Check if this is descriptive text (contains periods or descriptive words) {% endcomment %}
                      {% assign is_descriptive = false %}
                      {% if clean_material contains '.' or clean_material contains 'met een' or clean_material contains 'voorzien van' or clean_material.size > 40 %}
                        {% assign is_descriptive = true %}
                      {% endif %}
                      
                      {% if is_descriptive %}
                        <span class="spec-description-text">{{- clean_material -}}</span>
                      {% else %}
                        <a
                          href="/collections/all?filter.v.availability=1&filter.p.m.spec.materiaal={{ clean_material | url_encode }}"
                          class="spec-filter-link"
                        >
                          {{- clean_material -}}
                        </a>
                      {% endif %}
                      {%- unless forloop.last %} {% endunless %}
                    {% endfor %}
                  </td>
                </tr>
              {% endif %}
              {% if product.metafields.spec.stijl != blank %}
                <tr>
                  <td>
                    <span>
                      {%- if section.settings.stijl %}
                        <button type="button" data-bs-toggle="modal" data-bs-target="#stijl">
                          <img
                            src="https://cdn.shopify.com/s/files/1/0474/0454/8262/files/info-circle-solid.svg?v=1750928404"
                            alt=""
                          >
                        </button>
                      {%- endif -%}
                      Stijl</span
                    >
                  </td>
                  <td>
                    <span>{{ product.metafields.spec.stijl | remove: '"' | remove: '[' | remove: ']' }}</span>
                  </td>
                </tr>
              {% endif %}
              {% if product.metafields.spec.breedte != blank %}
                <tr>
                  <td>
                    <span>
                      {%- if section.settings.breedte %}
                        <button type="button" data-bs-toggle="modal" data-bs-target="#breedte">
                          <img
                            src="https://cdn.shopify.com/s/files/1/0474/0454/8262/files/info-circle-solid.svg?v=1750928404"
                            alt=""
                          >
                        </button>
                      {%- endif -%}
                      Breedte</span
                    >
                  </td>
                  <td>
                    {% assign clean_breedte = product.metafields.spec.breedte | remove: '"' | remove: '[' | remove: ']' | strip %}
                    <a
                      href="/collections/all?filter.v.availability=1&filter.p.m.spec.breedte={{ clean_breedte | url_encode }}"
                      class="spec-filter-link"
                    >
                      {{- clean_breedte -}}
                    </a>
                  </td>
                </tr>
              {% endif %}
              {% if product.metafields.spec.diepte != blank %}
                <tr>
                  <td>
                    <span>
                      {%- if section.settings.diepte %}
                        <button type="button" data-bs-toggle="modal" data-bs-target="#diepte">
                          <img
                            src="https://cdn.shopify.com/s/files/1/0474/0454/8262/files/info-circle-solid.svg?v=1750928404"
                            alt=""
                          >
                        </button>
                      {%- endif -%}
                      Diepte</span
                    >
                  </td>
                  <td>
                    <span>{{ product.metafields.spec.diepte | remove: '"' | remove: '[' | remove: ']' }}</span>
                  </td>
                </tr>
              {% endif %}
              {% if product.metafields.spec.hoogte != blank %}
                <tr>
                  <td>
                    <span>
                      {%- if section.settings.hoogte %}
                        <button type="button" data-bs-toggle="modal" data-bs-target="#hoogte">
                          <img
                            src="https://cdn.shopify.com/s/files/1/0474/0454/8262/files/info-circle-solid.svg?v=1750928404"
                            alt=""
                          >
                        </button>
                      {%- endif -%}
                      Hoogte</span
                    >
                  </td>
                  <td>
                    <span>{{ product.metafields.spec.hoogte | remove: '"' | remove: '[' | remove: ']' }}</span>
                  </td>
                </tr>
              {% endif %}
              {% if product.metafields.spec.gewicht != blank %}
                <tr>
                  <td>
                    <span>
                      {%- if section.settings.gewicht %}
                        <button type="button" data-bs-toggle="modal" data-bs-target="#gewicht">
                          <img
                            src="https://cdn.shopify.com/s/files/1/0474/0454/8262/files/info-circle-solid.svg?v=1750928404"
                            alt=""
                          >
                        </button>
                      {%- endif -%}
                      Gewicht</span
                    >
                  </td>
                  <td>
                    <span>{{ product.metafields.spec.gewicht }}</span>
                  </td>
                </tr>
              {% endif %}
              {% if product.metafields.spec.lengte != blank %}
                <tr>
                  <td>
                    <span>
                      {%- if section.settings.lengte %}
                        <button type="button" data-bs-toggle="modal" data-bs-target="#lengte">
                          <img
                            src="https://cdn.shopify.com/s/files/1/0474/0454/8262/files/info-circle-solid.svg?v=1750928404"
                            alt=""
                          >
                        </button>
                      {%- endif -%}
                      Lengte</span
                    >
                  </td>
                  <td>
                    {% assign lengte_values = product.metafields.spec.lengte | split: ',' %}
                    {% for lengte in lengte_values %}
                      {% assign clean_lengte = lengte | strip %}
                      <a
                        href="/collections/all?filter.v.availability=1&filter.p.m.spec.lengte={{ clean_lengte | url_encode }}"
                        class="spec-filter-link"
                      >
                        {{- clean_lengte -}}
                      </a>
                      {%- unless forloop.last %}, {% endunless %}
                    {% endfor %}
                  </td>
                </tr>
              {% endif %}
              {% if product.metafields.spec.dikte_blad  != blank %}
                <tr>
                  <td>
                    <span>
                      {% if section.settings.dikte_blad %}
                        <button type="button" data-bs-toggle="modal" data-bs-target="#dikte_blad">
                          <img
                            src="https://cdn.shopify.com/s/files/1/0474/0454/8262/files/info-circle-solid.svg?v=1750928404"
                            alt="info"
                          >
                        </button>
                      {% endif %}
                      Dikte blad
                    </span>
                  </td>
                  <td>
                    <span>{{ product.metafields.spec.dikte_blad }}</span>
                  </td>
                </tr>
              {% endif %}
               {% if product.metafields.custom.dikte_rand_blad != blank %}
                <tr>
                  <td>
                    <span>
                      {% if section.settings.dikte_rand_blad %}
                        <button type="button" data-bs-toggle="modal" data-bs-target="#dikte_rand_blad">
                          <img
                            src="https://cdn.shopify.com/s/files/1/0474/0454/8262/files/info-circle-solid.svg?v=1750928404"
                            alt="info"
                          >
                        </button>
                      {% endif %}
                      Dikte rand blad
                    </span>
                  </td>
                  <td>
                    <span>{{ product.metafields.custom.dikte_rand_blad }}</span>
                  </td>
                </tr>
              {% endif %}
              {% if product.metafields.custom.montage != blank %}
                <tr>
                  <td>
                    <span>
                      {% if section.settings.montage %}
                        <button type="button" data-bs-toggle="modal" data-bs-target="#montage">
                          <img
                            src="https://cdn.shopify.com/s/files/1/0474/0454/8262/files/info-circle-solid.svg?v=1750928404"
                            alt="info"
                          >
                        </button>
                      {% endif %}
                      Montage
                    </span>
                  </td>
                  <td>
                    <span>{{ product.metafields.custom.montage }}</span>
                  </td>
                </tr>
              {% endif %}
            </tbody>
          </table>
        </div>
        <div class="description-block">
          <div class="titlebar">
            <h3>Omschrijving</h3>
          </div>
          <div class="detail">
            <p>
              {{ product.description }}
            </p>
          </div>
          <a href="javascript:void(0);" class="btn-secondary">Toon meer <i class="fas fa-chevron-down"></i></a>
        </div>

        <div class="reviews-block" id="review-block-anchor">
          <div class="titlebar">
            <h3>Reviews</h3>
          </div>
          <div id="random_quotes"></div>
        </div>
      </div>
      <div class="col-md-5 col-sm-12">
        <div class="checkout-block">
          <div class="titlebar">
            <h3>{{ section.settings.title }}</h3>
          </div>
          {% if product.metafields.custom.upsell_products.value != blank %}
            <div class="row">
              {% for items in product.metafields.custom.upsell_products.value %}
                <div class="col-md-6 col-sm-12">
                  <div class="product-box coll-page">
                    <a href="{{ items.url }}">
                      <div class="box-img">
                        <img
                          srcset="
                            {%- if items.featured_media.width >= 165 -%}{{ items.featured_media | image_url: width: 165 }} 165w,{%- endif -%}
                            {%- if items.featured_media.width >= 360 -%}{{ items.featured_media | image_url: width: 360 }} 360w,{%- endif -%}
                            {%- if items.featured_media.width >= 533 -%}{{ items.featured_media | image_url: width: 533 }} 533w,{%- endif -%}
                            {%- if items.featured_media.width >= 720 -%}{{ items.featured_media | image_url: width: 720 }} 720w,{%- endif -%}
                            {%- if items.featured_media.width >= 940 -%}{{ items.featured_media | image_url: width: 940 }} 940w,{%- endif -%}
                            {%- if items.featured_media.width >= 1066 -%}{{ items.featured_media | image_url: width: 1066 }} 1066w,{%- endif -%}
                            {{ items.featured_media | image_url }} {{ items.featured_media.width }}w
                          "
                          src="{{ items.featured_media | image_url: width: 533 }}"
                          sizes="(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 130 | divided_by: 4 }}px, (min-width: 990px) calc((100vw - 130px) / 4), (min-width: 750px) calc((100vw - 120px) / 3), calc((100vw - 35px) / 2)"
                          alt="{{ items.featured_media.alt | escape }}"
                          class="motion-reduce"
                          {% unless lazy_load == false %}
                            loading="lazy"
                          {% endunless %}
                          width="{{ items.featured_media.width }}"
                          height="{{ items.featured_media.height }}"
                        >
                        <div class="main-tags">
                          {%- for coll in items.collections -%}
                            {% if coll.title == settings.collectionss.title %}
                             
                              {% comment %} NA DE BLACKFRIDAY AANZETTEN {% endcomment %}
                              {% comment %} <div
                                class="collname"
                                style="color: {{ settings.tag_color }}; background: {{ settings.tag_background }};"
                              >
                                <span class="super" style="color: {{ settings.tag_color }};">
                                  {{- settings.tag_title -}}
                                </span>
                                <span class="sale" style="color: {{ settings.tag_color2 }};">
                                  {{- settings.tag_title2 -}}
                                </span>
                              </div> {% endcomment %}
                            
                              <div class="notification-bar" style="background:none!important; padding: 0px!important;border-radius: 10px!important;">
                                <div class="notification-block">
                                    <h6 style="padding: 4px 10px !important; width: 100%; border-radius: 5px;">
                                        <b>SUPER</b>
                                        <span>SALE</span>
                                    </h6>
                            </div>
                          </div>
                        {% endif %}
                          {% endfor %}

                          {%- if items.compare_at_price > items.price -%}
                            {% capture discount %}{{ items.compare_at_price_max | minus:items.price | money }}€{% endcapture %}
                            <label>€{{ discount | remove: ',00€' | remove: '€' }} korting</label>
                          {% endif %}
                        </div>
                      </div>
                      <div class="description">
                        <h3>{{ items.title }}</h3>
                        {% assign current_variant = items.selected_or_first_available_variant %}
                        {% if current_variant.inventory_quantity > 0 %}
                          <h5 class="stockss show-stock-desktop show-stock-tablet show-stock-mobile">
                            Op voorraad (vandaag besteld, binnen 1-10 werkdagen bezorgd)
                          </h5>
                        {% endif %}
                        {% if items.metafields.arena.stockinfo != blank and current_variant.inventory_quantity <= 0 %}
                          {% if items.selected_or_first_available_variant.available == false %}
                            <!-- Out of stock -->
                          {% else %}
                            <h5
                              class="weekss show-delivery-weeks-desktop show-delivery-weeks-tablet show-delivery-weeks-mobile"
                              data-levertijd="{{ items.metafields.arena.stockinfo }}"
                            ></h5>
                          {% endif %}
                        {% endif %}
                        {%- if items.compare_at_price > items.price -%}
                          <p>
                            Adviesprijs <span>{{ items.compare_at_price | money }}</span>
                          </p>
                        {% endif %}
                        <h6>{{ items.price | money }},-</h6>
                      </div>
                    </a>
                  </div>
                </div>
              {% endfor %}
            </div>
          {% else %}
            <div class="row">
              {% if section.settings.collection != blank %}
                {% assign collection_handle = section.settings.collection %}
                {% assign collection = collections[collection_handle] %}
                {% if collection.products_count > 0 %}
                  {% for product in collection.products limit: section.settings.products_limit %}
                    <div class="col-md-6 col-sm-12">
                      <div class="product-box coll-page">
                        <a href="{{ product.url }}">
                          <div class="box-img">
                            <img
                              srcset="
                                {%- if product.featured_media.width >= 165 -%}{{ product.featured_media | image_url: width: 165 }} 165w,{%- endif -%}
                                {%- if product.featured_media.width >= 360 -%}{{ product.featured_media | image_url: width: 360 }} 360w,{%- endif -%}
                                {%- if product.featured_media.width >= 533 -%}{{ product.featured_media | image_url: width: 533 }} 533w,{%- endif -%}
                                {%- if product.featured_media.width >= 720 -%}{{ product.featured_media | image_url: width: 720 }} 720w,{%- endif -%}
                                {%- if product.featured_media.width >= 940 -%}{{ product.featured_media | image_url: width: 940 }} 940w,{%- endif -%}
                                {%- if product.featured_media.width >= 1066 -%}{{ product.featured_media | image_url: width: 1066 }} 1066w,{%- endif -%}
                                {{ product.featured_media | image_url }} {{ product.featured_media.width }}w
                              "
                              src="{{ product.featured_media | image_url: width: 533 }}"
                              sizes="(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 130 | divided_by: 4 }}px, (min-width: 990px) calc((100vw - 130px) / 4), (min-width: 750px) calc((100vw - 120px) / 3), calc((100vw - 35px) / 2)"
                              alt="{{ product.featured_media.alt | escape }}"
                              class="motion-reduce"
                              {% unless lazy_load == false %}
                                loading="lazy"
                              {% endunless %}
                              width="{{ product.featured_media.width }}"
                              height="{{ product.featured_media.height }}"
                            >
                            <div class="main-tags">
                              {%- for coll in product.collections -%}
                                {% if coll.title == settings.collectionss.title %}
                                  
                                  {% comment %} NA DE BLACKFRIDAY AANZETTEN {% endcomment %}
                                  {% comment %} <div
                                    class="collname"
                                    style="color: {{ settings.tag_color }}; background: {{ settings.tag_background }};"
                                  >
                                    <span class="super" style="color: {{ settings.tag_color }};">
                                      {{- settings.tag_title -}}
                                    </span>
                                    <span class="sale" style="color: {{ settings.tag_color2 }};">
                                      {{- settings.tag_title2 -}}
                                    </span>
                                  </div> {% endcomment %}
                                
                                  <div class="notification-bar" style="background:none!important; padding: 0px!important;border-radius: 10px!important;">
                                    <div class="notification-block">
                                        <h6 style="padding: 4px 10px !important; width: 100%; border-radius: 5px;">
                                            <b>SUPER</b>
                                            <span>SALE</span>
                                        </h6>
                                </div>
                              </div>
                            {% endif %}
                              {% endfor %}

                              {%- if product.compare_at_price > product.price -%}
                                {% capture discount %}{{ product.compare_at_price_max | minus:product.price | money }}€{% endcapture %}
                                <label>€{{ discount | remove: ',00€' | remove: '€' }} korting</label>
                              {% endif %}
                            </div>
                          </div>
                          <div class="description">
                            <h3>{{ product.title }}</h3>
                            {% assign current_variant = product.selected_or_first_available_variant %}
                            {% if current_variant.inventory_quantity > 0 %}
                              <h5 class="stockss show-stock-desktop show-stock-tablet show-stock-mobile">
                                Op voorraad (vandaag besteld, binnen 1-10 werkdagen bezorgd)
                              </h5>
                            {% endif %}
                            {% if product.metafields.arena.stockinfo != blank
                              and current_variant.inventory_quantity <= 0
                            %}
                              {% if product.selected_or_first_available_variant.available == false %}
                                <!-- Out of stock -->
                              {% else %}
                                <h5
                                  class="weekss show-delivery-weeks-desktop show-delivery-weeks-tablet show-delivery-weeks-mobile"
                                  data-levertijd="{{ product.metafields.arena.stockinfo }}"
                                ></h5>
                              {% endif %}
                            {% endif %}
                            {%- if product.compare_at_price > product.price -%}
                              <p>
                                Adviesprijs <span>{{ product.compare_at_price | money }}</span>
                              </p>
                            {% endif %}
                            <h6>{{ product.price | money }},-</h6>
                          </div>
                        </a>
                      </div>
                    </div>
                  {% endfor %}
                {% endif %}
              {% endif %}
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>
<!-- popup model code -->
{% if section.settings.garantie %}
  <div
    class="modal fade description-modal"
    id="garantie"
    tabindex="-1"
    aria-labelledby="garantieLabel"
    aria-hidden="true"
  >
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Garantie</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal">
            Sluiten
            <img src="https://cdn.shopify.com/s/files/1/0474/0454/8262/files/close-icon-black.svg?v=1726308511" alt="">
          </button>
        </div>
        <div class="modal-body">
          {{ section.settings['garantie-text'] }}
        </div>
      </div>
    </div>
  </div>
{% endif %}
{% if section.settings.material %}
  <div
    class="modal fade description-modal"
    id="material"
    tabindex="-1"
    aria-labelledby="materialLabel"
    aria-hidden="true"
  >
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Materiaal</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal">
            Sluiten
            <img src="https://cdn.shopify.com/s/files/1/0474/0454/8262/files/close-icon-black.svg?v=1726308511" alt="">
          </button>
        </div>
        <div class="modal-body">
          {{ section.settings['material-text'] }}
        </div>
      </div>
    </div>
  </div>
{% endif %}
{% if section.settings.stijl %}
  <div class="modal fade description-modal" id="stijl" tabindex="-1" aria-labelledby="stijlLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
