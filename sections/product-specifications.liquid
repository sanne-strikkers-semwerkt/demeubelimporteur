<script>
  $(document).ready(function () {
    // Function to remove empty or whitespace-only tags
    function removeEmptyTags() {
      $('.detail')
        .contents()
        .filter(function () {
          // Check if the node is a text node and contains only whitespace or non-breaking spaces
          if (this.nodeType === 3 && !/\S/.test(this.nodeValue.replace(/&nbsp;/g, ''))) {
            return true;
          }
          // Check if the element is empty or contains only whitespace or non-breaking spaces
          if (this.nodeType === 1) {
            var $this = $(this);
            if (
              $this.is(':empty') ||
              !$this
                .text()
                .trim()
                .replace(/&nbsp;/g, '').length
            ) {
              return true;
            }
          }
          return false;
        })
        .remove();
    }

    // Call the function on document ready
    removeEmptyTags();

    // Handle delivery time for product cards
    function updateDeliveryTimes() {
      $('.product-box .weekss').each(function () {
        var $this = $(this);
        var levertijdText = $this.data('levertijd');

        if (levertijdText) {
          var updatedText = processDeliveryTime(levertijdText);
          $this.text(updatedText);
        }
      });
    }

    function processDeliveryTime(levertijdText) {
      const rangeRegex = /tussen de\s+(\d+)\s+en\s+(\d+)\s+weken/i;
      const singleWeekRegex = /(\d+)\s*weken?/i;
      const vanafWeekRegex = /vanaf\s+week\s+(\d+)/i;

      let updatedText = levertijdText;

      if (rangeRegex.test(levertijdText)) {
        let match = levertijdText.match(rangeRegex);
        let earliestWeek = parseInt(match[1]);
        let dateAndMonth = getMondayOfWeekFromToday(earliestWeek);
        updatedText = `Levering vanaf ${dateAndMonth}`;
      } else if (vanafWeekRegex.test(levertijdText)) {
        let match = levertijdText.match(vanafWeekRegex);
        let weekNumber = parseInt(match[1]);
        let dateAndMonth = getMondayOfWeek(weekNumber);
        updatedText = `Levering vanaf ${dateAndMonth}`;
      } else if (singleWeekRegex.test(levertijdText)) {
        let match = levertijdText.match(singleWeekRegex);
        let weekNumber = parseInt(match[1]);
        let dateAndMonth = getMondayOfWeek(weekNumber);
        updatedText = `Levering vanaf ${dateAndMonth}`;
      }

      return updatedText;
    }

    function getMondayOfWeekFromToday(weeksFromToday) {
      let today = new Date();
      let targetDate = new Date(today.getFullYear(), today.getMonth(), today.getDate() + weeksFromToday * 7);

      // Get the Monday of the target week
      let day = targetDate.getDay();
      let diffToMonday = day === 0 ? -6 : 1 - day; // Adjust for Sunday = 0
      let monday = new Date(targetDate);
      monday.setDate(targetDate.getDate() + diffToMonday);

      let mondayDay = monday.getDate();
      const monthName = monday.toLocaleString('nl-NL', { month: 'long' });
      return `${mondayDay} ${monthName}`;
    }

    function getMondayOfWeek(weekNumber, year) {
      year = year || new Date().getFullYear();
      let jan1 = new Date(year, 0, 1);
      let jan1Day = jan1.getDay();
      let offset = jan1Day <= 4 ? 1 - jan1Day : 8 - jan1Day;
      let monday = new Date(year, 0, 1 + offset + (weekNumber - 1) * 7);
      let day = monday.getDate();
      const monthName = monday.toLocaleString('nl-NL', { month: 'long' }); // Dutch month
      return `${day} ${monthName}`;
    }

    // Call the function on document ready
    updateDeliveryTimes();

    dquote();

    dquote();

    function dquote() {
      var quotes = [
        {
          name: 'kenzo',
          quote:
            'Zeer tevreden van de meubels ! Wat staan ze hier prachtig !<br>Ook dienst na verkoop niets op aan te merken !<br>Vlot bereikbaar, zeer snel feedback, behulpzaam en vriendelijk !<br>Een aanrader !',
        },

        { name: 'Peter', quote: 'Zeer nette en vlotte levering en betaalbaar' },

        { name: 'Sjoerd', quote: 'Goede service, Korte levertijd, Prima volgens afspraak.' },

        {
          name: 'Henk',
          quote:
            'Wat een geweldige service en een fantastisch product! We genieten iedere dag weer opnieuw van dit prachtige product!',
        },

        {
          name: 'Hans van der Post',
          quote:
            'Correct behandeld in toonzaal.Duidelijke afspraken qua levering en betaling. Tijdig op <br>de hoogte gebracht van datum feitelijke levering. Keurig eubels gemonteerd en alle <br>verpakking meegenomen. <br><br>Kortom: zeer prettig zakendoen met de Meubel Importeur',
        },

        {
          name: 'Rob',
          quote:
            "Erg goede kwaliteit, snelle levering en het is allemaal zo in elkaar gezet. Zoals ze zo<br>mooi zeggen in het Nederlands 'een kind kan de was doen'",
        },

        {
          name: 'Danielle',
          quote:
            'Super service! De levering verliep perfect, zelf een moment kunnen kiezen en van te<br>voren ook nog gebeld worden als de bezorger er bijna was. Heel blij met de eubels,<br>geweldige prijs kwaliteit verhouding! 3,5 jaar geleden al salontafels, een tv meubel en<br>een vakkenkast gekocht en nu de set compleet gemaakt met een eettafel en<br>dressoir!',
        },

        { name: 'Angelique Pouw', quote: 'Top service en alle keren goede kwaliteit!' },

        { name: 'R', quote: 'Alles vlot verlopen, op tijd en volgens afspraak geleverd en de tafel is prachtig! :)' },

        { name: 'remy', quote: 'Mooie kast, uitstekende kwaliteit en nette bezorging. Top' },

        {
          name: 'Dorus Klinkert',
          quote:
            'Netjes geleverd en gemonteerd afval meegenomen alles op zijn plaats gezet beveel<br>jullie zeker aan bij familie en vrienden',
        },

        { name: 'Casper Van Herwaarden', quote: 'Erg snelle levering en goede prijs-/kwaliteitverhouding!' },

        { name: 'Maura', quote: 'Supermooi meubel, snelle levering en fijne service!' },

        {
          name: 'Anne Van H',
          quote:
            'Super goed bedrijf! Bestelling snel bezorgd. Goede service en mooie producten. Zou<br>er zeker weer bestellen.',
        },

        {
          name: 'Dirk Weller',
          quote:
            'Alles ging naar wens, op tijd geleverd en voldoet volledig aan de verwachting en dat<br>voor die prijs .. 😉👍',
        },
      ];

      var shownQuotes = JSON.parse(localStorage.getItem('shownQuotes')) || [];
      var newQuotes = [];

      while (newQuotes.length < 3) {
        var dquote = quotes[Math.floor(Math.random() * quotes.length)];
        if (!shownQuotes.includes(dquote.name)) {
          newQuotes.push(dquote);
          shownQuotes.push(dquote.name);
        }
        if (shownQuotes.length === quotes.length) {
          shownQuotes = [];
        }
      }

      localStorage.setItem('shownQuotes', JSON.stringify(shownQuotes));

      var html = '';
      newQuotes.forEach(function (dquote) {
        html +=
          '<div class="review-box">' +
          '<h6><span>' +
          '<img src="https://cdn.shopify.com/s/files/1/0563/8412/7158/files/Vector_4_e0f1a400-0cc9-4026-9216-0dbef3424057.svg?v=1718273262" alt="">' +
          '<img src="https://cdn.shopify.com/s/files/1/0563/8412/7158/files/Vector_4_e0f1a400-0cc9-4026-9216-0dbef3424057.svg?v=1718273262" alt="">' +
          '<img src="https://cdn.shopify.com/s/files/1/0563/8412/7158/files/Vector_4_e0f1a400-0cc9-4026-9216-0dbef3424057.svg?v=1718273262" alt="">' +
          '<img src="https://cdn.shopify.com/s/files/1/0563/8412/7158/files/Vector_4_e0f1a400-0cc9-4026-9216-0dbef3424057.svg?v=1718273262" alt="">' +
          '<img src="https://cdn.shopify.com/s/files/1/0563/8412/7158/files/Vector_4_e0f1a400-0cc9-4026-9216-0dbef3424057.svg?v=1718273262" alt="">' +
          '</span>' +
          '</h6>' +
          '<ul><li class="re-name">' +
          dquote['name'] +
          '</li><li>Heeft dit artikel gekocht</li></ul>' +
          '<div class="col">' +
          '<p>' +
          dquote['quote'] +
          '</p>' +
          '</div>' +
          '</div>';
      });

      $('#random_quotes').html(html);
    }
  });
</script>

<style>
  /* Stock Information Visibility Controls */
  {% unless settings.show_stock_desktop %}
    .show-stock-desktop {
      display: none !important;
    }
  {% endunless %}

  {% unless settings.show_stock_tablet %}
    @media (max-width: 1024px) and (min-width: 768px) {
      .show-stock-tablet {
        display: none !important;
      }
    }
  {% endunless %}

  {% unless settings.show_stock_mobile %}
    @media (max-width: 767px) {
      .show-stock-mobile {
        display: none !important;
      }
    }
  {% endunless %}

  /* Delivery Weeks Visibility Controls */
  {% unless settings.show_delivery_weeks_desktop %}
    .show-delivery-weeks-desktop {
      display: none !important;
    }
  {% endunless %}

  {% unless settings.show_delivery_weeks_tablet %}
    @media (max-width: 1024px) and (min-width: 768px) {
      .show-delivery-weeks-tablet {
        display: none !important;
      }
    }
  {% endunless %}

  {% unless settings.show_delivery_weeks_mobile %}
    @media (max-width: 767px) {
      .show-delivery-weeks-mobile {
        display: none !important;
      }
    }
  {% endunless %}



  /* List styling for description block ul elements */
  .description-block .detail ul {
    list-style-type: disc !important;
    padding-left: 20px !important;
  }

  .description-block .detail ul li {
    list-style-type: disc !important;
    font-size: 15px;
    display: list-item !important;
    font-family: Poppins, sans-serif;
  }

  /* Specification table styling */
  .specificaties-block table tbody tr:nth-child(odd) td:last-child {
    background: #f1f1f1;
  }

  .specificaties-block table tbody tr:nth-child(even) td:last-child {
    background: #ffffff;
  }

  .specificaties-block table tbody tr td:last-child {
    border-radius: 0 4px 4px 0;
    padding: 8px 12px;
  }

  /* Specification filter links styling */
  .specificaties-block table tbody tr td:last-child a {
    background: inherit;
    padding: 2px 8px;
    border-radius: 4px;
    text-decoration: none;
    color: inherit;
    transition: background-color 0.3s ease;
    display: inline-block;
    border: 1px solid rgba(0, 0, 0, 0.2);
  }

  .specificaties-block table tbody tr td:last-child a:hover {
    background: rgba(0, 0, 0, 0.1);
  }

  /* Specification span styling - same as links */
  .specificaties-block table tbody tr td:last-child span {
    background: inherit;
    padding: 4px 8px;
    border-radius: 4px;
    display: inline-block;
  }

  /* Do NOT style descriptive text as clickable boxes */
  .specificaties-block table tbody tr td:last-child span.spec-description-text {
    background: transparent;
    padding: 0;
    border-radius: 0;
    border: none;
    display: inline;
  }
</style>

