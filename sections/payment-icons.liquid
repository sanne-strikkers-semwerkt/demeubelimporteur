{% comment %}
  Payment Icons Section
  Simple payment methods display for theme customizer
{% endcomment %}

<div class="payment-icons-section color-{{ section.settings.color_scheme }} gradient" 
     style="
       {%- if section.settings.background_color != blank -%}background-color: {{ section.settings.background_color }};{%- endif -%}
       {%- if section.settings.text_color != blank -%}color: {{ section.settings.text_color }};{%- endif -%}
       padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
       padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
     ">
  <div class="page-width">
    <div class="payment-icons-section__content">
      
      {%- if shop.enabled_payment_types.size > 0 -%}
        <ul class="payment-icons-section__list list-payment" role="list">
          {%- for type in shop.enabled_payment_types -%}
            <li class="payment-icons-section__item list-payment__item">
              {{ type | payment_type_svg_tag: class: 'payment-icons-section__icon icon icon--full-color' }}
            </li>
          {%- endfor -%}
        </ul>
      {%- else -%}
        <p class="payment-icons-section__empty">{{ 'sections.footer.no_payment_methods' | t }}</p>
      {%- endif -%}
    </div>
  </div>
</div>

{% style %}
  .payment-icons-section {
    width: 100%;
  }

  .payment-icons-section__content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: {{ section.settings.alignment | default: 'center' }};
  }

  .payment-icons-section__title {
    margin: 0;
    font-weight: 600;
  }

  .payment-icons-section__list {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    list-style: none;
    margin: 0;
    padding: 0;
    justify-content: {{ section.settings.alignment | default: 'center' }};
  }

  .payment-icons-section__item {
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    padding: 0.8rem;
    transition: all 0.3s ease;
  }

  .payment-icons-section__item:hover {
    background: rgba(255, 255, 255, 0.2);
    transform: translateY(-2px);
  }

  .payment-icons-section__icon {
    height: auto;
    max-width: 100%;
    filter: brightness(0) invert(1);
    width: {{ section.settings.icon_size | default: 'medium' | replace: 'small', '2.4rem' | replace: 'medium', '3.2rem' | replace: 'large', '4rem' }};
    height: {{ section.settings.icon_size | default: 'medium' | replace: 'small', '1.6rem' | replace: 'medium', '2.1rem' | replace: 'large', '2.6rem' }};
  }

  .payment-icons-section__empty {
    color: inherit;
    font-style: italic;
    margin: 0;
    opacity: 0.8;
  }

  /* Responsive design */
  @media (min-width: 750px) {
    .payment-icons-section {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  @media (max-width: 768px) {
    .payment-icons-section__list {
      gap: 0.8rem;
    }
    
    .payment-icons-section__item {
      padding: 0.6rem;
    }
    
    .payment-icons-section__icon {
      width: {{ section.settings.icon_size | default: 'medium' | replace: 'small', '2rem' | replace: 'medium', '2.8rem' | replace: 'large', '3.2rem' }};
      height: {{ section.settings.icon_size | default: 'medium' | replace: 'small', '1.3rem' | replace: 'medium', '1.8rem' | replace: 'large', '2.1rem' }};
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Payment Icons",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Show title",
      "default": true
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "We accept"
    },
    {
      "type": "select",
      "id": "icon_size",
      "label": "Icon size",
      "options": [
        {
          "value": "small",
          "label": "Small"
        },
        {
          "value": "medium",
          "label": "Medium"
        },
        {
          "value": "large",
          "label": "Large"
        }
      ],
      "default": "medium"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "background-1"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Payment Icons"
    }
  ]
}
{% endschema %}
