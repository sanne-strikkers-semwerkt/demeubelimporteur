<section class="about-reviews-wrp">
  <div class="container">
    <div class="review-title">
      <h2>{{ section.settings['reviews-heading'] | escape }}</h2>
      <a href="{{ section.settings.rateus-btn-link }}" target="_blank" class="btn-orange">
        {{ section.settings['rateus-btn-text'] | escape }}
      </a>
    </div>

    <div class="about-review-slider"></div>

    <a href="{{ section.settings.rateus-btn-link }}" target="_blank" class="btn-orange mobile-btn-orange">
      {{ section.settings['rateus-btn-text'] | escape }}
    </a>
  </div>
</section>

{% render 'crisp-chat' %}

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const reviewSlider = document.querySelector('.about-review-slider');
    if (!reviewSlider) return;

    const config = {
      shopId: '{{ section.settings.webwinkelkeur_id }}',
      publicCode: '{{ section.settings.webwinkelkeur_public_code }}',
      limit: parseInt('{{ section.settings.max_reviews }}', 10) || 10,
      cacheKey: 'wkk_reviews_cache_{{ section.id }}',
      cacheTTL: 1000 * 60 * 60,
    };

    function isLocalStorageAvailable() {
      try {
        const test = '__storage_test__';
        localStorage.setItem(test, test);
        localStorage.removeItem(test);
        return true;
      } catch (e) {
        return false;
      }
    }

    function getCachedReviews() {
      if (!isLocalStorageAvailable()) return null;
      const cached = localStorage.getItem(config.cacheKey);
      if (!cached) return null;
      try {
        const data = JSON.parse(cached);
        if (Date.now() - data.timestamp < config.cacheTTL) {
          return data.ratings;
        }
        localStorage.removeItem(config.cacheKey);
        return null;
      } catch {
        localStorage.removeItem(config.cacheKey);
        return null;
      }
    }

    function setCachedReviews(ratings) {
      if (!isLocalStorageAvailable()) return;
      const dataToCache = {
        ratings,
        timestamp: Date.now(),
      };
      localStorage.setItem(config.cacheKey, JSON.stringify(dataToCache));
    }

    function createStarHtml(ratingValue) {
      let stars = '';
      for (let i = 0; i < 5; i++) {
        const starIcon =
          i < ratingValue
            ? 'https://cdn.shopify.com/s/files/1/0563/8412/7158/files/star-icon.svg'
            : 'https://cdn.shopify.com/s/files/1/0563/8412/7158/files/star-grey-icon.svg';
        const altText = i < ratingValue ? 'star-icon' : 'empty-star-icon';
        stars += `<li><img src="${starIcon}" alt="${altText}" /></li>`;
      }
      return stars;
    }

    // FIX: New function to format the date from YYYY-MM-DD to DD-MM-YYYY
    function formatDate(dateString) {
      if (!dateString || !/^\d{4}-\d{2}-\d{2}$/.test(dateString)) {
        return dateString; // Return original if format is unexpected
      }
      const [year, month, day] = dateString.split('-');
      return `${day}-${month}-${year}`;
    }

    function createReviewHtml(rating) {
      const { name = 'Anonieme klant', rating: ratingValue = 0, comment = '', date = '', country = '' } = rating;

      const flagMap = {
        NL: 'https://www.demeubelimporteur.nl/cdn/shop/files/nederland-icon_small.svg?v=1747380887',
        BE: 'https://cdn.shopify.com/s/files/1/0563/8412/7158/files/belgie-icon_587292f0-ae96-4df8-abcd-212eff6f7435.svg?v=1750160378',
        // Add more countries if needed
      };

      const countryCode = country.trim().toUpperCase();
      const flagUrl = flagMap[countryCode] || '';
      const starsHtml = createStarHtml(ratingValue);
      const formattedDate = formatDate(date);

      // Handle null/empty comments
      const commentText = comment;

      return `
    <div>
      <div class="slider-box">
        <ul class="rating-icon">${starsHtml}</ul>
        <h3>
          ${
            flagUrl
              ? `<img src="${flagUrl}" alt="${countryCode} vlag" style="width:20px; height:20px; margin-right:6px; vertical-align:middle;" />`
              : ''
          }
          ${name}
        </h3>
        <h6><span>${formattedDate}</span> Review voor De Meubel Importeur</h6>
        <p>${commentText}</p>
      </div>
    </div>
  `;
    }

    function renderReviews(ratings) {
      if (!ratings || ratings.length === 0) {
        reviewSlider.innerHTML = '<p>Er zijn nog geen 5-sterren reviews beschikbaar.</p>';
        return;
      }
      const html = ratings.map(createReviewHtml).join('');
      reviewSlider.innerHTML = html;
      $(reviewSlider).slick({
        arrows: true,
        dots: true,
        autoplay: false,
        autoplaySpeed: 4500,
        speed: 500,
        infinite: true,
        slidesToShow: 3,
        slidesToScroll: 1,
        responsive: [
          {
            breakpoint: 1199,
            settings: {
              slidesToShow: 2,
            },
          },
          {
            breakpoint: 767,
            settings: {
              slidesToShow: 1,
            },
          },
        ],
      });
    }
async function fetchAndRenderReviews() {
  const cachedReviews = getCachedReviews();
  if (cachedReviews) {
    // Apply the same filter to cached reviews
    const filteredCachedReviews = cachedReviews.filter(r => {
      return r.rating === 5 && 
             r.comment && 
             r.comment !== 'null' && 
             r.comment.trim() !== '';
    });
    renderReviews(filteredCachedReviews);
    return;
  }
  try {
    const apiUrl = `https://dashboard.webwinkelkeur.nl/api/1.0/ratings.json?id=${config.shopId}&public_code=${config.publicCode}&limit=50`;
    const response = await fetch(apiUrl);
    if (!response.ok) {
      throw new Error(`HTTP error! status: ${response.status}`);
    }
    const data = await response.json();
    if (data.status !== 'success' || !data.ratings) {
      throw new Error('Fout bij het ophalen van de reviews-data.');
    }
    const sortedRatings = data.ratings.sort((a, b) => new Date(b.date) - new Date(a.date));
    const fiveStarRatings = sortedRatings.filter(r => {
      return r.rating === 5 && 
             r.comment && 
             r.comment !== 'null' && 
             r.comment.trim() !== '';
    }).slice(0, config.limit);
    setCachedReviews(fiveStarRatings);
    renderReviews(fiveStarRatings);
  } catch (error) {
    console.error('Fout bij laden van reviews:', error);
    reviewSlider.innerHTML = '<p>Fout bij laden van reviews. Probeer het later opnieuw.</p>';
  }
}
    fetchAndRenderReviews();
  });
</script>

{% schema %}
{
  "name": "Reviews",
  "settings": [
    {
      "type": "text",
      "id": "reviews-heading",
      "label": "Titel",
      "default": "Wat klanten zeggen"
    },
    {
      "type": "text",
      "id": "rateus-btn-text",
      "label": "Knoptekst",
      "default": "Geef jouw mening"
    },
    {
      "type": "url",
      "id": "rateus-btn-link",
      "label": "Link voor knop"
    },
    {
      "type": "header",
      "content": "Webwinkelkeur Instellingen"
    },
    {
      "type": "text",
      "id": "webwinkelkeur_id",
      "label": "Webwinkelkeur Shop ID",
      "default": "1214608"
    },
    {
      "type": "text",
      "id": "webwinkelkeur_public_code",
      "label": "Webwinkelkeur Publieke Code"
    },
    {
      "type": "range",
      "id": "max_reviews",
      "min": 5,
      "max": 50,
      "step": 1,
      "label": "Maximaal aantal reviews",
      "default": 10
    }
  ],
  "presets": [
    {
      "name": "Reviews"
    }
  ]
}
{% endschema %}
