{%- style -%}
  .spacer-component-{{ section.id }} {
    height: {{ section.settings.spacer_height | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .spacer-component-{{ section.id }} {
      height: {{ section.settings.spacer_height }}px;
    }
  }

  {%- if section.settings.spacer_height_mobile > 0 -%}
    @media screen and (max-width: 749px) {
      .spacer-component-{{ section.id }} {
        height: {{ section.settings.spacer_height_mobile }}px;
      }
    }
  {%- endif -%}
{%- endstyle -%}

<div class="spacer-component-{{ section.id }}"></div>

{% schema %}
{
  "name": "Spacer",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "range",
      "id": "spacer_height",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Spatie hoogte (desktop)",
      "default": 40
    },
    {
      "type": "range",
      "id": "spacer_height_mobile",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Spatie hoogte (mobiel)",
      "info": "0 = gebruik desktop waarde",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Spacer"
    }
  ]
}
{% endschema %}

