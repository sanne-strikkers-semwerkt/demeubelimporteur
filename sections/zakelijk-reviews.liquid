<style>
  .zakelijk-reviews {
    padding: 60px 0;
    background-color: #f1f1f1;
  }
  .zakelijk-reviews h2 {
    font-family: 'Zilla Slab', serif;
    font-weight: 600;
    font-size: 32px;
    line-height: 25px;
    color: #000000;
    margin-bottom: 40px;
  }
  .zakelijk-reviews-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
    margin-bottom: 30px;
  }
  .zakelijk-review-card {
    background-color: #ffffff;
    border: 1px solid #d8d8d8;
    border-radius: 10px;
    padding: 30px;
  }
  .zakelijk-review-stars {
    display: flex;
    gap: 5px;
    margin-bottom: 15px;
  }
  .zakelijk-review-star {
    width: 16px;
    height: 16px;
    fill: #fbba00;
  }
  .zakelijk-review-star.empty {
    fill: #cfcfcf;
  }
  .zakelijk-review-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 15px;
  }
  .zakelijk-review-author {
    font-family: 'Poppins', sans-serif;
    font-weight: 400;
    font-size: 15px;
    line-height: 22.5px;
    color: #000000;
  }
  .zakelijk-review-flag {
    width: 17px;
    height: 17px;
    border-radius: 2px;
  }
  .zakelijk-review-date {
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    font-size: 12px;
    line-height: 18px;
    color: #9b9b9b;
    margin-bottom: 15px;
  }
  .zakelijk-review-text {
    font-family: 'Poppins', sans-serif;
    font-weight: 400;
    font-size: 15px;
    line-height: 25px;
    color: #000000;
  }
  .zakelijk-reviews-pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 10px;
  }
  .zakelijk-reviews-pagination-dot {
    width: 13px;
    height: 13px;
    border-radius: 50%;
    background-color: #d9d9d9;
    border: none;
    cursor: pointer;
    transition: background-color 0.3s;
  }
  .zakelijk-reviews-pagination-dot.active {
    background-color: #000000;
  }
  .zakelijk-reviews-pagination-nav {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    border: 1px solid #d8d8d8;
    background-color: #ffffff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.3s;
  }
  .zakelijk-reviews-pagination-nav:hover {
    background-color: #f1f1f1;
  }
  @media (max-width: 991px) {
    .zakelijk-reviews-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }
  }
  @media (max-width: 767px) {
    .zakelijk-reviews-grid {
      grid-template-columns: 1fr;
    }
    .zakelijk-reviews {
      padding: 40px 0;
    }
  }
</style>

<section class="zakelijk-reviews">
  <div class="container">
    {% if section.settings.heading != blank %}
      <h2>{{ section.settings.heading }}</h2>
    {% endif %}
    <div class="zakelijk-reviews-grid">
      {% for block in section.blocks %}
        <div class="zakelijk-review-card" {{ block.shopify_attributes }}>
          <div class="zakelijk-review-stars">
            {% assign rating = block.settings.rating | default: 5 %}
            {% for i in (1..5) %}
              {% if i <= rating %}
                <svg class="zakelijk-review-star" viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg">
                  <path d="M8 0L10.163 5.52786L16 6.11146L11.8541 9.94428L12.9443 16L8 12.5279L3.05573 16L4.1459 9.94428L0 6.11146L5.83698 5.52786L8 0Z"/>
                </svg>
              {% else %}
                <svg class="zakelijk-review-star empty" viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg">
                  <path d="M8 0L10.163 5.52786L16 6.11146L11.8541 9.94428L12.9443 16L8 12.5279L3.05573 16L4.1459 9.94428L0 6.11146L5.83698 5.52786L8 0Z"/>
                </svg>
              {% endif %}
            {% endfor %}
          </div>
          <div class="zakelijk-review-meta">
            {% if block.settings.author != blank %}
              <span class="zakelijk-review-author">{{ block.settings.author }}</span>
            {% endif %}
            {% if block.settings.flag != blank %}
              <img src="{{ block.settings.flag | img_url: '17x17' }}" alt="Flag" class="zakelijk-review-flag">
            {% endif %}
          </div>
          {% if block.settings.date != blank %}
            <div class="zakelijk-review-date">{{ block.settings.date }}</div>
          {% endif %}
          {% if block.settings.text != blank %}
            <p class="zakelijk-review-text">{{ block.settings.text }}</p>
          {% endif %}
        </div>
      {% endfor %}
    </div>
    <div class="zakelijk-reviews-pagination">
      <button class="zakelijk-reviews-pagination-nav" aria-label="Previous">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M12.5 15L7.5 10L12.5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <button class="zakelijk-reviews-pagination-dot active" aria-label="Page 1"></button>
      <button class="zakelijk-reviews-pagination-dot" aria-label="Page 2"></button>
      <button class="zakelijk-reviews-pagination-dot" aria-label="Page 3"></button>
      <button class="zakelijk-reviews-pagination-dot" aria-label="Page 4"></button>
      <button class="zakelijk-reviews-pagination-dot" aria-label="Page 5"></button>
      <button class="zakelijk-reviews-pagination-nav" aria-label="Next">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M7.5 15L12.5 10L7.5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Zakelijk Reviews",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Reviews voor De Meubel Importeur"
    }
  ],
  "blocks": [
    {
      "type": "zak_review",
      "name": "Review",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "label": "Rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author Name",
          "default": "R. Verhulst"
        },
        {
          "type": "image_picker",
          "id": "flag",
          "label": "Country Flag"
        },
        {
          "type": "text",
          "id": "date",
          "label": "Date",
          "default": "23-04-2025   Review voor DeMeubelimporteur"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Review Text",
          "default": "Verkoop ging wat slechter maar de afwikkeling was zeer goed."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Zakelijk Reviews",
      "category": "Zakelijk",
      "blocks": [
        {
          "type": "zak_review",
          "settings": {
            "rating": 4,
            "author": "R. Verhulst",
            "date": "23-04-2025   Review voor DeMeubelimporteur",
            "text": "Verkoop ging wat slechter maar de afwikkeling was zeer goed."
          }
        },
        {
          "type": "zak_review",
          "settings": {
            "rating": 5,
            "author": "R. Coenen",
            "date": "23-04-2025   Review voor DeMeubelimporteur",
            "text": "Top service voor een mooie prijs!"
          }
        },
        {
          "type": "zak_review",
          "settings": {
            "rating": 5,
            "author": "E Postma",
            "date": "23-04-2025   Review voor DeMeubelimporteur",
            "text": "Alleen de stoelen zijn nog niet binnen maar we zijn tot heden zeer tevreden goede service en ook goed advies hopelijk komen de stoelen eerder dan week 33 verder alles goed"
          }
        }
      ]
    }
  ]
}
{% endschema %}
