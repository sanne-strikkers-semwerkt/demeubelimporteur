{% comment %}
  Shopify Wishlist
  Usage:
    - Create a new page in the Shopify admin
      - Admin > Online store > Pages > Add page
    - Set the new page's template to: 'page.wishlist'
    - Do NOT remove the `grid-wishlist` attribute
  
  Notes:
  - The grid will be populated with product cards using Javascript
  - Any content inside of the `[grid-wishlist]` element will be completely replaced by the product cards
  
  Tip:
  - Place a loading element inside the `[grid-wishlist]` element and it will automatically be removed once the product cards have loaded
  - Add any liquid code before/after the grid element
{% endcomment %}
<div class="container">
  <h2 class="wishlist-title">Wishlist</h2>
  <div class="wishlist__grid flex container" grid-wishlist>
    {% comment %} Sample loading element {% endcomment %}
    
    <div class="wishlist__loader full-width text-center">Loading...</div>
  </div>
</div>
<style>
  .wishlist__grid .breadcrumb, .wishlist__grid .detail-title, .wishlist__grid .product-detail-block .col-md-3, .wishlist__grid .product-detail-info .price-block h2 span, .wishlist__grid .order-block h5,
  .wishlist__grid .product-detail-info .order-block ul li, .wishlist__grid .description, .wishlist__grid .slider.slider-for div , .wishlist__grid .order-block{display: none;}
  .wishlist__grid .slider.slider-for div:first-child, .wishlist__grid .wishlists-for .btn-heart{display: block;}
  .wishlist__grid .product-detail-block .slider-for .slider-box .currentImg-wishlist{display:block;width: 100%; max-width: 300px; height: 300px; max-height: 300px; min-height: unset;}
  .wishlist__grid .product-detail-block .slider-for .slider-box .currentImg{display:none;}
  .wishlist__grid .product-detail-wrp{width: 23%;}
  .wishlist__grid .for-wish .col-sm-12{width: 100%;}
  .wishlist__grid .title-product{display: block; margin-top: 15px; font-weight: 600;}
  .wishlist__grid .wishlists-for{display: flex; justify-content: space-between;}
  .wishlist__grid .wishlists-for .btn-heart{border: none; background: transparent;}
  .wishlist__grid .for-wish{flex-direction: column;}
  .wishlist__grid.flex.container.loaded{display: flex; gap: 20px; flex-wrap: wrap;}
  .wishlist__grid .product-detail-wrp{padding: 0;}
  .wishlist-title{text-align: center;margin: 30px 0; font-weight: 600;}
  .wishlist__grid .title-product.tileees{display: block;}
  .wishlist__grid .title-product.tileees a{color: #000;}
  .wishlist__grid .title-product{display: none;}
  @media only screen and (max-width: 991px){
    .wishlist__grid .product-detail-wrp{width: 31%;}
  }
  @media only screen and (max-width: 767px){
    .wishlist__grid .product-detail-wrp{width: 48%;}
    .wishlist__grid .product-detail-wrp .container, .wishlist__grid .product-detail-info{padding: 0;}
  }
  @media only screen and (max-width: 575px){
    .wishlist__grid .product-detail-wrp {
        width: 47%;
    }
  }
  @media only screen and (max-width: 480px){
    .wishlist__grid .product-detail-wrp{width: 100%;}
    .wishlist__grid .product-detail-block .slider-for .slider-box img{margin: auto;}
  }
</style>

{% schema %}
  {
    "templates": ["page"]
  }
{% endschema %}