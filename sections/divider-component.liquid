{%- style -%}
  .divider-component-{{ section.id }} {
    margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
    margin-bottom: {{ section.settings.margin_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .divider-component-{{ section.id }} {
      margin-top: {{ section.settings.margin_top }}px;
      margin-bottom: {{ section.settings.margin_bottom }}px;
    }
  }

  .divider-component-{{ section.id }} .divider-component__line {
    border-top: {{ section.settings.line_thickness }}px {{ section.settings.line_style }} {% if section.settings.line_color != blank %}{{ section.settings.line_color }}{% else %}rgba(var(--color-foreground), 0.1){% endif %};
    width: {{ section.settings.line_width }}%;
    margin: 0 auto;
  }
{%- endstyle -%}

<div class="divider-component-{{ section.id }}{% unless section.settings.full_width %} page-width{% endunless %}">
  <div class="divider-component__line"></div>
</div>

{% schema %}
{
  "name": "Divider",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "range",
      "id": "line_thickness",
      "min": 1,
      "max": 10,
      "step": 1,
      "unit": "px",
      "label": "Lijn dikte",
      "default": 1
    },
    {
      "type": "select",
      "id": "line_style",
      "label": "Lijn stijl",
      "options": [
        {
          "value": "solid",
          "label": "Volledig"
        },
        {
          "value": "dashed",
          "label": "Gestippeld"
        },
        {
          "value": "dotted",
          "label": "Puntjes"
        }
      ],
      "default": "solid"
    },
    {
      "type": "color",
      "id": "line_color",
      "label": "Lijn kleur",
      "info": "Laat leeg om de standaard kleur te gebruiken"
    },
    {
      "type": "range",
      "id": "line_width",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Lijn breedte",
      "default": 100
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Volle breedte",
      "default": false
    },
    {
      "type": "header",
      "content": "Marges"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Marge boven",
      "default": 20
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Marge onder",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Divider"
    }
  ]
}
{% endschema %}

