        <div id="ai-history-empty-state" style="display:none; text-align:center; padding: 40px 20px;">
          <p>Uw analysegeschiedenis is leeg.</p>
          <small>Voltooide analyses worden hier automatisch opgeslagen.</small>
        </div>
        <button
          id="ai-clear-history-button"
          style="display:none; margin: 15px auto 0;  background:none; border:none; color: var(--text-color-light); cursor:pointer; display:block;"
        >
          Wis Geschiedenis
        </button>
      </div>

      <div id="ai-analysis-view" class="ai-modal-view">
        <div style="text-align: center;">
          <img
            id="ai-image-preview-analysis"
            src=""
            alt="Room preview"
            style="max-height: 250px; border-radius: var(--border-radius-sm); margin-bottom: 0px; object-fit: cover;"
          >
          <div class="ai-live-analysis-wrapper">
            <div class="ai-thought-bubble">
              <div id="ai-live-analysis-text-container">
