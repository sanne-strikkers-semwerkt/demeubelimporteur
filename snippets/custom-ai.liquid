      <div id="ai-results-view" class="ai-modal-view">
        <div id="ai-final-analysis-card">
          <img id="ai-image-preview-results" src="" alt="Uw geuploade foto">
          <div>
            <h4 style="margin-top:0;">Mijn Stijlanalyse</h4>
            <strong id="ai-style-name"></strong>
            <p id="ai-style-description" style="color: var(--text-color-light);"></p>
          </div>
        </div>
        <h3 class="text-lg font-bold">Passende aanbevelingen:</h3>
        <div id="product-results-container"></div>
        <div class="white-background-sticky">
          <button class="ai-advisor-trigger-button2 ai-restart-button" id="ai-restart-button">
            <i class="fa-solid fa-image"></i> Analyseer een nieuwe foto
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<template id="ai-product-card-template">
  <div class="ai-product-card">
    <img src="" alt="">
    <div class="ai-product-card-info">
      <h4 class="text-sm"><a href="" target="_blank" rel="noopener noreferrer"></a></h4>
      <div class="ai-product-price"></div>
    </div>
  </div>
</template>

<template id="ai-history-item-template">
  <div class="ai-history-item">
    <img src="" alt="Historie afbeelding">
    <div class="ai-history-item-info">
      <strong></strong>
      <small></small>
    </div>
  </div>
</template>

<div id="ai-toast"></div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const AIStyleAdvisor = {
      config: {
        historyKey: 'demeubelimporteur_ai_history',
        styleApiUrl: 'https://ai-stylist-endpoint.vercel.app/api/style-advice',
        geminiApiKey: 'AIzaSyDZ0grvqRXhS12Q5RwhG1MsI1PV3Ooup0s',
        geminiApiEndpoint: 'https://generativelanguage.googleapis.com/v1beta/models/gemini-pro:generateContent',
        phrases: {
          analysis: [
            'Oké, even kijken...',
            'Ik scan de compositie...',
            'Nu identificeer ik de kleuren...',
            'Ik herken de meubelstijlen...',
            'Momentje, ik koppel dit aan interieurstijlen...',
            'Perfect! Ik zoek nu naar passende producten.',
          ],
          error: (msg) => `Oeps, er ging iets mis. ${msg}`,
        },
      },

      state: {
        history: [],
        analysisInterval: null,
        toastTimeout: null,
        currentPhraseIndex: 0,
      },

      elements: {
        modal: document.getElementById('ai-advisor-modal'),
        triggerBtn: document.getElementById('ai-advisor-trigger'),
        closeBtn: document.getElementById('ai-modal-close'),
        restartBtn: document.getElementById('ai-restart-button'),
        clearHistoryBtn: document.getElementById('ai-clear-history-button'),
        tabs: document.querySelectorAll('.ai-tab-button'),
        views: document.querySelectorAll('.ai-modal-view'),
        fileInput: document.getElementById('ai-file-uploader'),
        uploadLabel: document.getElementById('ai-upload-label'),

        history: {
          list: document.getElementById('ai-history-list'),
          emptyState: document.getElementById('ai-history-empty-state'),
        },
        analysis: {
          view: document.getElementById('ai-analysis-view'),
          imagePreview: document.getElementById('ai-image-preview-analysis'),
          textContainer: document.getElementById('ai-live-analysis-text-container'),
        },
        results: {
          view: document.getElementById('ai-results-view'),
          imagePreview: document.getElementById('ai-image-preview-results'),
          styleName: document.getElementById('ai-style-name'),
          styleDescription: document.getElementById('ai-style-description'),
          productsContainer: document.getElementById('product-results-container'),
        },

        toast: document.getElementById('ai-toast'),
        templates: {
          productCard: document.getElementById('ai-product-card-template'),
          historyItem: document.getElementById('ai-history-item-template'),
        },
      },

      init() {
        this.bindEvents();
      },

      bindEvents() {
        this.elements.triggerBtn.addEventListener('click', () => this.ui.openModal());
        this.elements.closeBtn.addEventListener('click', () => this.ui.closeModal());
        this.elements.modal.addEventListener('click', (e) => {
          if (e.target === this.elements.modal) this.ui.closeModal();
        });
        this.elements.restartBtn.addEventListener('click', () => this.ui.setActiveTab('upload'));
        this.elements.clearHistoryBtn.addEventListener('click', () => this.history.clear());

        this.elements.tabs.forEach((tab) => {
          tab.addEventListener('click', () => this.ui.setActiveTab(tab.dataset.tab));
        });

        this.elements.fileInput.addEventListener('change', (e) => this.handleFileUpload(e.target.files[0]));

        this.elements.uploadLabel.addEventListener('dragover', (e) => {
          e.preventDefault();
          e.currentTarget.classList.add('dragover');
        });
        this.elements.uploadLabel.addEventListener('dragleave', (e) => e.currentTarget.classList.remove('dragover'));
        this.elements.uploadLabel.addEventListener('drop', (e) => {
          e.preventDefault();
          e.currentTarget.classList.remove('dragover');
          if (e.dataTransfer.files.length) this.handleFileUpload(e.dataTransfer.files[0]);
        });

        this.elements.history.list.addEventListener('click', (e) => {
          const item = e.target.closest('.ai-history-item');
          if (item) this.history.viewItem(item.dataset.historyId);
        });
      },

      async handleFileUpload(file) {
        if (!file || !file.type.startsWith('image/')) {
          this.ui.showToast('Selecteer a.u.b. een geldig afbeeldingsbestand.', true);
          return;
        }

        try {
          const base64Image = await this.utils.fileToBase64(file);
          this.ui.showView('analysis');
          this.elements.analysis.imagePreview.src = base64Image;
          this.elements.results.imagePreview.src = base64Image;

          this.ui.startAnalysisAnimation();

          const result = await this.api.getStyleRecommendations(base64Image);
          if (!result || !result.analysis) throw new Error('De AI kon geen analyse genereren.');

          await this.history.save(base64Image, result);
          this.ui.displayResults(result, true); // showSkeletons = true
        } catch (error) {
          console.error('Analysis failed:', error);
          this.ui.showAnalysisError(error.message);
        } finally {
          this.ui.stopAnalysisAnimation();
          this.elements.fileInput.value = ''; // Reset file input
        }
      },

      ui: {
        openModal() {
          AIStyleAdvisor.history.load();
          AIStyleAdvisor.ui.setActiveTab('upload');
          AIStyleAdvisor.elements.modal.classList.add('active');
        },
        closeModal() {
          AIStyleAdvisor.elements.modal.classList.remove('active');
        },

        showView(viewName) {
          AIStyleAdvisor.elements.views.forEach((v) => v.classList.remove('active'));
          document.getElementById(`ai-${viewName}-view`).classList.add('active');
        },

        setActiveTab(tabName) {
          AIStyleAdvisor.elements.tabs.forEach((t) => t.classList.toggle('active', t.dataset.tab === tabName));
          this.showView(tabName);
        },

        showToast(message, isError = false) {
          const { toast } = AIStyleAdvisor.elements;
          clearTimeout(AIStyleAdvisor.state.toastTimeout);
          toast.textContent = message;
          toast.className = isError ? 'error' : '';
          toast.classList.add('show');
          AIStyleAdvisor.state.toastTimeout = setTimeout(() => toast.classList.remove('show'), 3500);
        },

        startAnalysisAnimation() {
          this.stopAnalysisAnimation();
          const textEl = AIStyleAdvisor.elements.analysis.textContainer.querySelector('p');
          const phrases = AIStyleAdvisor.config.phrases.analysis;

          const updateText = () => {
            textEl.style.opacity = '0';
            setTimeout(() => {
              AIStyleAdvisor.state.currentPhraseIndex = (AIStyleAdvisor.state.currentPhraseIndex + 1) % phrases.length;
              textEl.innerHTML = `<em>${phrases[AIStyleAdvisor.state.currentPhraseIndex]}</em>`;
              textEl.style.opacity = '1';
            }, 300);
          };

          updateText();
          AIStyleAdvisor.state.analysisInterval = setInterval(updateText, 2000);
        },

        stopAnalysisAnimation() {
          clearInterval(AIStyleAdvisor.state.analysisInterval);
          AIStyleAdvisor.state.currentPhraseIndex = 0;
        },

        showAnalysisError(message) {
          const { textContainer } = AIStyleAdvisor.elements.analysis;
          textContainer.innerHTML = `<p style="color:#d32f2f;">${AIStyleAdvisor.config.phrases.error(message)}</p>`;
        },

        async displayResults(data, fetchJustifications = false) {
          const { styleName, styleDescription, productsContainer } = AIStyleAdvisor.elements.results;
          styleName.innerText = data.analysis.style_name;
          styleDescription.innerText = data.analysis.description;

          if (!data.products || data.products.length === 0) {
            productsContainer.innerHTML = '<p>Helaas kon ik geen passende producten vinden voor deze analyse.</p>';
            this.showView('results');
            return;
          }

          if (fetchJustifications) {
            productsContainer.innerHTML = Array(data.products.length).fill(this.createSkeletonCard()).join('');
            this.showView('results');

            const justifications = await Promise.all(
              data.products.map((p) => AIStyleAdvisor.api.getGeminiJustification(p.title, data.analysis.style_name))
            );

            productsContainer.innerHTML = data.products
              .map((p, i) => this.createProductCard(p, justifications[i]))
              .join('');
          } else {
            // From history, justification is already stored
            productsContainer.innerHTML = data.products.map((p) => this.createProductCard(p, p.justification)).join('');
            this.showView('results');
          }
        },

        createProductCard(product, justification) {
          const card = AIStyleAdvisor.elements.templates.productCard.content.cloneNode(true).firstElementChild;
          card.querySelector('img').src = product.imageUrl || '';
          card.querySelector('img').alt = product.title;
          card.querySelector('a').href = product.url;
          card.querySelector('a').textContent = product.title;
          card.querySelector('.ai-product-price').textContent = `€${parseFloat(product.price).toFixed(2)}`;
          return card.outerHTML;
        },

        createSkeletonCard() {
          return `
                    <div class="ai-product-card skeleton">
                        <div class="skeleton-img"></div>
                        <div class="ai-product-card-info">
                            <div class="skeleton-text"></div>
                            <div class="skeleton-text-sm"></div>
                        </div>
                    </div>`;
        },
      },

      history: {
        load() {
          try {
            AIStyleAdvisor.state.history = JSON.parse(localStorage.getItem(AIStyleAdvisor.config.historyKey) || '[]');
          } catch (e) {
            console.error('Could not parse history', e);
            AIStyleAdvisor.state.history = [];
          }
          this.render();
        },

        render() {
          const { history } = AIStyleAdvisor.state;
          const { list, emptyState } = AIStyleAdvisor.elements.history;
          const hasHistory = history.length > 0;

          emptyState.style.display = hasHistory ? 'none' : 'block';
          AIStyleAdvisor.elements.clearHistoryBtn.style.display = hasHistory ? 'block' : 'none';

          list.innerHTML = '';
          history.forEach((item) => {
            const el = AIStyleAdvisor.elements.templates.historyItem.content.cloneNode(true).firstElementChild;
            el.dataset.historyId = item.id;
            el.querySelector('img').src = item.thumbnail;
            el.querySelector('strong').textContent = item.analysis.style_name;
            el.querySelector('small').textContent = `Geanalyseerd op ${new Date(item.timestamp).toLocaleDateString(
              'nl-NL'
            )}`;
            list.appendChild(el);
          });
        },

        async save(fullImageData, resultData) {
          const thumbnail = await AIStyleAdvisor.utils.createImageThumbnail(fullImageData);
          const justifications = await Promise.all(
            resultData.products.map((p) =>
              AIStyleAdvisor.api.getGeminiJustification(p.title, resultData.analysis.style_name)
            )
          );

          const productsWithJustification = resultData.products.map((p, i) => ({
            ...p,
            justification: justifications[i],
          }));

          const newEntry = {
            id: Date.now(),
            timestamp: new Date().toISOString(),
            thumbnail,
            fullImage: fullImageData,
            analysis: resultData.analysis,
            products: productsWithJustification,
          };

          let history = AIStyleAdvisor.state.history;
          history.unshift(newEntry);
          if (history.length > 10) history.pop();

          try {
            // Don't save full-res image to localStorage to save space
            const historyForStorage = history.map(({ fullImage, ...rest }) => rest);
            localStorage.setItem(AIStyleAdvisor.config.historyKey, JSON.stringify(historyForStorage));
          } catch (e) {
            console.error('Could not save history to localStorage.', e);
          }

          this.render();
        },

        clear() {
          if (confirm('Weet u zeker dat u uw volledige geschiedenis wilt wissen?')) {
            AIStyleAdvisor.state.history = [];
            localStorage.removeItem(AIStyleAdvisor.config.historyKey);
            this.render();
          }
        },

        viewItem(id) {
          const item = AIStyleAdvisor.state.history.find((h) => h.id == id);
          if (item) {
            AIStyleAdvisor.elements.results.imagePreview.src = item.fullImage;
            AIStyleAdvisor.ui.displayResults(item, false); // No new justifications needed
          }
        },
      },

      utils: {
        fileToBase64(file) {
          return new Promise((resolve, reject) => {
            const reader = new FileReader();
            reader.readAsDataURL(file);
            reader.onload = () => resolve(reader.result);
            reader.onerror = reject;
          });
        },

        createImageThumbnail(base64Str, maxDim = 200) {
          return new Promise((resolve, reject) => {
            const img = new Image();
            img.src = base64Str;
            img.onload = () => {
              let { width, height } = img;
              if (width > height) {
                if (width > maxDim) {
                  height *= maxDim / width;
                  width = maxDim;
                }
              } else {
                if (height > maxDim) {
                  width *= maxDim / height;
                  height = maxDim;
                }
              }
              const canvas = document.createElement('canvas');
              canvas.width = width;
              canvas.height = height;
              canvas.getContext('2d').drawImage(img, 0, 0, width, height);
              resolve(canvas.toDataURL('image/jpeg', 0.7));
            };
            img.onerror = reject;
          });
        },
      },

      api: {
        async getStyleRecommendations(base64Image) {
          const response = await fetch(AIStyleAdvisor.config.styleApiUrl, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ image: base64Image, context: { page_url: window.location.href } }),
          });
          if (!response.ok) {
            const errorData = await response.json().catch(() => ({}));
            throw new Error(errorData.error || `Server responded with status ${response.status}`);
          }
          return await response.json();
        },

        async getGeminiJustification(productTitle, styleName) {
          const { geminiApiKey, geminiApiEndpoint } = AIStyleAdvisor.config;
          if (!geminiApiKey || geminiApiKey === 'AIzaSyAZCy1kkiYgcE4tCaSMfJmKlMdUQyLdNrE') {
            console.warn('Gemini API Key is not set. Using fallback text.');
            return 'Een uitstekende keuze voor uw interieur.';
          }

          const prompt = `Je bent een interieurexpert voor Demeubelimporteur.nl. Schrijf één korte, overtuigende zin (max 15 woorden) waarom een "${productTitle}" perfect past in een kamer met een "${styleName}" stijl. Spreek direct tegen de klant.`;

          try {
            const response = await fetch(`${geminiApiEndpoint}?key=${geminiApiKey}`, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ contents: [{ parts: [{ text: prompt }] }] }),
            });
            if (!response.ok) throw new Error('Gemini API response was not ok.');
            const data = await response.json();
            const text = data?.candidates?.[0]?.content?.parts?.[0]?.text;
            if (text) return text.trim();
            throw new Error('Invalid response structure from Gemini API.');
          } catch (error) {
            console.error('Gemini API call failed:', error);
            return 'Een perfecte stilistische aanvulling op uw interieur.'; // Fallback
          }
        },
      },
    };

    AIStyleAdvisor.init();
  });
</script>
