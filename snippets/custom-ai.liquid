<style>
  :root {
    --primary-color: #fb5a00;
    --primary-color-light: #fff8f5;
    --text-color: #333;
    --text-color-light: #666;
    --background-light: #ffffff;
    --background-medium: #f7f7f7;
    --border-color: #e5e5e5;
    --border-radius-sm: 8px;
    --border-radius-md: 16px;
    --shadow-sm: 0 4px 15px rgba(0, 0, 0, 0.07);
    --shadow-md: 0 8px 30px rgba(0, 0, 0, 0.12);
    --font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    --transition-speed: 0.3s;
  }

  .ai-advisor-trigger-button {
    font-family: var(--font-family);
    
    font-weight: 500;
    border-radius: var(--border-radius-sm);
    border: none;
    background: transparent;
    color: var(--primary-color);
    cursor: pointer;
    transition: all var(--transition-speed) ease;
  }

  .ai-advisor-trigger-button2 {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    font-family: var(--font-family);
    
    font-weight: 600;
    padding: 12px 24px;
    border-radius: var(--border-radius-sm);
    border: none;
    background-color: var(--primary-color);
    color: var(--background-light);
    cursor: pointer;
    transition: all var(--transition-speed) ease;
    box-shadow: var(--shadow-sm);
  }

  .divider-vertical {
    height: 12px;
    width: 1px;
    background: #333;
  }
  .ai-advisor-trigger-button:hover,
  .ai-advisor-trigger-button:focus-visible {
    outline: none;
    text-decoration: underline;
  }

  .ai-modal-overlay {
    display: none;
    position: fixed;
    z-index: 9999;
    inset: 0;
    background-color: rgba(0, 0, 0, 0.6);
    animation: fadeIn var(--transition-speed) ease;
  }
  .ai-modal-overlay.active {
    display: block;
  }

  .ai-modal-content {
    font-family: var(--font-family);
    position: relative;
    background-color: var(--background-medium);
    margin: 5vh auto;
    width: 90%;
    max-width: 680px;
    height: 90vh;
    max-height: 800px;
    border-radius: var(--border-radius-md);
    box-shadow: var(--shadow-md);
    animation: slideIn 0.4s ease-out;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .ai-modal-header {
    padding: 20px 30px;
    background-color: var(--background-light);
    border-bottom: 1px solid var(--border-color);
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-shrink: 0;
  }
  .ai-modal-header h3 {
    margin: 0;
    
    color: var(--text-color);
    font-weight: 700;
  }

  .product-overview-wrp .overview-title h3 {
    margin-bottom: 0px;
  }

  .ai-modal-close-button {
    color: var(--text-color-light);
    
    font-weight: 700;
    cursor: pointer;
    transition: color 0.2s;
    border: none;
    background: none;
    padding: 0;
  }
  .ai-modal-close-button:hover,
  .ai-modal-close-button:focus-visible {
    color: var(--primary-color);
    outline: none;
  }

  .ai-modal-tabs {
    display: flex;
    background-color: var(--background-medium);
    padding: 8px;
    border-bottom: 1px solid var(--border-color);
    flex-shrink: 0;
    gap: 8px;
  }
  .ai-tab-button {
    flex: 1;
    padding: 12px 10px;
    border: none;
    background-color: transparent;
    cursor: pointer;
    font-family: var(--font-family);
    
    font-weight: 600;
    color: var(--text-color-light);
    border-radius: var(--border-radius-sm);
    transition: all 0.2s ease-in-out;
  }
  .ai-tab-button.active {
    background-color: var(--background-light);
    color: var(--primary-color);
    box-shadow: 0 2px 5px rgba(0, 0, 0, 0.05);
  }

  .white-background-sticky {
    background: white;
    width: 100%;
    position: absolute;
    bottom: 0;
    left: 0;
    padding: 11px 30px;
    border-top: 1px solid var(--border-color);
  }

  .ai-modal-body {
    padding: 30px;
    overflow-y: auto;
    height: 100%;
  }
  .ai-modal-view {
    display: none;
  }
  .ai-modal-view.active {
    display: block;
    animation: fadeInUp 0.5s;
  }

  #ai-upload-label {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 40px;
    border: 2px dashed var(--border-color);
    border-radius: var(--border-radius-md);
    text-align: center;
    cursor: pointer;
    background-color: var(--background-light);
    transition: all 0.2s;
  }
  .font-sized-custom {
    
    color: #333333;
  }
  #ai-upload-label:hover,
  #ai-upload-label.dragover {
    border-color: var(--primary-color);
    background-color: var(--primary-color-light);
  }

  .ai-live-analysis-wrapper {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-top: 20px;
  }
  .ai-avatar {
    width: 45px;
    height: 45px;
    border-radius: 50%;
    background: linear-gradient(45deg, var(--primary-color), #ff8c42);
    flex-shrink: 0;
    box-shadow: var(--shadow-sm);
  }
  .ai-thought-bubble {
    position: relative; 
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    background-color: var(--background-light);
    border-radius: 24px;
    padding: 20px;
    width: 100%;
    min-height: 80px;
    max-height: 80px;
    box-shadow: var(--shadow-sm);
    margin-left: 15px;
  }

  .ai-thought-bubble::before {
    content: '';
    position: absolute;
    width: 0;
    height: 0;
    border-style: solid;
    /* Position tail on the left, pointing to the avatar */
    top: 50%;
    left: -15px;
    transform: translateY(-50%);
    /* Create a triangle pointing left */
    border-width: 10px 15px 10px 0;
    border-color: transparent var(--background-light) transparent transparent;
  }

  /* --- Add this inside your existing @media (max-width: 768px) block --- */

  /* Reset margins for column layout */
  .ai-thought-bubble {
    margin-left: 0;
    margin-top: 15px; /* Add space for the tail on top */
  }

  /* Reposition the tail for mobile view */
  .ai-thought-bubble::before {
    /* Position tail on the top, pointing to the avatar */
    top: -15px;
    left: 50%;
    transform: translateX(-50%);
    /* Create a triangle pointing up */
    border-width: 0 10px 15px 10px;
    border-color: transparent transparent var(--background-light) transparent;
  }

  #ai-live-analysis-text-container p {
    margin: 0;
    transition: opacity 0.3s;
  }

  #ai-final-analysis-card {
    background-color: var(--background-light);
    border-radius: var(--border-radius-md);
    padding: 24px;
    margin-bottom: 30px;
    border: 1px solid var(--border-color);
    display: flex;
    gap: 24px;
    align-items: flex-start;
  }
  #ai-image-preview-results {
    width: 120px;
    height: 120px;
    border-radius: var(--border-radius-sm);
    object-fit: cover;
    flex-shrink: 0;
  }
  #ai-style-name {
    font-weight: 700;
    color: var(--primary-color);
    display: block;
    margin-top: 0;
    margin-bottom: 8px;
    
  }

  /* Improved Product Card & Skeleton Loader */
  .ai-product-card {
    display: flex;
    background: var(--background-light);
    margin-block: 10px;
    align-items: center;
    padding: 12px;
    border-radius: var(--border-radius-md);
    border: 1px solid var(--border-color);
    transition: background-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }
  .ai-product-card:hover {
    background-color: #f1f1f1;
    transform: translateY(-2px);
    box-shadow: var(--shadow-sm);
  }
  .ai-product-card img {
    width: 80px;
    height: 80px;
    object-fit: cover;
    margin-right: 16px;
    border-radius: var(--border-radius-sm);
    flex-shrink: 0;
  }
  .ai-product-card-info {
    flex-grow: 1;
  }
  .ai-product-card-info h4 {
    margin: 0 0 4px;
  }
  .ai-product-card-info h4 a {
    text-decoration: none;
    color: var(--text-color);
    
    font-weight: 600;
  }
  .ai-product-card-info h4 a:hover {
    color: var(--primary-color);
  }
  .ai-product-price {
    font-weight: 600;
    color: var(--text-color);
  }

  .skeleton {
    opacity: 1;
    background-color: #f0f0f0;
    border-color: #e0e0e0;
    position: relative;
    overflow: hidden;
  }
  .skeleton::after {
    content: '';
    position: absolute;
    top: 0;
    left: -150%;
    width: 150%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.4), transparent);
    animation: shimmer 1.5s infinite;
  }
  .skeleton-img {
    width: 80px !important;
    height: 80px !important;
    background-color: #e0e0e0;
    border-radius: var(--border-radius-sm);
  }
  .skeleton-text {
    height: 20px;
    width: 80%;
    background-color: #e0e0e0;
    border-radius: 4px;
    margin-bottom: 8px;
  }
  .skeleton-text-sm {
    height: 16px;
    width: 40%;
    background-color: #e0e0e0;
    border-radius: 4px;
  }

  #ai-toast {
    position: fixed;
    bottom: -100px;
    left: 50%;
    transform: translateX(-50%);
    width: calc(100% - 40px);
    max-width: 500px;
    background-color: var(--text-color);
    color: var(--background-light);
    padding: 16px 24px;
    border-radius: var(--border-radius-sm);
    box-shadow: var(--shadow-md);
    z-index: 10000;
    transition: transform 0.5s ease-in-out, background-color 0.3s;
    font-family: var(--font-family);
    
    text-align: center;
  }
  #ai-toast.show {
    transform: translate(-50%, -20px);
  }
  #ai-toast.error {
    background-color: #d32f2f;
  }

  .ai-history-item {
    display: flex;
    align-items: center;
    padding: 12px;
    border-radius: var(--border-radius-sm);
    margin-bottom: 10px;
    cursor: pointer;
    transition: background-color 0.2s;
    border: 1px solid var(--border-color);
    background: var(--background-light);
  }
  .ai-history-item:hover {
    background-color: #f0f0f0;
  }
  .ai-history-item img {
    width: 60px;
    height: 60px;
    border-radius: 6px;
    object-fit: cover;
    margin-right: 15px;
  }
  .ai-history-item-info strong {
    display: block;
    
    color: var(--text-color);
  }
  .ai-history-item-info small {
    
    color: var(--text-color-light);
  }

  .ai-restart-button {
    margin-top: 0px;
    width: 100%;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
  @keyframes slideIn {
    from {
      transform: translateY(-30px);
      opacity: 0;
    }
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @keyframes shimmer {
    100% {
      left: 150%;
    }
  }

  @media (max-width: 768px) {
    .ai-modal-content {
      width: 100%;
      height: 100%;
      max-height: 100vh;
      border-radius: 0;
      margin: 0;
    }
    .ai-modal-header {
      padding: 15px 20px;
    }
    .ai-modal-header h3 {
      
    }
    .ai-modal-body {
      padding: 30px 10px;
    }
    #ai-final-analysis-card {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 15px;
    }
    .ai-live-analysis-wrapper {
      flex-direction: column;
      align-items: center;
      gap: 15px;
    }
    .ai-avatar {
      margin-right: 0;
    }
  }

  .ai-modal-view.active {
    padding-bottom: 60px;
  }
  #ai-image-preview-analysis {
    margin: auto;
  }
</style>

<button class="ai-advisor-trigger-button" id="ai-advisor-trigger">Start Ai stijladvies</button>

<div id="ai-advisor-modal" class="ai-modal-overlay" role="dialog" aria-modal="true" aria-labelledby="ai-modal-title">
  <div class="ai-modal-content">
    <div class="ai-modal-header">
      <h3 id="ai-modal-title">Ai interieur stijladvies</h3>
      <button class="ai-modal-close-button" id="ai-modal-close" aria-label="Close modal">&times;</button>
    </div>
    <div class="ai-modal-tabs">
      <button class="ai-tab-button active" data-tab="upload"><i class="fa-solid fa-plus"></i> Nieuwe Analyse</button>
      <button class="ai-tab-button" data-tab="history">
        <i class="fa-solid fa-clock-rotate-left"></i> Mijn Geschiedenis
      </button>
    </div>
    <div class="ai-modal-body">
      <div id="ai-upload-view" class="ai-modal-view active">
        <p>
          Krijg direct meubeladvies. Upload een foto van uw kamer en onze AI vindt de perfecte items die naadloos
          aansluiten bij uw stijl.
        </p>
        <label for="ai-file-uploader" id="ai-upload-label">
          <i class="fa-solid fa-cloud-arrow-up font-sized-custom"></i>
          <strong>Klik of sleep hier uw foto</strong>
        </label>
        <input type="file" id="ai-file-uploader" accept="image/jpeg, image/png" style="display:none;">
      </div>

      <div id="ai-history-view" class="ai-modal-view">
