{% assign hidden_product_id = 15706174095694 %}
{% unless card_product.id == hidden_product_id %}
<div class="col-lg-3 col-md-4 col-sm-12">
    <div
      class="product-box coll-page"
      id="Product_box_{{ card_product.id }}"
      data-stockinfo="{{ card_product.metafields.arena.stockinfo }}"
    >
      <a href="{{ card_product.url }}">
        <div class="box-img">
          <img
            src="{{ card_product.featured_media | image_url: width: 400 }}"
            alt="{{ card_product.title | escape }}"
            class="motion-reduce"
            loading="lazy"
            width="400"
            height="400"
          >
          <div class="main-tags">
            {%- for coll in card_product.collections -%}
              {% if coll.title == settings.collectionss.title %}
             {% comment %} NA DE BLACKFRIDAY AANZETTEN {% endcomment %}
                {% comment %} <div class="collname" style="color: {{ settings.tag_color }}; background: {{ settings.tag_background }};">
                  <span class="super" style="color: {{ settings.tag_color }};">{{ settings.tag_title }}</span>
                  <span class="sale" style="color: {{ settings.tag_color2 }};">{{ settings.tag_title2 }}</span>
                </div> {% endcomment %}
                <div class="notification-bar" style="background:none!important; padding: 0px!important;border-radius: 10px!important;">
                  <div class="notification-block">
                      <h6 style="padding: 4px 10px !important; width: 100%; border-radius: 5px;">
                          <b>SUPER</b>
                          <span>SALE</span>
                      </h6>
              </div>
            </div>
              {% endif %}
            {% endfor %}
            {%- if card_product.compare_at_price > card_product.price -%}
              {% capture discount %}{{ card_product.compare_at_price_max | minus:card_product.price | money }}€{% endcapture %}
              <label class="desk-label">€{{ discount | remove: ',00€' | remove: '€' }} korting</label>
            {% endif %}
          </div>
        </div>
        <div class="description">
          <h3>{{ card_product.title }}</h3>
          {% assign current_variant = card_product.selected_or_first_available_variant %}
          {% if current_variant.inventory_quantity > 0 %}
            <h5 class="stockss show-stock-desktop show-stock-tablet show-stock-mobile">
              <!-- <b> -->
              <!-- <i class="fas fa-check"></i> -->
              Op voorraad
              <!-- </b> -->
              <!-- (vandaag besteld, binnen 1-5 dagen bezorgd) -->
            </h5>
          {% endif %}
          {% if card_product.metafields.arena.stockinfo != blank and current_variant.inventory_quantity <= 0 %}
            <h5 class="weekss show-delivery-weeks-desktop show-delivery-weeks-tablet show-delivery-weeks-mobile"></h5>
          {% endif %}
          {%- if card_product.compare_at_price > card_product.price -%}
            <p>
              Adviesprijs <span class="sale-line-as-before">{{ card_product.compare_at_price | money }}</span>
            </p>
          {% endif %}
          {% comment %}
            {% assign current_variant = card_product.selected_or_first_available_variant %}
            {% if current_variant.inventory_quantity > 0 %}
                  <h5 class="stockss"><b><i class="fas fa-check"></i> Op voorraad</b> (vandaag besteld, binnen 1-10 werkdagen bezorgd)</h5>
            {% endif %}
          {% endcomment %}
  
          <h6>{{ card_product.price | money }}</h6>
          {%- if card_product.compare_at_price > card_product.price -%}
            {% capture discount %}{{ card_product.compare_at_price_max | minus:card_product.price | money }}€{% endcapture %}
            <label class="mob-label">€{{ discount | remove: ',00€' | remove: '€' }} korting</label>
          {% endif %}
        </div>
      </a>
    </div>
  </div>
  
  <script>
    $(document).ready(function () {
      function getMondayOfWeek(weekNumber, year) {
        year = year || new Date().getFullYear();
        let jan1 = new Date(year, 0, 1);
        let jan1Day = jan1.getDay();
        let offset = jan1Day <= 4 ? 1 - jan1Day : 8 - jan1Day;
        let monday = new Date(year, 0, 1 + offset + (weekNumber - 1) * 7);
        let day = monday.getDate();
        const monthName = monday.toLocaleString('nl-NL', { month: 'long' });
        return `${day} ${monthName}`;
      }
  
      function getMondayOfWeekFromToday(weeksFromToday) {
        let today = new Date();
        let targetDate = new Date(today.getFullYear(), today.getMonth(), today.getDate() + weeksFromToday * 7);
        let day = targetDate.getDay();
        let diffToMonday = day === 0 ? -6 : 1 - day;
        let monday = new Date(targetDate);
        monday.setDate(targetDate.getDate() + diffToMonday);
        let mondayDay = monday.getDate();
        const monthName = monday.toLocaleString('nl-NL', { month: 'long' });
        return `${mondayDay} ${monthName}`;
      }
  
      $('.product-box.coll-page').each(function () {
        let $item = $(this);
        let levertijdText = $item.data('stockinfo');
  
        if (!levertijdText) {
          console.warn('No stockinfo metafield for this product.');
          return;
        }
  
        const rangeRegex = /tussen de\s+(\d+)\s+en\s+(\d+)\s+weken/i;
        const singleWeekRegex = /(\d+)\s*weken?/i;
        const vanafWeekRegex = /vanaf\s+week\s+(\d+)/i;
  
        let updatedText = levertijdText;
  
        if (rangeRegex.test(levertijdText)) {
          let match = levertijdText.match(rangeRegex);
          let earliestWeek = parseInt(match[1]);
          let dateAndMonth = getMondayOfWeekFromToday(earliestWeek);
          updatedText = `Levering vanaf ${dateAndMonth}`;
        } else if (vanafWeekRegex.test(levertijdText)) {
          let match = levertijdText.match(vanafWeekRegex);
          let weekNumber = parseInt(match[1]);
          let dateAndMonth = getMondayOfWeek(weekNumber);
          updatedText = `Levering vanaf ${dateAndMonth}`;
        } else if (singleWeekRegex.test(levertijdText)) {
          let match = levertijdText.match(singleWeekRegex);
          let weekNumber = parseInt(match[1]);
          let dateAndMonth = getMondayOfWeek(weekNumber);
          updatedText = `Levering vanaf ${dateAndMonth}`;
        } 
  
        $item.find('h5.weekss').text(updatedText);
      });
    });
  </script>
  
  <style>
    {% unless settings.show_stock_desktop %}
      .show-stock-desktop {
        display: none !important;
      }
    {% endunless %}
    
    {% unless settings.show_stock_tablet %}
      @media (max-width: 1024px) and (min-width: 768px) {
        .show-stock-tablet {
          display: none !important;
        }
      }
    {% endunless %}
    
    {% unless settings.show_stock_mobile %}
      @media (max-width: 767px) {
        .show-stock-mobile {
          display: none !important;
        }
      }
    {% endunless %}
    
    {% unless settings.show_delivery_weeks_desktop %}
      .show-delivery-weeks-desktop {
        display: none !important;
      }
    {% endunless %}
    
    {% unless settings.show_delivery_weeks_tablet %}
      @media (max-width: 1024px) and (min-width: 768px) {
        .show-delivery-weeks-tablet {
          display: none !important;
        }
      }
    {% endunless %}
    
    {% unless settings.show_delivery_weeks_mobile %}
      @media (max-width: 767px) {
        .show-delivery-weeks-mobile {
          display: none !important;
        }
      }
    {% endunless %}
  
  </style>
{% endunless %}