<span class="field-currency" style="display:none;">{{ cart.currency.symbol }}</span>
{% comment %}
  <div class="field" style="display:none;">
    <input
      class="field__input"
      name="{{ filter.min_value.param_name }}"
      id="{{ id_prefix }}{{ filter.label | escape }}-GTE"
      {%- if filter.min_value.value -%}
        value="{{ filter.min_value.value | money_without_currency }}"
        {% else %}
        value="0"
      {%- endif -%}
      type="text"
      inputmode="decimal"
      placeholder="0"
      data-pattern="\d| |,|\."
      data-min="0"
      data-max="{{ filter.range_max | money_without_currency }}"
    >
    <label class="field__label" for="{{ id_prefix }}{{ filter.label | escape }}-GTE">
      {{- 'products.facets.from' | t -}}
    </label>
  </div>

  {%- if filter_type != 'vertical' -%}
    <span class="field-currency" style="display:none;">{{ cart.currency.symbol }}</span>
  {%- endif -%}
  {%- assign max_price_amount1 = filter.range_max | strip_html | escape -%}
  <div class="field" style="display:none;">
    <input
      class="field__input"
      name="{{ filter.max_value.param_name }}"
      id="{{ id_prefix }}{{ filter.label | escape }}-LTE"
      {%- if filter.max_value.value -%}
        value="{{ filter.max_value.value | money_without_currency | remove: '.' }}"
        {% else %}
        value="{{ max_price_amount1 | money_without_currency | remove: '.' }}"
      {%- endif -%}
      type="text"
      inputmode="decimal"
      placeholder="{{ filter.range_max | money_without_currency }}"
      data-pattern="\d| |,|\."
      data-min="0"
      data-max="{{ filter.range_max | money_without_currency }}"
    >
    <label class="field__label" for="{{ id_prefix }}{{ filter.label | escape }}-LTE">
      {{- 'products.facets.to' | t -}}
    </label>
  </div>
{% endcomment %}
{%- assign max_price_amount1 = filter.range_max | strip_html | escape -%}
<style>
  /* Mobile price slider styles */
  .mobile-facets__submenu .range-box .slider-range.ui-slider,
  .mobile-facets__submenu .range-box .slider-range.ui-widget.ui-widget-content {
    position: relative;
    width: 100% !important;
    height: 5px !important;
    border: none !important;
    box-shadow: none !important;
    outline: none !important;
    border-radius: 15px;
    background: #d8d8d8 !important;
    margin: 0 0 15px 0;
    display: block !important;
  }
  
  .mobile-facets__submenu .range-box .ui-slider .ui-slider-range {
    background: #fb5a00 !important;
    height: 100% !important;
    border-radius: 15px;
  }
  
  .mobile-facets__submenu .range-box .ui-slider .ui-slider-handle {
    width: 17px !important;
    height: 17px !important;
    background: #fb5a00 !important;
    border-radius: 20px !important;
    border: none !important;
    box-shadow: none !important;
    outline: none !important;
    top: -7px !important;
    margin: 0 !important;
    cursor: pointer;
  }
  
  .mobile-facets__submenu .range-box .ui-slider .ui-slider-handle:focus {
    outline: none !important;
  }
</style>
<div class="range-box mt-4" data-price-range-max="{{ max_price_amount1 | money_without_currency | remove: '.' }}" data-filter-label="{{ filter.label | escape }}">
  <div class="slider-range"></div>
  {% comment %}
    <div class="slider-range ui-slider ui-corner-all ui-slider-horizontal ui-widget ui-widget-content">
      <div class="ui-slider-range ui-corner-all ui-widget-header" style="left: 0%; width: 100%;"></div>
      <span tabindex="0" class="ui-slider-handle ui-corner-all ui-state-default" style="left: 0%;"></span>
      <span tabindex="0" class="ui-slider-handle ui-corner-all ui-state-default" style="left: 100%;"></span>
    </div>
  {% endcomment %}
  <ul>
    <li>
      <input
        type="text"
        disabled
        class="min-value"
        name="{{ filter.min_value.param_name }}"
        id="{{ id_prefix }}{{ filter.label | escape }}-GTE"
        {%- if filter.min_value.value -%}
          value="{{ filter.min_value.value | money_without_currency }}"
        {% else %}
          value="0"
        {%- endif -%}
        data-max="{{ filter.range_max | money_without_currency }}"
        data-min="0"
      >
    </li>
    <li><span class="line"></span></li>
    <li>
      <input
        type="text"
        disabled
        class="max-value"
        name="{{ filter.max_value.param_name }}"
        id="{{ id_prefix }}{{ filter.label | escape }}-LTE"
        {%- if filter.max_value.value -%}
          value="{{ filter.max_value.value | money_without_currency | remove: '.' }}"
        {% else %}
          value="{{ max_price_amount1 | money_without_currency | remove: '.' }}"
        {%- endif -%}
        data-max="{{ filter.range_max | money_without_currency }}"
        data-min="0"
      >
    </li>
  </ul>
</div>
<script>
  /* **** RANGE SLIDER - MOBILE **** */
  $(function() {
    // Wait for mobile facets to be available and jQuery UI slider to be loaded
    function initMobilePriceSlider() {
      // Try to find the range-box - use multiple selector strategies
      var $rangeBox = $('.mobile-facets__submenu .range-box[data-filter-label="{{ filter.label | escape }}"]');
      
      // Fallback: if specific selector doesn't work, try finding by input ID
      if ($rangeBox.length === 0) {
        var $minInput = $('#{{ id_prefix }}{{ filter.label | escape }}-GTE');
        if ($minInput.length) {
          $rangeBox = $minInput.closest('.range-box');
        }
      }
      
      // Fallback: find any range-box in mobile submenu if still not found
      if ($rangeBox.length === 0) {
        $rangeBox = $('.mobile-facets__submenu .range-box').first();
      }
      
      if ($rangeBox.length === 0) return;
      
      // Check if jQuery UI slider is available
      if (typeof $.fn.slider === 'undefined') {
        setTimeout(initMobilePriceSlider, 100);
        return;
      }
      
      var maxValue = parseFloat($rangeBox.attr('data-price-range-max')) || {{ max_price_amount1 | money_without_currency | remove: '.' }};
      var $minInput = $rangeBox.find('.min-value');
      var $maxInput = $rangeBox.find('.max-value');
      var $slider = $rangeBox.find('.slider-range');
      
      if ($slider.length === 0 || $minInput.length === 0 || $maxInput.length === 0) return;
      
      // Get current values from inputs or use defaults
      var currentMin = parseFloat($minInput.val()) || 0;
      var currentMax = parseFloat($maxInput.val()) || maxValue;
      
      // Ensure values are within valid range
      currentMin = Math.max(0, Math.min(currentMin, maxValue));
      currentMax = Math.max(currentMin, Math.min(currentMax, maxValue));
      
      // Destroy existing slider if it exists
      if ($slider.hasClass('ui-slider')) {
        try {
          $slider.slider('destroy');
          // Remove all ui-slider classes to ensure clean state
          $slider.removeClass('ui-slider ui-corner-all ui-slider-horizontal ui-widget ui-widget-content');
          $slider.empty(); // Clear any slider-generated HTML
        } catch(e) {
          // Force remove classes and clear content
          $slider.removeClass('ui-slider ui-corner-all ui-slider-horizontal ui-widget ui-widget-content');
          $slider.empty();
        }
      }
      
      // Initialize slider
      try {
        
        $slider.slider({
          range: true,
          min: 0,
          max: maxValue,
          values: [currentMin, currentMax],
          slide: function (event, ui) {
            // Update the visible input values
            $minInput.val(Math.round(ui.values[0]));
            $maxInput.val(Math.round(ui.values[1]));
            // Don't auto-submit on mobile - user clicks apply button
          },
          change: function (event, ui) {
            // Ensure values are synced when slider stops
            $minInput.val(Math.round(ui.values[0]));
            $maxInput.val(Math.round(ui.values[1]));
          }
        });
        
        // Verify slider was created and ensure it's visible
        if ($slider.hasClass('ui-slider')) {
          
          // Ensure slider has proper dimensions and visibility
          $slider.css({
            'width': '100%',
            'height': '5px',
            'display': 'block',
            'visibility': 'visible',
            'opacity': '1'
          });
          
          // Check if slider has width/height
          var sliderWidth = $slider.width();
          var sliderHeight = $slider.height();
          
          if (sliderWidth === 0 || sliderHeight === 0) {
          }
        } 
        
        // Sync input values with slider on initialization
        $minInput.val(Math.round($slider.slider("values", 0)));
        $maxInput.val(Math.round($slider.slider("values", 1)));
        
        // Handle manual input changes
        $minInput.off('change.priceSlider').on('change.priceSlider', function() {
          var val = parseFloat($(this).val()) || 0;
          val = Math.max(0, Math.min(val, maxValue));
          var maxVal = $slider.slider("values", 1);
          if (val > maxVal) val = maxVal;
          $slider.slider("values", [val, maxVal]);
          $(this).val(Math.round(val));
        });
        
        $maxInput.off('change.priceSlider').on('change.priceSlider', function() {
          var val = parseFloat($(this).val()) || maxValue;
          val = Math.max(0, Math.min(val, maxValue));
          var minVal = $slider.slider("values", 0);
          if (val < minVal) val = minVal;
          $slider.slider("values", [minVal, val]);
          $(this).val(Math.round(val));
        });
      } catch (e) {
        $slider.hide();
        $minInput.show();
        $maxInput.show();
      }
    }
    
    // Initialize immediately if DOM is ready, otherwise wait
    if (document.readyState === 'loading') {
      $(document).ready(function() {
        setTimeout(initMobilePriceSlider, 100);
      });
    } else {
      setTimeout(initMobilePriceSlider, 100);
    }
    
    // Re-initialize when mobile facets menu is opened (for dynamic content)
    $(document).on('click', '.mobile-facets__summary', function() {
      setTimeout(initMobilePriceSlider, 500);
    });
    
    // Also re-initialize when details element opens (for price filter specifically)
    $(document).on('click', 'details[id*="Details-Mobile"][open]', function() {
      setTimeout(initMobilePriceSlider, 300);
    });
  });
    // if($("#Filter-{{ filter.label | escape }}-LTE").val() != null){
    //     var x = $("#Filter-{{ filter.label | escape }}-LTE").val();
    //      x = new Intl.NumberFormat('en-DE').format(x);
    //       $(".max-value").val(x);
    // }
    // if($("#Filter-{{ filter.label | escape }}-GTE").val() != null){
    //     var y = $("#Filter-{{ filter.label | escape }}-GTE").val();
    //       y = new Intl.NumberFormat('en-DE').format(y);
    //      $(".min-value").val(y);
    // }
  // $(".min-value").val($(".slider-range").slider("values", 0));
  // $(".max-value").val($(".slider-range").slider("values", 1));
  /* **** END RANGE SLIDER **** */
</script>
{% comment %}
  <!-- mobile slider script -->
  <script>
      /* **** RANGE SLIDER **** */
   $(function() {
      $(".mobile-facets__submenu .slider-range").slider({
         range: true,
         min: 0,
         value:79,
         max: {{ max_price_amount1 | money_without_currency | remove: '.' }},
         values: [ $("#Mobile-Filter-{{ filter.label | escape }}-GTE").val() , $("#Mobile-Filter-{{ filter.label | escape }}-LTE").val() ],
         slide: function (event, ui) {
            $('.mobile-facets__submenu .slider-range').find(".min-value").val(ui.values[0]);
            $('.mobile-facets__submenu .slider-range').find(".max-value").val(ui.values[1]);
            $("#Mobile-Filter-{{ filter.label | escape }}-GTE").attr({"max" : ui.values[ 1 ], "min" : ui.values[ 0 ],"value" : ui.values[ 0 ] }).trigger('click');
            $("#Mobile-Filter-{{ filter.label | escape }}-LTE").attr({"max" : ui.values[ 1 ], "min" : ui.values[ 0 ],"value" : ui.values[ 1 ] }).trigger('click');
              $('#FacetFiltersFormMobile').trigger('submit');
        },
      });
        if($("#Mobile-Filter-{{ filter.label | escape }}-LTE").val() != null){
            var x1 = $("#Mobile-Filter-{{ filter.label | escape }}-LTE").val();
             x1 = new Intl.NumberFormat('en-DE').format(x1);
              $('.mobile-facets__submenu .slider-range').find(".max-value").val(x1);
        }
        if($("#Mobile-Filter-{{ filter.label | escape }}-GTE").val() != null){
            var y1 = $("#Mobile-Filter-{{ filter.label | escape }}-GTE").val();
              y1 = new Intl.NumberFormat('en-DE').format(y1);
             $('.mobile-facets__submenu .slider-range').find(".min-value").val(y1);
        }
      $('.mobile-facets__submenu .slider-range').find(".min-value").val($(".mobile-facets__submenu .slider-range").slider("values", 0));
      $('.mobile-facets__submenu .slider-range').find(".max-value").val($(".mobile-facets__submenu .slider-range").slider("values", 1));
    /* **** END RANGE SLIDER **** */
    });
  </script>
{% endcomment %}
