<div class="product-box-main">
  <div class="container relative">
    <div class="row">
      <div class="col-md-6 col-sm-12">
        <div class="main-box">
          {%- for media in product.media limit: 1 -%}
            <div class="box-img">
              <img src="{{ media.preview_image | image_url: width: 100 }}" alt="">
            </div>
          {% endfor %}
          <div>
            <h3>{{ product.title | escape }}</h3>

            <div class="product-overview-block3">
              <div class="product-price flex gap-3 relative">
                {%- if product.compare_at_price > product.price -%}
                  <span class="original-price text-muted font-light text-xl md:text-2xl">
                    <b>{{ product.compare_at_price | money }}</b>
                  </span>
                {%- endif -%}
                <span class="current-price text-dmi text-3xl md:text-5xl font-bold">{{ product.price | money }}</span>

         

              </div>
            </div>
          </div>

        </div>
      </div>
      <div class="col-md-6 col-sm-12">
        <div class="wishlistss">
          <quantity-input data-url="{{ product.url }}" data-section="{{ section.id }}">
            <div class="form-group" id="Quantity-Form-{{ section.id }}">
              <select name="quantity" class="form-control" id="Quantity-{{ section.id }}">
                {%- assign quantity_step = product.metafields.custom.quantity_steps.value | default: 1 | times: 1 -%}
                {%- for i in (1..15) -%}
                  {%- assign quantity_value = i | times: quantity_step -%}
                  <option value="{{ quantity_value }}">{{ quantity_value }}</option>
                {%- endfor -%}
              </select>
            </div>
            <script>
              $(document).on('change', 'select.form-control#Quantity-{{ section.id }}3', function () {
                $('.product-form_quantity').val($(this).val());
              });
            </script>
          </quantity-input>
          {% if product.has_only_default_variant %}
            <product-form class="product-form" data-section-id="{{ section.id }}">
              <div class="product-form__error-message-wrapper" role="alert" hidden>
                <svg
                  aria-hidden="true"
                  focusable="false"
                  role="presentation"
                  class="icon icon-error"
                  viewBox="0 0 13 13"
                >
                  <circle cx="6.5" cy="6.50049" r="5.5" stroke="white" stroke-width="2"/>
                  <circle cx="6.5" cy="6.5" r="5.5" fill="#EB001B" stroke="#EB001B" stroke-width="0.7"/>
                  <path d="M5.87413 3.52832L5.97439 7.57216H7.02713L7.12739 3.52832H5.87413ZM6.50076 9.66091C6.88091 9.66091 7.18169 9.37267 7.18169 9.00504C7.18169 8.63742 6.88091 8.34917 6.50076 8.34917C6.12061 8.34917 5.81982 8.63742 5.81982 9.00504C5.81982 9.37267 6.12061 9.66091 6.50076 9.66091Z" fill="white"/>
                  <path d="M5.87413 3.17832H5.51535L5.52424 3.537L5.6245 7.58083L5.63296 7.92216H5.97439H7.02713H7.36856L7.37702 7.58083L7.47728 3.537L7.48617 3.17832H7.12739H5.87413ZM6.50076 10.0109C7.06121 10.0109 7.5317 9.57872 7.5317 9.00504C7.5317 8.43137 7.06121 7.99918 6.50076 7.99918C5.94031 7.99918 5.46982 8.43137 5.46982 9.00504C5.46982 9.57872 5.94031 10.0109 6.50076 10.0109Z" fill="white" stroke="#EB001B" stroke-width="0.7" />
                </svg>
                <span class="product-form__error-message"></span>
              </div>

              {%- form 'product',
                product,
                id: product_form_id,
                class: 'form',
                novalidate: 'novalidate',
                data-type: 'add-to-cart-form'
              -%}
                <input type="hidden" name="quantity" class="product-form_quantity" value="1">
                <input
                  type="hidden"
                  name="id"
                  value="{{ product.selected_or_first_available_variant.id }}"
                  {% if product.selected_or_first_available_variant.available == false %}
                    disabled
                  {% endif %}
                  class="product-variant-id"
                >

                <div class="product-form__buttons">
                  <button
                    id="ProductSubmitButton-{{ section.id }}"
                    type="submit"
                    name="add"
                    class="
                      btn-orange new-color product-form__submit button--full-width btn-atc-sticky
                      {% if block.settings.show_dynamic_checkout %}button--secondary{% else %}button--primary{% endif %}
                    "
                    {% if product.selected_or_first_available_variant.available == false %}
                      disabled
                    {% endif %}
                  >
                    {%- if product.selected_or_first_available_variant.available == false -%}
                      {{ 'products.product.sold_out' | t }}
                    {%- else -%}
                      In winkelwagen
                    {%- endif -%}
                    {%- render 'loading-spinner' -%}
                  </button>
                </div>
              {%- endform -%}
            </product-form>
          {% else %}
            <a href="#variantss">
              <button
                class="btn-orange new-color button--primary"
                {% if product.selected_or_first_available_variant.available == false %}
                  disabled
                {% endif %}
              >
                {%- if product.selected_or_first_available_variant.available == false -%}
                  {{ 'products.product.sold_out' | t }}
                {%- else -%}
                  In winkelwagen
                {%- endif -%}
              </button>
            </a>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</div>
