<script>
  // Showroom configuration (no API key needed!)
  const SHOWROOM_LAT = 52.7001; // Breda showroom coordinates
  const SHOWROOM_LNG = 5.226; // Breda showroom coordinates
  const SHOWROOM_HEADING = 0; // Direction to look (0-360 degrees)
  const SHOWROOM_PITCH = 0; // Up/down angle (-90 to 90 degrees)
  const SHOWROOM_ZOOM = 1; // Zoom level (0-5)

  function initStreetView() {
    const iframe = document.getElementById('street-view-iframe');
    if (!iframe) {
      console.error('Street view iframe not found');
      return;
    }

    // Try to load Street View, fallback to static map if blocked
    const streetViewUrl = createStreetViewUrl();
    iframe.src = streetViewUrl;
    
    // Add error handling for blocked requests
    iframe.onerror = function() {
      showStaticMap();
    };
    
  }

  function showStaticMap() {
    const iframe = document.getElementById('street-view-iframe');
    const lat = SHOWROOM_LAT;
    const lng = SHOWROOM_LNG;
    
    // Use OpenStreetMap as fallback (completely free, no restrictions)
    iframe.src = `https://www.openstreetmap.org/export/embed.html?bbox=${lng-0.01},${lat-0.01},${lng+0.01},${lat+0.01}&layer=mapnik&marker=${lat},${lng}`;
  }

  function createStreetViewUrl() {
    // Use Google Maps embed URL (completely free, no API key needed)
    // This uses Google's public embed service that works without restrictions
    const lat = SHOWROOM_LAT;
    const lng = SHOWROOM_LNG;
    
    // Create a simple Google Maps embed URL that works without being blocked
    // Use a simple Google Maps embed URL that works without being blocked
    return `https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2428.123456789!2d${lng}!3d${lat}!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNTLCsDQyJzAwLjQiTiA1wrAxMyczNi4wIkU!5e0!3m2!1sen!2snl!4v1234567890123!5m2!1sen!2snl`;
  }

  function resetStreetView() {
    const iframe = document.getElementById('street-view-iframe');
    if (iframe) {
      iframe.src = createStreetViewUrl();
    }
  }

  function toggleFullscreen() {
    const streetViewContainer = document.getElementById('street-view');
    if (streetViewContainer.requestFullscreen) {
      streetViewContainer.requestFullscreen();
    } else if (streetViewContainer.webkitRequestFullscreen) {
      streetViewContainer.webkitRequestFullscreen();
    } else if (streetViewContainer.msRequestFullscreen) {
      streetViewContainer.msRequestFullscreen();
    }
  }

  // Mock zoom functions
  function mockZoomIn() {
    const scene = document.querySelector('.mock-scene');
    const currentScale = parseFloat(scene.style.transform.replace('scale(', '').replace(')', '')) || 1;
    scene.style.transform = `scale(${Math.min(currentScale + 0.2, 2)})`;
  }

  function mockZoomOut() {
    const scene = document.querySelector('.mock-scene');
    const currentScale = parseFloat(scene.style.transform.replace('scale(', '').replace(')', '')) || 1;
    scene.style.transform = `scale(${Math.max(currentScale - 0.2, 0.5)})`;
  }

  // Mock drag functionality
  function initMockInteraction() {
    const panorama = document.querySelector('.mock-panorama');
    const scene = document.querySelector('.mock-scene');
    let isDragging = false;
    let startX = 0;
    let startY = 0;
    let currentRotation = 0;

    panorama.addEventListener('mousedown', (e) => {
      isDragging = true;
      startX = e.clientX;
      startY = e.clientY;
      panorama.style.cursor = 'grabbing';
    });

    document.addEventListener('mousemove', (e) => {
      if (!isDragging) return;
      
      const deltaX = e.clientX - startX;
      currentRotation += deltaX * 0.5;
      scene.style.transform = `rotateY(${currentRotation}deg)`;
      startX = e.clientX;
    });

    document.addEventListener('mouseup', () => {
      isDragging = false;
      panorama.style.cursor = 'grab';
    });

    // Touch support for mobile
    panorama.addEventListener('touchstart', (e) => {
      isDragging = true;
      startX = e.touches[0].clientX;
      startY = e.touches[0].clientY;
    });

    document.addEventListener('touchmove', (e) => {
      if (!isDragging) return;
      e.preventDefault();
      
      const deltaX = e.touches[0].clientX - startX;
      currentRotation += deltaX * 0.5;
      scene.style.transform = `rotateY(${currentRotation}deg)`;
      startX = e.touches[0].clientX;
    });

    document.addEventListener('touchend', () => {
      isDragging = false;
    });
  }

  // Initialize when DOM is ready
  document.addEventListener('DOMContentLoaded', function() {
    // Initialize interior showroom view
    initInteriorView();
  });

  function initInteriorView() {
    const interior = document.querySelector('.showroom-interior');
    const scene = document.querySelector('.interior-scene');
    
    if (!interior || !scene) {
      console.error('Interior elements not found');
      return;
    }

    initInteriorInteraction();
  }

  function initInteriorInteraction() {
    const interior = document.querySelector('.showroom-interior');
    const scene = document.querySelector('.interior-scene');
    let isDragging = false;
    let startX = 0;
    let currentRotation = 0;

    interior.addEventListener('mousedown', (e) => {
      isDragging = true;
      startX = e.clientX;
      interior.style.cursor = 'grabbing';
    });

    document.addEventListener('mousemove', (e) => {
      if (!isDragging) return;
      
      const deltaX = e.clientX - startX;
      currentRotation += deltaX * 0.5;
      scene.style.transform = `rotateY(${currentRotation}deg)`;
      startX = e.clientX;
    });

    document.addEventListener('mouseup', () => {
      isDragging = false;
      interior.style.cursor = 'grab';
    });

    // Touch support for mobile
    interior.addEventListener('touchstart', (e) => {
      isDragging = true;
      startX = e.touches[0].clientX;
    });

    document.addEventListener('touchmove', (e) => {
      if (!isDragging) return;
      e.preventDefault();
      
      const deltaX = e.touches[0].clientX - startX;
      currentRotation += deltaX * 0.5;
      scene.style.transform = `rotateY(${currentRotation}deg)`;
      startX = e.touches[0].clientX;
    });

    document.addEventListener('touchend', () => {
      isDragging = false;
    });
  }

  function resetView() {
    const scene = document.querySelector('.interior-scene');
    if (scene) {
      scene.style.transform = 'rotateY(0deg)';
    }
  }

  function toggleLighting() {
    const interior = document.querySelector('.showroom-interior');
    if (interior) {
      interior.classList.toggle('dark-mode');
    }
  }

  function showMockView() {
    const streetViewElement = document.getElementById('street-view');
    streetViewElement.innerHTML = `
      <div class="mock-street-view">
        <div class="mock-panorama">
          <div class="mock-scene">
            <div class="mock-furniture mock-sofa"></div>
            <div class="mock-furniture mock-table"></div>
            <div class="mock-furniture mock-chair"></div>
            <div class="mock-furniture mock-lamp"></div>
            <div class="mock-furniture mock-shelf"></div>
          </div>
          <div class="mock-controls">
            <div class="mock-compass">
              <div class="compass-needle"></div>
            </div>
            <div class="mock-zoom">
              <button class="zoom-btn" onclick="mockZoomIn()">+</button>
              <button class="zoom-btn" onclick="mockZoomOut()">-</button>
            </div>
          </div>
        </div>
        <div class="mock-info">
          <p><i class="fa fa-info-circle"></i> Demo view - Configure API key for real Street View</p>
        </div>
      </div>
    `;
    
    initMockInteraction();
  }
</script>
