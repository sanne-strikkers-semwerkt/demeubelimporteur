{% comment %}
  Virtual Showroom Tour Snippet
  360° view of your physical showrooms using Google Street View
{% endcomment %}

<div class="virtual-showroom-tour">
  <div class="page-width">
    <div class="showroom-header">
      <h2 class="showroom-title">Bekijk onze showroom in 360°</h2>
      <p class="showroom-description">Ontdek onze fysieke showroom vanuit je eigen huis</p>
    </div>

    <div class="showroom-container">
      <div class="street-view-container">
        <div id="street-view" class="street-view-iframe">
          <div class="showroom-interior">
            <div class="interior-scene">
              <div class="furniture-display">
                <div class="furniture-item sofa-1"></div>
                <div class="furniture-item table-1"></div>
                <div class="furniture-item chair-1"></div>
                <div class="furniture-item lamp-1"></div>
                <div class="furniture-item shelf-1"></div>
                <div class="furniture-item sofa-2"></div>
                <div class="furniture-item table-2"></div>
                <div class="furniture-item chair-2"></div>
              </div>
              <div class="room-walls">
                <div class="wall wall-front"></div>
                <div class="wall wall-left"></div>
                <div class="wall wall-right"></div>
                <div class="wall wall-back"></div>
              </div>
              <div class="room-floor"></div>
              <div class="room-ceiling"></div>
            </div>
            <div class="interior-controls">
              <div class="control-panel">
                <button onclick="resetView()" class="control-btn" title="Reset View">
                  <i class="fa fa-home"></i>
                </button>
                <button onclick="toggleFullscreen()" class="control-btn" title="Fullscreen">
                  <i class="fa fa-expand"></i>
                </button>
                <button onclick="toggleLighting()" class="control-btn" title="Toggle Lighting">
                  <i class="fa fa-lightbulb"></i>
                </button>
              </div>
              <div class="view-info">
                <p><i class="fa fa-info-circle"></i> 360° Interieur view van onze showroom</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="showroom-info">
        <div class="showroom-details">
          <h3>Onze Showroom</h3>
          <div class="detail-item">
            <i class="fa fa-map-marker-alt"></i>
            <div>
              <strong>Adres:</strong>
              <p>Industrieweg 7, 1613 KT Breda</p>
            </div>
          </div>
          
          <div class="detail-item">
            <i class="fa fa-clock"></i>
            <div>
              <strong>Openingstijden:</strong>
              <p>Ma: 11:00-17:00<br>Di-Vr: 09:00-17:30<br>Za: 09:00-17:00<br>Zo: Gesloten</p>
            </div>
          </div>
          
          <div class="detail-item">
            <i class="fa fa-phone"></i>
            <div>
              <strong>Telefoon:</strong>
              <p>+31 228 123 456</p>
            </div>
          </div>
          
          <div class="detail-item">
            <i class="fa fa-route"></i>
            <div>
              <strong>Routebeschrijving:</strong>
              <a href="https://www.google.com/maps/search/?api=1&query=Industrieweg+7+Breda" target="_blank" class="directions-link">
                <i class="fa fa-external-link-alt"></i>
                Bekijk op Google Maps
              </a>
            </div>
          </div>
        </div>

        <div class="showroom-features">
          <h4>Wat kun je verwachten?</h4>
          <ul class="features-list">
            <li><i class="fa fa-check"></i> Volledige collectie meubels</li>
            <li><i class="fa fa-check"></i> Professioneel advies</li>
            <li><i class="fa fa-check"></i> Interieur styling tips</li>
            <li><i class="fa fa-check"></i> Gratis parkeren</li>
            <li><i class="fa fa-check"></i> Toegankelijk voor rolstoelen</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="showroom-cta">
      <h3>Bezoek onze showroom</h3>
      <p>Ervaar onze meubels in het echt en krijg persoonlijk advies van onze experts</p>
      <div class="cta-buttons">
        <a href="https://www.google.com/maps/search/?api=1&query=Industrieweg+7+Breda" target="_blank" class="btn btn-primary">
          <i class="fa fa-map-marker-alt"></i>
          Route plannen
        </a>
        <a href="tel:+31228123456" class="btn btn-secondary">
          <i class="fa fa-phone"></i>
          Bel ons
        </a>
      </div>
    </div>
  </div>
</div>

