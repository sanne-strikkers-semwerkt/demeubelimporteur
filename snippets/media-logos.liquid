{% comment %}
  Media Logos Component - Small version for header
{% endcomment %}

<div class="media-logos-header">
  
  {% comment %} <span class="font-custom-header-badge">
    Troste winnaar van
  </span>
  <div class="media-logo-item">
    <img src="{{ 'shopping-awards-logo-dark.png' | asset_url }}" alt="Slam!" class="logo-slam-header" width="auto" height="36">
  </div> {% endcomment %}

  <div class="media-logo-item">
    <img src="https://cdn.shopify.com/s/files/1/0563/8412/7158/files/shopping-awards-label-header.png?v=1776063380" alt="Shopping Awards Winnaar 2026" class="logo-slam-header" width="auto" height="36">
  </div>

</div>

<style>
/* Container */
.media-logos-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  max-width: 100%;
  padding: 0 12px; /* prevents touching screen edges */
  box-sizing: border-box;
}

/* Logo wrapper */
.media-logo-item {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
}

/* Logo image */
.logo-slam-header {
  display: block;
  max-width: 100%;   /* prevents overflow */
  height: auto;      /* keeps aspect ratio */
  max-height: 40px;  /* desktop size */
  object-fit: contain;
}

/* Optional hover */
.logo-slam-header:hover {
  opacity: 0.9;
}

/* Tablet & mobile */
@media screen and (max-width: 768px) {
  .media-logos-header {
    padding: 0 8px;
  }

  .logo-slam-header {
    max-height: 32px;
  }
}

/* Small phones */
@media screen and (max-width: 480px) {
  .logo-slam-header {
    max-height: 28px;
  }
}
</style>