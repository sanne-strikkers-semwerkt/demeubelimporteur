<div class="quicklinks-wrapper" role="region" aria-label="Sub-collection navigation">
  <div class="quicklinks-container">
    <ul class="quicklinks-list">
      {%- assign current_collection_url = collection.url -%}
      {% for sub_collection in collection.metafields.custom.sub_collection.value %}
        <li>
          <a
            href="{{ sub_collection.url }}"
            class="quicklinks-pill{% if sub_collection.url == current_collection_url %} is-active{% endif %}"
          >
            {% if sub_collection.featured_image %}
              <img
                class="quicklinks-pill__image"
                src="{{ sub_collection.featured_image | image_url: width: 80, height: 80, crop: 'center' }}"
                alt=""
                loading="lazy"
                width="32"
                height="32"
              >
            {% endif %}
            <span class="quicklinks-pill__title">
              {{ sub_collection.title | remove: 'Mangohouten' }}
            </span>
          </a>
        </li>
      {% endfor %}
    </ul>
  </div>

  <button type="button" class="quicklinks-arrow prev" aria-label="Previous slide">
    <svg
      aria-hidden="true"
      focusable="false"
      role="presentation"
      xmlns="http://www.w3.org/2000/svg"
      width="8"
      height="12"
      viewBox="0 0 8 12"
    >
      <path d="M7 1.5 2.5 6l4.5 4.5" stroke="currentColor" stroke-width="1.5" fill="none" fill-rule="evenodd"/>
    </svg>
  </button>
  <button type="button" class="quicklinks-arrow next" aria-label="Next slide">
    <svg
      aria-hidden="true"
      focusable="false"
      role="presentation"
      xmlns="http://www.w3.org/2000/svg"
      width="8"
      height="12"
      viewBox="0 0 8 12"
    >
      <path d="m1.5 1.5 4.5 4.5-4.5 4.5" stroke="currentColor" stroke-width="1.5" fill="none" fill-rule="evenodd"/>
    </svg>
  </button>
</div>

<style>
  :root {
    /* === CORE STYLES (Based on your design) === */
    --pill-height: 44px;
    --pill-bg-color: #f1f1f1;
    --pill-bg-hover-color: #f0f0f0;
    --pill-bg-active-color: #ebebeb;
    --pill-border-color: #e3e3e3;
    --pill-border-active-color: #d8d8d8;
    --pill-text-color: #212121;
    --pill-radius: 12px;
    --pill-shadow: inset 0 1px 2px rgba(0, 0, 0, 0.04);
    --pill-shadow-hover: inset 0 1px 2px rgba(0, 0, 0, 0.04), 0 4px 12px rgba(0, 0, 0, 0.08);

    --arrow-size: 36px;
    --arrow-bg-color: #ffffff;
    --arrow-border-color: #d8d8d8;
    --arrow-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);

    /* === BEHAVIOR & SPACING === */
    --page-bg-color: #ffffff; /* IMPORTANT: Must match your page's exact background */
    --gradient-width: 60px;
    --transition-speed: 0.2s;
    --transition-ease: ease-out;
  }

  /* === MAIN WRAPPER (Mobile First) === */
  .quicklinks-wrapper {
    position: relative;
    margin: 0 auto 1.5rem auto;
  }

  /* === SLIDER CONTAINER & FADE EFFECT === */
  .quicklinks-container {
    position: relative;
    overflow: hidden;
  }
  .quicklinks-container::before,
  .quicklinks-container::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    z-index: 2;
    width: var(--gradient-width);
    pointer-events: none;
    opacity: 0;
    transition: opacity var(--transition-speed) var(--transition-ease);
  }
  .quicklinks-container::before {
    left: 0;
    background: linear-gradient(to right, var(--page-bg-color) 0%, transparent 30%);
  }
  .quicklinks-container::after {
    right: 0;
    background: linear-gradient(to left, var(--page-bg-color) 0%, transparent 30%);
  }
  /* Show gradients only when scrollable */
  .quicklinks-wrapper.is-scrollable .quicklinks-container::before,
  .quicklinks-wrapper.is-scrollable .quicklinks-container::after {
    opacity: 1;
  }

  /* === SCROLLABLE LIST === */
  .quicklinks-list {
    list-style: none;
    display: flex;
    scroll-snap-type: x mandatory;
    padding: 5px 15px;
    margin: -5px 0;
    overflow-x: auto;
    scroll-behavior: smooth;
    gap: 8px;

    /* Hide scrollbar */
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .quicklinks-list::-webkit-scrollbar {
    display: none;
  }

  /* When not scrollable, add more padding for better spacing */
  .quicklinks-wrapper:not(.is-scrollable) .quicklinks-list {
    padding: 5px 40px 5px 0;
    justify-content: flex-start;
  }

  .quicklinks-list li {
    scroll-snap-align: center;
    margin: 0;
    flex-shrink: 0;
  }

  /* Cursor changes for desktop drag-to-scroll */
  .quicklinks-list.is-dragging {
    scroll-behavior: auto;
    cursor: grabbing;
  }
  .quicklinks-list.is-dragging .quicklinks-pill {
    cursor: grabbing;
  }

  /* === PILL DESIGN === */
  .quicklinks-pill {
    display: inline-flex;
    align-items: center;
    height: var(--pill-height);
    padding: 0 12px 0 8px;
    background-color: var(--pill-bg-color);
    border-radius: var(--pill-radius);
    border: 1px solid var(--pill-border-color);
    text-decoration: none;
    white-space: nowrap;
    box-shadow: var(--pill-shadow);
    cursor: pointer;
    transition: background-color var(--transition-speed) var(--transition-ease),
      border-color var(--transition-speed) var(--transition-ease),
      box-shadow var(--transition-speed) var(--transition-ease);
    min-width: fit-content;
  }
  .quicklinks-pill:hover {
    background-color: var(--pill-bg-hover-color);
    box-shadow: var(--pill-shadow-hover);
  }
  .quicklinks-pill.is-active {
    background-color: var(--pill-bg-active-color);
    border-color: var(--pill-border-active-color);
    pointer-events: none;
    cursor: default;
  }
  .quicklinks-pill__image {
    width: 32px;
    height: 32px;
    border-radius: calc(var(--pill-radius) - 2px);
    object-fit: cover;
    margin-right: 10px;
  }
  .quicklinks-pill__title {
    color: var(--pill-text-color);
    font-size: 14px;
    font-weight: 500;
    line-height: 1;
    text-transform: capitalize;
  }

  /* === ARROW DESIGN === */
  .quicklinks-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 3;
    width: var(--arrow-size);
    height: var(--arrow-size);
    border-radius: 50%;
    background-color: var(--arrow-bg-color);
    border: 1px solid var(--arrow-border-color);
    box-shadow: var(--arrow-shadow);
    cursor: pointer;
    display: flex;
    justify-content: center;
    align-items: center;
    color: #333;
    opacity: 0;
    visibility: hidden;
    transition: all 0.2s ease;
  }
  /* Show arrows only when scrollable */
  .quicklinks-wrapper.is-scrollable .quicklinks-arrow {
    opacity: 1;
    visibility: visible;
  }
  .quicklinks-arrow:hover {
    transform: translateY(-50%) scale(1.1);
    border-color: #b0b0b0;
  }
  .quicklinks-arrow.prev {
    left: -15px;
  }
  .quicklinks-arrow.next {
    right: -15px;
  }
  .quicklinks-arrow:disabled {
    opacity: 0.2 !important;
    cursor: not-allowed;
    transform: translateY(-50%) scale(1);
    pointer-events: none;
  }

  /* === DESKTOP STIJLEN === */
  @media screen and (min-width: 1024px) {
    .quicklinks-wrapper {
      max-width: none;
    }

    .quicklinks-list {
      justify-content: flex-start;
      padding: 5px 15px;
    }

    /* When not scrollable on desktop, align left and add more padding */
    .quicklinks-wrapper:not(.is-scrollable) .quicklinks-list {
      padding: 5px 60px 5px 0;
      justify-content: flex-start;
    }

    .quicklinks-arrow.prev {
      left: 0px;
    }
    .quicklinks-arrow.next {
      right: 0px;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const wrapper = document.querySelector('.quicklinks-wrapper');
    if (!wrapper) return;

    const list = wrapper.querySelector('.quicklinks-list');
    const prevButton = wrapper.querySelector('.quicklinks-arrow.prev');
    const nextButton = wrapper.querySelector('.quicklinks-arrow.next');

    if (!list || !prevButton || !nextButton) return;

    let lastScrollableState = null;
    
    const updateSliderState = () => {
      // Voeg een marge toe om flip-flopping op breakpoints te voorkomen
      // Check eerst met de huidige state, dan pas de class toepassen
      const scrollDifference = list.scrollWidth - list.clientWidth;
      // Gebruik een marge van 10px om te voorkomen dat kleine layout changes de state veranderen
      const isScrollable = scrollDifference > 10;
      
      // Alleen de class updaten als de state daadwerkelijk veranderd is
      if (lastScrollableState !== isScrollable) {
        wrapper.classList.toggle('is-scrollable', isScrollable);
        lastScrollableState = isScrollable;
        
        // Wacht even zodat de layout kan stabiliseren na class change
        requestAnimationFrame(() => {
          // Re-check na layout stabilisatie om zeker te zijn
          const recheckDifference = list.scrollWidth - list.clientWidth;
          const recheckScrollable = recheckDifference > 10;
          
          if (recheckScrollable !== isScrollable) {
            // Als de state anders is na layout change, corrigeer het
            wrapper.classList.toggle('is-scrollable', recheckScrollable);
            lastScrollableState = recheckScrollable;
          }
        });
      }

      if (isScrollable) {
        // Gebruik een kleine tolerantie voor afrondingsfouten
        prevButton.disabled = list.scrollLeft <= 1;
        nextButton.disabled = list.scrollLeft >= list.scrollWidth - list.clientWidth - 1;
      } else {
        prevButton.disabled = true;
        nextButton.disabled = true;
      }
    };

    const getSlideWidth = () => {
      const firstItem = list.querySelector('li');
      if (!firstItem) return 0;
      const itemStyle = window.getComputedStyle(firstItem);
      const itemMargin = parseFloat(itemStyle.marginLeft) + parseFloat(itemStyle.marginRight);
      // Gebruik de scrollbreedte van het item voor meer precisie
      return firstItem.offsetWidth + itemMargin;
    };

    // --- ARROW NAVIGATION ---
    prevButton.addEventListener('click', () => {
      list.scrollLeft -= getSlideWidth();
    });
    nextButton.addEventListener('click', () => {
      list.scrollLeft += getSlideWidth();
    });

    // --- DRAG-TO-SCROLL ---
    let isDragging = false;
    let startX;
    let scrollLeft;

    list.addEventListener('mousedown', (e) => {
      isDragging = true;
      list.classList.add('is-dragging');
      startX = e.pageX - list.offsetLeft;
      scrollLeft = list.scrollLeft;
    });
    list.addEventListener('mouseleave', () => {
      isDragging = false;
      list.classList.remove('is-dragging');
    });
    list.addEventListener('mouseup', () => {
      isDragging = false;
      list.classList.remove('is-dragging');
    });
    list.addEventListener('mousemove', (e) => {
      if (!isDragging) return;
      e.preventDefault();
      const x = e.pageX - list.offsetLeft;
      const walk = (x - startX) * 2;
      list.scrollLeft = scrollLeft - walk;
    });

    // --- INITIALIZATION ---
    const initializeSlider = () => {
      const activePill = list.querySelector('.quicklinks-pill.is-active');
      if (activePill) {
        const slide = activePill.closest('li');
        if (slide) {
          // Scroll de actieve pil naar het midden
          const newScrollLeft = slide.offsetLeft - list.offsetLeft - list.clientWidth / 2 + slide.clientWidth / 2;
          list.scroll({ left: newScrollLeft, behavior: 'auto' });
        }
      }
      updateSliderState();
    };

    // Update de staat van de knoppen na het scrollen
    let scrollTimer = null;
    list.addEventListener('scroll', () => {
      clearTimeout(scrollTimer);
      scrollTimer = setTimeout(updateSliderState, 150);
    });

    // Update de staat ook als de grootte van het venster verandert
    let resizeTimer = null;
    const resizeObserver = new ResizeObserver(() => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(updateSliderState, 100);
    });
    resizeObserver.observe(list);

    // Wacht even met initialiseren om zeker te zijn dat alles geladen is
    setTimeout(initializeSlider, 100);
  });
</script>
